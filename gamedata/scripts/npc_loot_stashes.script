-- chance to yoink is (once per "looting_update_time" sec for one squad):
-- (squad_size * 0.33) * (squad_ranks_sum / squad_size) * loot_tendency[squad_community] * (1.3448 * 0.9545^distance_to)

local stashes = {}		-- "free" = free to steal, "looted" = mark for release, "safe" = safe
local enable_ngreward_looting = npc_loot_stashes_mcm.get_config("reward_loot") 		-- allows NPCs to steal stashes created by new game or given as reward
local looting_update_time = npc_loot_stashes_mcm.get_config("update_time") 		-- for one squad per irl time (4 sec = 0.8 stashes looted per in game minute averagely)
local sleeping_loot_frequency = npc_loot_stashes_mcm.get_config("sleep_freq")	-- simulates looting while sleeping by rapidly running loot function based on passed hours (0.25 = 4 times less); set to 0 to disable looting during sleep
local add_percentage = npc_loot_stashes_mcm.get_config("add_perc")	-- if two stashes proc'd with chances 1 and 200, this value of 100% will make it 201 and 400, decreasing range between and let lower chance stashes to be picked for looting more often
local npc_queue = {}		-- for updates per level
local squads_on_level = {}		-- save squads
local paid_stashes = {}
local test_actor_stash = {}		-- xcvb del
local test_stashes_looted = 0	-- xcvb del
local cost = npc_loot_stashes_mcm.get_config("cost")		-- paid stash cost per day
local max_time_limit = (npc_loot_stashes_mcm.get_config("max_time")) * 60 * 60 * 24		-- paid stash max days
local ctime_to_t = utils_data.CTime_to_table
local t_to_ctime = utils_data.CTime_from_table
local sfind = string.find
local rnd = math.random
local debugx = npc_loot_stashes_mcm.get_config("debugx")
local delete_stashes = npc_loot_stashes_mcm.get_config("delete_stashes")
local act_tmr

function pr(...)
	if not debugx then return end
	printf(...)
end

local loot_tendency = {
	["stalker"] = 1.3,
	["dolg"] = 0.9,
	["freedom"] = 1.2,
	["csky"] = 1,
	["ecolog"] = 0.5,
	["killer"] = 0.9,
	["army"] = 0.15,
	["bandit"] = 1.15,
	["monolith"] = 0.1,
	["renegade"] = 1,
	["greh"] = 0.7,
	["isg"] = 0.3,
}

local rank_to_mult = {
	["novice"] = 0.45,
	["trainee"] = 0.6,
	["experienced"] = 0.75,
	["professional"] = 0.9,
	["veteran"] = 1.05,
	["expert"] = 1.2,
	["master"] = 1.35,
	["legend"] = 1.5,
}

