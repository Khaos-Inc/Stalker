        local enemy_obj_id = enemy_id and level.object_by_id(enemy_id)
        local squad = get_object_squad(npc)
        local squad_id
        if type(squad) == "table" and squad.id then
                squad_id = squad:id()
        elseif type(squad) == "number" then
                squad_id = squad
        else
                squad_id = npc_id
        end

        if cinema_mode then
                -- Cinema Mode Activated
        elseif vanilla_mode then
                local is_companion = (alife():has_info(enemy_id, "npcx_is_companion")) or (npc:has_info("npcx_is_companion"))
                if enemy_id ~= db.actor:id() and not is_companion then return false end
        end

        --[[if swicth_table3[npc_id]["priority"].value == nil then swicth_table3[npc_id]["priority"].value = 0.05 end
        swicth_table [npc_id]["priority"].value = 0
        swicth_table2[npc_id]["priority"].value = 0
        swicth_table4[npc_id]["priority"].value = 0
        swicth_table5[npc_id]["priority"].value = 0]]--

        local t3 = time_table3[npc_id]
