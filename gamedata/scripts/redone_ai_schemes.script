-----------------------------------------------------------------------------
-- NPC UTLIS
-----------------------------------------------------------------------------
function set_table_memory(npc, enemy, table_npc, time_key)
        if not enemy or not enemy:alive() then return end
        if not table_npc then return end

        local npc_id = npc:id()
        local flag = table_npc[npc_id]
        if not flag then return end

        local schemes = time_key or {"coward", "dumb", "stupid"}
        local current_time = time_global()

        for _, key in ipairs(type(schemes) == "table" and schemes or {schemes}) do
                local last_seen_var  = "_" .. key .. "_last_seen_update"
                local seen_var       = "_" .. key .. "_seen_update"
                local time_since_var = "_" .. key .. "_time_since_last_seen"
                        npc[last_seen_var]  = npc[last_seen_var]  or current_time
                        npc[seen_var]       = npc[seen_var]       or current_time
                        npc[time_since_var] = npc[time_since_var] or 0
                local delta_last = current_time - npc[last_seen_var]
                local delta_seen = current_time - npc[seen_var]

                npc[time_since_var] = delta_last
                npc._enemy_seen = delta_seen

                if not npc._memory_enabled and delta_seen < 100 then
                        npc._memory_enabled = true
                        --printf("[DEBUG] NPC Memory table_npc")
                end

                npc._since_seen = delta_last < 100
                if npc._memory_enabled and delta_last >= 25000 then
                        npc._memory_enabled = nil
                        table_npc[npc_id] = nil
                        --printf("[DEBUG] NPC Memory table_npc nil")
                end

                local hit_time = last_hit_time and last_hit_time[npc_id]
                if hit_time and (current_time - hit_time) < 100 then
                        npc[seen_var]      = current_time
                        npc[last_seen_var] = current_time
                        --printf("[DEBUG] HIT MEMORY REFRESH")
                end

                if delta_last < 800 then
                        npc[last_seen_var] = current_time
                        npc[seen_var]      = current_time
                end
        end
end

local function set_npc_distance(npc, enemy)
	if not enemy or not enemy:alive() then
		npc._too_close = false
		return false
	end

        local id = npc:id()
        npc._too_close = npc._too_close or false

        local abort_dist, release_dist = redone_ai_combat.get_combat_distances(npc, enemy)
        if not npc._too_close then
                if xr_conditions.pure_enemy_dist_le(nil, npc, {abort_dist}) then
                        local st = db.storage[npc:id()]
                        --st.force_reposition = true
                        --st.force_reposition_until = time_global() + 5000

                        npc._too_close = true
                        --printf("[DEBUG] NPC %d ENTER too_close\n", id)
                        return true
                end
        else
                if not xr_conditions.pure_enemy_dist_le(nil, npc, {release_dist}) then
                        npc._too_close = false
                        --printf("[DEBUG] NPC %d EXIT too_close\n", id)
                end
                return npc._too_close
        end
        return false
end

local function set_cover_distance(npc)
        local pos = npc:position()
        local cover = npc:best_cover(pos, pos, 4, 1, 200)
        if not cover then npc._cover_pos = false
                return false
        end

        local cpos = cover:position()
        local distance_sq = cpos:distance_to_sqr(pos)

        if distance_sq < 0.8 then npc._cover_pos = true
                return true
        end

        npc._cover_pos = false

        if type(xr_logic) == "table" and type(xr_logic.switch_to_section) == "function" then
                xr_logic.switch_to_section(npc, "cover", nil)
        else
                local vid = cover:level_vertex_id()
                npc:set_path_type(game_object.level_path)
                npc:set_dest_level_vertex_id(vid)
        end
        return false
end

local function get_enemy_distance(npc, enemy)
	if not enemy or not enemy:alive() then return false end
	local dist_sqr = npc:position():distance_to_sqr(enemy:position())

	return dist_sqr < 100
end

local function get_weapon_type(weapon)
        local wpn = weapon
        local sec = wpn:section()
        local kind = ini_sys:r_string_ex(sec, "kind") or "unknown"
        if not sec then return false end

        local lr = {
                ["w_pistol"]   = false,
                ["w_smg"]      = true,
                ["w_rifle"]    = true,
                ["w_shotgun"]  = true,
                ["w_sniper"]   = false,
                ["w_launcher"] = false,
        }

        if lr[kind] then
                return true
        else
                return false
        end
end

local function get_sniper_weapon(wpn)
	if not wpn then return false end
	if IsSniper and IsSniper(wpn) then return true end

	local sec = wpn:section()
	local kind = ini_sys:r_string_ex(sec, "kind") or ""
        if not sec then return false end

	if kind == "w_sniper" then return true end

	return false
end

-----------------------------------------------------------------------------
-- COWARD SCHEMES
-----------------------------------------------------------------------------
function scheme_cover_coward(enemy, npc, actor)
        --printf("[DEBUG] SCHEME COWARD COVER started for NPC: %d\n", npc:id())
	if not npc or not npc:alive() then return false end
        if not enemy or not enemy:alive() then return false end

        local IsEnemy = redone_ai_combat.get_combat_enemy(npc)
        if not IsEnemy or not IsEnemy:alive() then return false end
        if (IsMonster(enemy) or character_community(enemy) == "zombied") then return false end
        if IsWounded(npc) then return false end

        local actor = db.actor
        local npc_id = npc:id()
        local enemy_id = db.storage[npc_id] and db.storage[npc_id].enemy_id
        local enemy_obj_id = enemy_id and level.object_by_id(enemy_id)
        local squad = get_object_squad(npc)
        local squad_id
        if type(squad) == "table" and squad.id then
                squad_id = squad:id()
        elseif type(squad) == "number" then
                squad_id = squad
        else
                squad_id = npc_id
        end

        if cinema_mode then
                -- Cinema Mode Activated
        elseif vanilla_mode then
                local is_companion = (alife():has_info(enemy_id, "npcx_is_companion")) or (npc:has_info("npcx_is_companion"))
                if enemy_id ~= db.actor:id() and not is_companion then return false end
        end

        --[[if swicth_table[npc_id]["priority"].value == nil then swicth_table[npc_id]["priority"].value = 0.05 end
        swicth_table2[npc_id]["priority"].value = 0
        swicth_table3[npc_id]["priority"].value = 0
        swicth_table4[npc_id]["priority"].value = 0
        swicth_table5[npc_id]["priority"].value = 0]]--

        local t1 = time_table[npc_id]
        local tg = time_global()
        local mem = npc:memory_time(enemy)

        if time_table[npc_id] == nil then time_table[npc_id] = tg - mem end

        npc._coward = mem
        if npc._coward == 0 then npc._coward = tg end

        time_table[npc_id] = tg - npc._coward
                npc._coward_time_since_last_seen = npc._coward_time_since_last_seen or 0
                npc._coward_time_since_seen      = npc._coward_time_since_seen or 0
                npc._coward_last_seen_update     = npc._coward_last_seen_update or tg
                npc._coward_seen_update          = npc._coward_seen_update or tg
        local m = mem
        if m ~= npc._coward_last_seen_update then
                npc._coward_last_seen_update = m
                npc._coward_seen_update      = m
        end
        local delta_last_seen = tg - npc._coward_last_seen_update
        local delta_seen      = tg - npc._coward_seen_update
                npc._coward_time_since_last_seen = delta_last_seen
                npc._coward_time_since_seen      = delta_seen
        local time_since_last_seen = npc._coward_time_since_last_seen
        local time_since_seen      = npc._coward_time_since_seen

        local weapon = npc:active_item()
        if not weapon then
                local bw_id = npc:best_weapon()
                weapon = bw_id and level.object_by_id(bw_id)
        end

        local actor_weapon = actor and actor:active_item()
        local is_actor_sniper = get_sniper_weapon(actor_weapon)

        local npc_see_actor = false
        local actor_see_npc = false

        if actor and actor:alive() then
                npc_see_actor = npc:see(actor)
                actor_see_npc = actor:see(npc)
        end

        local npc_see_enemy = false
        local enemy_see_npc = false

        if enemy and enemy:alive() then
                npc_see_enemy = npc:see(enemy)
                enemy_see_npc = enemy:see(npc)
        end

        local npc_health   = npc.health
        local enemy_health = enemy.health

        local pos1 = npc:position()
        local pos2 = enemy:position()
        local dist = pos1:distance_to_sqr(pos2)

        if get_enemy_distance(npc, enemy) then return false end
        if dist < 1000 or dist >= 5000 then return false end

        if IsStalker(npc) then
                if npc._cover_pos == true then npc._cover_pos = false end
                if weapon ~= nil then
                        if get_weapon_type(weapon) == true then
                                swicth_table[npc_id]["priority"].value = 1.0 + 1.5
                        else
                                swicth_table[npc_id]["priority"].value = 0.5 + 0.5
                        end
                end

                if npc_see_enemy then
                        if enemy_obj_id then
                                swicth_table[npc_id][enemy_id].value = 5.0
                        end

                	if not table_npc[npc_id] then
                		table_npc[npc_id] = true
                	end

                elseif table_npc[npc_id] then
                	set_table_memory(npc, enemy, table_npc, "coward")
                end

                if (not npc_see_actor and actor_see_npc) or (not npc_see_enemy and enemy_see_npc) then return false end

                if sniper_combat_enabled and is_actor_sniper then
                        if dist >= 500 and t1 ~= nil then
                	        if swicth_table[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                		        return true
                	        end
                                return false
                        end
                end

                if npc_health <= 0.5 and t1 ~= nil then
                	if dist >= 1000 and dist < 5000 and t1 < rnd then
                		if swicth_table[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                			return true
                		end
                		return false
                	end
                else
                	if enemy_health <= 0.25 and t1 ~= nil then
                		if dist <= 5000 and t1 < rnd then
                			if swicth_table[npc_id]["priority"].value >= 0.05 and npc_health < 0.8 then
                				return false
                			end
                			return true
                		end
                	elseif enemy_health <= 0.5 and t1 ~= nil then
                		if dist <= 2500 and t1 < rnd then
                			if swicth_table[npc_id]["priority"].value >= 0.05 and npc_health < 0.5 then
                				return false
                			end
                			return true
                		end
                	elseif enemy_health <= 0.75 and t1 ~= nil then
                		if dist <= 1500 and t1 < rnd then
                			if swicth_table[npc_id]["priority"].value >= 0.05 and npc_health < 0.3 then
                				return false
                			end
                			return true
                		end
                	end
                end

                if last_hit_time[npc_id] and tg - last_hit_time[npc_id] < 10000 then
                        --printf("[DEBUG] COWARD COVER HIT for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table[npc_id]["priority"].value = 1.0 + 5
                end

                coward_npc(npc:id())

                if is_coward(npc:id(), dist, time_since_last_seen) and swicth_table[npc:id()]["priority"].value >= 0.05 then
                        --printf("[DEBUG] COWARD COVER for NPC: %d, squad_id: %s\n", npc:id(), tostring(squad_id))
                        swicth_table[npc_id]["priority"].value = 1.0 + 3
                end

                if table_npc[npc_id] and time_since_last_seen >= 100 and swicth_table[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] TABLE_NPC COWARD COVER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table[npc_id]["priority"].value = 1.0 + 3
                end

                if verification_npc[npc_id] == nil then verification_npc[npc_id] = 0 end
                if coward_table[npc_id] ~= 1 then
                        if (dist > 1000 and dist < 5000) and time_table[npc_id] < rnd2 then
                                if swicth_table[npc_id]["priority"].value >= 0.05 and verification_npc[npc_id] ~= 20 then
                                        if verification_npc[npc_id] < 20 then verification_npc[npc_id] = verification_npc[npc_id] + 1 end
                                        return true
                                end
                        else
                                return false
                        end
                        return false
                end
                if verification_npc[npc_id] > 0 then verification_npc[npc_id] = math.max(0, verification_npc[npc_id] - 0.5) end
                if verification_npc[npc_id] <= 0 then verification_npc[npc_id] = 0 end

                if combat_mode and set_npc_distance(npc, enemy) then
                        --printf("[DEBUG] SCHEME COWARD COMBAT FALSE for NPC: %d\n", npc:id())
                        return false
                end
        end
        --printf("[DEBUG] SCHEME COWARD CAMPER ended for NPC: %d\n", npc_id)
        return false
end

function scheme_camper_coward(enemy, npc, actor)
        --printf("[DEBUG] SCHEME COWARD CAMPER started for NPC: %d\n", npc:id())
	if not npc or not npc:alive() then return false end
        if not enemy or not enemy:alive() then return false end

        local IsEnemy = redone_ai_combat.get_combat_enemy(npc)
        if not IsEnemy or not IsEnemy:alive() then return false end
        if (IsMonster(enemy) or character_community(enemy) == "zombied") then return false end
        if IsWounded(npc) then return false end

        local actor = db.actor
        local npc_id = npc:id()
        local enemy_id = db.storage[npc_id] and db.storage[npc_id].enemy_id
        local enemy_obj_id = enemy_id and level.object_by_id(enemy_id)
        local squad = get_object_squad(npc)
        local squad_id
        if type(squad) == "table" and squad.id then
                squad_id = squad:id()
        elseif type(squad) == "number" then
                squad_id = squad
        else
                squad_id = npc_id
        end

        if cinema_mode then
                -- Cinema Mode Activated
        elseif vanilla_mode then
                local is_companion = (alife():has_info(enemy_id, "npcx_is_companion")) or (npc:has_info("npcx_is_companion"))
                if enemy_id ~= db.actor:id() and not is_companion then return false end
        end

        --[[if swicth_table2[npc_id]["priority"].value == nil then swicth_table2[npc_id]["priority"].value = 0.05 end
        swicth_table [npc_id]["priority"].value  = 0
        swicth_table3[npc_id]["priority"].value  = 0
        swicth_table4[npc_id]["priority"].value  = 0
        swicth_table5[npc_id]["priority"].value  = 0]]--

        local t2 = time_table2[npc_id]
        local tg = time_global()
        local mem = npc:memory_time(enemy)

        if time_table2[npc_id] == nil then time_table2[npc_id] = tg - mem end

        npc._coward = mem
        if npc._coward == 0 then npc._coward = tg end

        time_table2[npc_id] = tg - npc._coward
                npc._coward_time_since_last_seen = npc._coward_time_since_last_seen or 0
                npc._coward_time_since_seen      = npc._coward_time_since_seen or 0
                npc._coward_last_seen_update     = npc._coward_last_seen_update or tg
                npc._coward_seen_update          = npc._coward_seen_update or tg
        local m = mem
        if m ~= npc._coward_last_seen_update then
                npc._coward_last_seen_update = m
                npc._coward_seen_update      = m
        end
        local delta_last_seen = tg - npc._coward_last_seen_update
        local delta_seen      = tg - npc._coward_seen_update
                npc._coward_time_since_last_seen = delta_last_seen
                npc._coward_time_since_seen      = delta_seen
        local time_since_last_seen = npc._coward_time_since_last_seen
        local time_since_seen      = npc._coward_time_since_seen

        local weapon = npc:active_item()
        if not weapon then
                local bw_id = npc:best_weapon()
                weapon = bw_id and level.object_by_id(bw_id)
        end

        local actor_weapon = actor and actor:active_item()
        local is_actor_sniper = get_sniper_weapon(actor_weapon)

        local npc_see_actor = false
        local actor_see_npc = false

        if actor and actor:alive() then
                npc_see_actor = npc:see(actor)
                actor_see_npc = actor:see(npc)
        end

        local npc_see_enemy = false
        local enemy_see_npc = false

        if enemy and enemy:alive() then
                npc_see_enemy = npc:see(enemy)
                enemy_see_npc = enemy:see(npc)
        end

        local npc_health   = npc.health
        local enemy_health = enemy.health

        local pos1 = npc:position()
        local pos2 = enemy:position()
        local dist = pos1:distance_to_sqr(pos2)

        if get_enemy_distance(npc, enemy) then return false end
        if time_since_seen == nil or dist == nil then return false end

        if IsStalker(npc) then
                if npc._cover_pos == nil then npc._cover_pos = true end
                if weapon ~= nil then
                        if get_weapon_type(weapon) == false then
                                swicth_table2[npc_id]["priority"].value = 1.0 + 1.5
                        else
                                swicth_table2[npc_id]["priority"].value = 0.5 + 0.5
                        end
                end

                if npc_see_enemy then
                	if enemy_obj_id then
                		swicth_table2[npc_id][enemy_id].value = 5.0
                	end
                	
                	if not table_npc[npc_id] then
                		table_npc[npc_id] = true
                	end

                elseif table_npc[npc_id] then
                	set_table_memory(npc, enemy, table_npc, "coward")
                end

                if (not npc_see_actor and actor_see_npc) or (not npc_see_enemy and enemy_see_npc) then return false end

                if sniper_combat_enabled and is_actor_sniper then
                        if dist >= 500 and t2 ~= nil then
                	        if swicth_table2[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                		        return false
                	        end
                                return true
                        end
                end

                if npc_health <= 0.5 and t2 ~= nil then
                	if dist >= 1000 and dist < 5000 and t2 < rnd then
                		if swicth_table2[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                			return false
                		end
                		return true
                	end
                else
                	if enemy_health <= 0.25 and t2 ~= nil then
                		if dist <= 5000 and t2 < rnd then
                			if swicth_table2[npc_id]["priority"].value >= 0.05 and npc_health < 0.8 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.5 and t2 ~= nil then
                		if dist <= 2500 and t2 < rnd then
                			if swicth_table2[npc_id]["priority"].value >= 0.05 and npc_health < 0.5 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.75 and t2 ~= nil then
                		if dist <= 1500 and t2 < rnd then
                			if swicth_table2[npc_id]["priority"].value >= 0.05 and npc_health < 0.3 then
                				return true
                			end
                			return false
                		end
                	end
                end

                if last_hit_time[npc_id] and tg - last_hit_time[npc_id] < 15000 then
                        --printf("[DEBUG] COWARD CAMPER HIT for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table2[npc_id]["priority"].value = 1.0 + 5
                end

                coward_npc(npc_id)

                if is_coward(npc_id, dist, time_since_last_seen) and swicth_table2[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] COWARD CAMPER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table2[npc_id]["priority"].value = 1.0 + 3
                end

                if table_npc[npc_id] and time_since_last_seen >= 100 and swicth_table2[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] TABLE_NPC COWARD CAMPER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table2[npc_id]["priority"].value = 1.0 + 3
                end

                if verification_npc2[npc_id] == nil then verification_npc2[npc_id] = 0 end
                if verification_npc[npc_id] == 20 and (dist > 1000 and dist < 5000) then
                        if verification_npc2[npc_id] < 25 then
                                verification_npc2[npc_id] = verification_npc2[npc_id] + 1
                        else
                                verification_npc[npc_id] = 0
                                verification_npc2[npc_id] = 0
                                return false
                        end
                        return true
                end
                if verification_npc2[npc_id] > 0 then verification_npc2[npc_id] = math.max(0, verification_npc2[npc_id] - 0.5) end
                if verification_npc2[npc_id] <= 0 then verification_npc2[npc_id] = 0 end

                if (time_since_seen <= math_random(coward_min, coward_max) and dist >= 100) or (time_since_last_seen <= math_random(coward_min, coward_max) and dist >= 100) then
                        if cover_mode and npc._cover_pos ~= true then set_cover_distance(npc)
                                --printf("[DEBUG] COWARD CAMPER MOVE FALSE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                                return false
                        end
                        --printf("[DEBUG] COWARD CAMPER MOVE TRUE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        return true
                end
        end
        --printf("[DEBUG] SCHEME COWARD CAMPER ended for NPC: %d\n", npc_id)
        return false
end

