-----------------------------------------------------------------------------
-- NPC SCHEMES
-----------------------------------------------------------------------------
local coward_min, coward_max
local dumb_min, dumb_max

if aggression_mode == 1 then
        coward_min, coward_max = 1500, 5000
        dumb_min, dumb_max     = 10000, 15000

elseif aggression_mode == 2 then
        coward_min, coward_max = 2500, 5000
        dumb_min, dumb_max     = 7500, 10000

elseif aggression_mode == 3 then
        coward_min, coward_max = 3500, 5000
        dumb_min, dumb_max     = 5000, 7500
end

function coward_npc(id, npc)
        if not npc then
                npc = db.storage[id] and db.storage[id].object
                if not npc then return false end
        end

        if coward_table [id] ~= nil then return end
        if dumb_table   [id] ~= nil then return end
        if stupid_table [id] ~= nil then return end
        --printf("[DEBUG] COWARD NPC called for NPC id=%d\n", id)

        local fchance = 5
        local rchance = 5
        if IsStalker(npc, id) then
                local rank = ranks.get_obj_rank_name(npc)
                local faction = character_community(npc)
                if factions[faction] then
                        if rank == "master" then fchance = 4
                        elseif rank == "legend" then fchance = 5
                        else fchance = 2
                        end
                else
                        fchance = 4
                end

                if coward_f[faction] then
                        if rank == "novice" then rchance = 1
                        elseif rank == "trainee" then rchance = 1
                        elseif rank == "experienced" then rchance = 1
                        elseif rank == "professional" then rchance = 2
                        elseif rank == "expert" then rchance = 2
                        elseif rank == "veteran" then rchance = 3
                        else rchance = 2 end
                end
        end

        local tchance = fchance + rchance
        local coward_rnd = math_random(1, tchance)

        if coward_rnd == 1 then
                coward_table[id] = 1
        else
                coward_table[id] = 2
        end
end

function is_coward(id, distance, my_memory)
        local min_dist = 1000
        local max_dist = 5000

        if coward_table[id] ~= 1 then return false end
        if not distance or distance < min_dist or distance > max_dist then return false end
        if my_memory < coward_rnd then return false end

        return true
end

