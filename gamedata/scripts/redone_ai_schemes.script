-- DEBUG
local LAST_META_LOG = {}
local function meta_trace(mode, scheme_id, npc_id, enemy_id, state, extra)
	if DEBUG_META_OFF then return end

	if mode == "raw" and not DEBUG_META_TRACE_RAW then return end
	if mode == "clean" and not DEBUG_META_TRACE_CLEAN then return end

	local key =
		tostring(scheme_id) ..
		":" .. tostring(npc_id) ..
		":" .. tostring(enemy_id) ..
		":" .. tostring(state)

	local line =
		"[META SWITCH TABLE" .. tostring(scheme_id) .. "] " ..
		"[NPC " .. tostring(npc_id) .. "] " ..
		"[ENEMY " .. tostring(enemy_id) .. "] " ..
		"-> " .. tostring(state)

	if extra then line = line .. " | " .. tostring(extra) end

	-- CLEAN MODE = ONLY CHANGES
	if mode == "clean" then
		if LAST_META_LOG[key] == line then return end
		LAST_META_LOG[key] = line
	end

	if db and db.storage then
		printf(line)
	else
		print(line)
	end
end
------------------------------------------------
-- SAFE OBJECTS
------------------------------------------------
local SAFE_EMPTY = setmetatable({}, {
	__index = function()
		return nil
	end
})
------------------------------------------------
-- SWITCH TABLE FACTORY
------------------------------------------------
local CLEANUP_INTERVAL = 100
local function create_swicth_table(scheme_id)
	local access_counter = 0

	return setmetatable({}, {
		__index = function(t1, npc_id)
			meta_trace("raw",scheme_id,npc_id,"-","NPC_ENTRY")
			local npc_obj = db.storage[npc_id] and db.storage[npc_id].object
			if not npc_obj or not npc_obj:alive() then
				rawset(t1, npc_id, nil)
				meta_trace("clean",scheme_id,npc_id,"-","NPC REJECT","npc invalid/dead")
				return SAFE_EMPTY
			end

			local npc_table = rawget(t1, npc_id)
			if npc_table then
				meta_trace("raw",scheme_id,npc_id,"-","NPC CACHE HIT")
				return npc_table
			end

			meta_trace("clean",scheme_id,npc_id,"-","NPC_INIT")
			npc_table = setmetatable({}, {
				__index = function(t2, enemy_id)
					--meta_trace("raw",scheme_id,npc_id,enemy_id,"REQUEST")
					------------------------------------------------
					-- PRIORITY
					------------------------------------------------
					if enemy_id == "priority" then
					        local p = rawget(t2, "__priority")
					        if not p then
					                p = setmetatable({}, {
					                        __index = function(t, k)
					                                if k == "value" then
					                                        return rawget(t, "_value")
					                                end
					                        end,
					                        __newindex = function(t, k, v)
					                                if k == "value" then
					                                        rawset(t, "_value", v)
					                                        meta_trace("clean", scheme_id, npc_id, "priority", "UPDATE", tostring(v))
					                                else
					                                        rawset(t, k, v)
					                                end
					                        end
					                })

					                p.value = 0.05
					                rawset(t2, "__priority", p)
					                meta_trace("clean",scheme_id,npc_id,"priority","PRIORITY INIT","value=0.05")
					        end

					        return p
					end
					------------------------------------------------
					-- ENGINE LOOKUP
					------------------------------------------------
					local enemy_obj = db.storage[enemy_id] and db.storage[enemy_id].object or level.object_by_id(enemy_id)
					if not enemy_obj then
						meta_trace("clean",scheme_id,npc_id,enemy_id,"ENGINE MISS","enemy missing from db.storage")
						return SAFE_EMPTY
					end

					if not enemy_obj:alive() then
						meta_trace("clean",scheme_id,npc_id,enemy_id,"REJECT_DEAD","enemy dead")
						return SAFE_EMPTY
					end

					if enemy_id == 0 then
						if enemy_obj ~= db.actor then
							meta_trace("clean",scheme_id,npc_id,enemy_id,"REJECT 0 ID")
							return SAFE_EMPTY
						end
					end

					-- CACHE HIT
					local cached = rawget(t2, enemy_id)
					if cached then
						meta_trace("raw",scheme_id,npc_id,enemy_id,"CACHE RETURN")
						return cached
					end
					------------------------------------------------
					-- ENEMY TABLE
					------------------------------------------------
					local enemy_table = setmetatable({}, {
						__index = function(t3, k3)
							return rawget(t3, k3)
						end
					})

					rawset(t2, enemy_id, enemy_table)
					meta_trace("clean",scheme_id,npc_id,enemy_id,"ACCEPT","enemy cached")
					------------------------------------------------
					-- CLEANUP
					------------------------------------------------
					access_counter = access_counter + 1

					if access_counter >= CLEANUP_INTERVAL then
						access_counter = 0

						meta_trace("raw",scheme_id,npc_id,enemy_id,"CLEANUP START")
						for k in pairs(t2) do
							if type(k) == "number" then
								local obj = db.storage[k] and db.storage[k].object
								if not obj or not obj:alive() or k == npc_obj:id() then
									t2[k] = nil
									meta_trace("clean",scheme_id,npc_id,k,"CLEANUP_REMOVE")
								end
							end
						end
					end
					return enemy_table
				end
			})
			rawset(t1, npc_id, npc_table)
			return npc_table
		end
	})
end

-- CREATE TABLES
local swicth_tables = {}
for i = 1, 5 do swicth_tables[i] = create_swicth_table(i) end
