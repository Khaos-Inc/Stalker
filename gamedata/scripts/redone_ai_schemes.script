        if time_table3[npc_id] == nil then time_table3[npc_id] = tg - mem end

        npc._dumb = mem
        if npc._dumb == 0 then npc._dumb = tg end

        time_table3[npc_id] = tg - npc._dumb
                npc._dumb_time_since_last_seen = npc._dumb_time_since_last_seen or 0
                npc._dumb_time_since_seen      = npc._dumb_time_since_seen or 0
                npc._dumb_last_seen_update     = npc._dumb_last_seen_update or tg
                npc._dumb_seen_update          = npc._dumb_seen_update or tg
        local m = mem
        if m ~= npc._dumb_last_seen_update then
                npc._dumb_last_seen_update = m
                npc._dumb_seen_update      = m
        end
        local delta_last_seen = tg - npc._dumb_last_seen_update
        local delta_seen      = tg - npc._dumb_seen_update
                npc._dumb_time_since_last_seen = delta_last_seen
                npc._dumb_time_since_seen      = delta_seen
        local time_since_last_seen = npc._dumb_time_since_last_seen
        local time_since_seen      = npc._dumb_time_since_seen

        local weapon = npc:active_item()
        if not weapon then
                local bw_id = npc:best_weapon()
                weapon = bw_id and level.object_by_id(bw_id)
        end

        local actor_weapon = actor and actor:active_item()
        local is_actor_sniper = get_sniper_weapon(actor_weapon)

        local npc_see_actor = false
        local actor_see_npc = false

        if actor and actor:alive() then
                npc_see_actor = npc:see(actor)
                actor_see_npc = actor:see(npc)
        end

        local npc_see_enemy = false
        local enemy_see_npc = false

        if enemy and enemy:alive() then
                npc_see_enemy = npc:see(enemy)
                enemy_see_npc = enemy:see(npc)
        end

        local npc_health   = npc.health
        local enemy_health = enemy.health

        local pos1 = npc:position()
        local pos2 = enemy:position()
        local dist = pos1:distance_to_sqr(pos2)

        if get_enemy_distance(npc, enemy) then return false end
        if dist < 100 or dist >= 1000 then return false end

        if IsStalker(npc) then
                if npc._cover_pos == true then npc._cover_pos = false end
                if weapon ~= nil then
                        if get_weapon_type(weapon) == true then
                                swicth_table3[npc_id]["priority"].value = 1.0 + 1.5
                        else
                                swicth_table3[npc_id]["priority"].value = 0.5 + 0.5
                        end
                end

                if npc_see_enemy then
                	if enemy_obj_id then
                		swicth_table3[npc_id][enemy_id].value = 5.0
                	end
                	
                	if not table_npc[npc_id] then
                		table_npc[npc_id] = true
                	end

                elseif table_npc[npc_id] then
                	set_table_memory(npc, enemy, table_npc, "coward")
                end

                if (not npc_see_actor and actor_see_npc) or (not npc_see_enemy and enemy_see_npc) then return false end

                if sniper_combat_enabled and is_actor_sniper then
                        if dist >= 500 and t3 ~= nil then
                	        if swicth_table3[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                		        return true
                	        end
                                return false
                        end
                end

                if npc_health <= 0.5 and t3 ~= nil then
                	if dist >= 100 and dist < 1000 and t3 < rnd then
                		if swicth_table3[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                			return true
                		end
                		return false
                	end
                else
                	if enemy_health <= 0.25 and t3 ~= nil then
                		if dist <= 1000 and t3 < rnd then
                			if swicth_table3[npc_id]["priority"].value >= 0.05 and npc_health < 0.8 then
                				return false
                			end
                			return true
                		end
                	elseif enemy_health <= 0.5 and t3 ~= nil then
                		if dist <= 750 and t3 < rnd then
                			if swicth_table3[npc_id]["priority"].value >= 0.05 and npc_health < 0.5 then
                				return false
                			end
                			return true
                		end
                	elseif enemy_health <= 0.75 and t3 ~= nil then
                		if dist <= 500 and t3 < rnd then
                			if swicth_table3[npc_id]["priority"].value >= 0.05 and npc_health < 0.3 then
                				return false
                			end
                			return true
                		end
                	end
                end

                if last_hit_time[npc_id] and tg - last_hit_time[npc_id] < 10000 then
                        --printf("[DEBUG] DUMB COVER HIT for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table3[npc_id]["priority"].value = 1.0 + 5
                end

                dumb_npc(npc:id())

                if is_dumb(npc:id(), dist, time_since_last_seen) and swicth_table3[npc:id()]["priority"].value >= 0.05 then
                        --printf("[DEBUG] DUMB COVER for NPC: %d, squad_id: %s\n", npc:id(), tostring(squad_id))
                        swicth_table3[npc_id]["priority"].value = 1.0 + 3
                end

                if table_npc[npc_id] and time_since_last_seen >= 100 and swicth_table3[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] TABLE_NPC DUMB COVER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table3[npc_id]["priority"].value = 1.0 + 3
                end

                if verification_npc3[npc_id] == nil then verification_npc3[npc_id] = 0 end
                if dumb_table[npc_id] ~= 1 then
                        if (dist > 100 and dist < 1000) and time_table3[npc_id] < rnd2 then
                                if swicth_table3[npc_id]["priority"].value >= 0.05 and verification_npc3[npc_id] ~= 15 then
                                        if verification_npc3[npc_id] < 15 then verification_npc3[npc_id] = verification_npc3[npc_id] + 1 end
                                        return true
                                end
                        else
                                return false
                        end
                        return false
                end
                if verification_npc3[npc_id] > 0 then verification_npc3[npc_id] = math.max(0, verification_npc3[npc_id] - 0.5) end
                if verification_npc3[npc_id] <= 0 then verification_npc3[npc_id] = 0 end

                if combat_mode and set_npc_distance(npc, enemy) then
                        --printf("[DEBUG] SCHEME DUMB COMBAT FALSE for NPC: %d\n", npc:id())
                        return false
                end
        end
        --printf("[DEBUG] SCHEME DUMB COVER ended for NPC: %d\n", npc_id)
        return false
end

function scheme_camper_dumb(enemy, npc, actor)
        --printf("[DEBUG] SCHEME DUMB CAMPER started for NPC: %d\n", npc:id())
	if not npc or not npc:alive() then return false end
        if not enemy or not enemy:alive() then return false end

        local IsEnemy = redone_ai_combat.get_combat_enemy(npc)
        if not IsEnemy or not IsEnemy:alive() then return false end
        if (IsMonster(enemy) or character_community(enemy) == "zombied") then return false end
        if IsWounded(npc) then return false end

        local actor = db.actor
        local npc_id = npc:id()
        local enemy_id = db.storage[npc_id] and db.storage[npc_id].enemy_id
        local enemy_obj_id = enemy_id and level.object_by_id(enemy_id)
        local squad = get_object_squad(npc)
        local squad_id
        if type(squad) == "table" and squad.id then
                squad_id = squad:id()
        elseif type(squad) == "number" then
                squad_id = squad
        else
                squad_id = npc_id
        end

        if cinema_mode then
                -- Cinema Mode Activated
        elseif vanilla_mode then
                local is_companion = (alife():has_info(enemy_id, "npcx_is_companion")) or (npc:has_info("npcx_is_companion"))
                if enemy_id ~= db.actor:id() and not is_companion then return false end
        end

        --[[if swicth_table4[npc_id]["priority"].value == nil then swicth_table4[npc_id]["priority"].value = 0.05 end
        swicth_table[npc_id] ["priority"].value  = 0
        swicth_table2[npc_id]["priority"].value  = 0
        swicth_table3[npc_id]["priority"].value  = 0
        swicth_table5[npc_id]["priority"].value  = 0]]--

        local t4 = time_table4[npc_id]
        local tg = time_global()
        local mem = npc:memory_time(enemy)

        if time_table4[npc_id] == nil then time_table4[npc_id] = tg - mem end

        npc._dumb = mem
        if npc._dumb == 0 then npc._dumb = tg end

        time_table4[npc_id] = tg - npc._dumb
                npc._dumb_time_since_last_seen = npc._dumb_time_since_last_seen or 0
                npc._dumb_time_since_seen      = npc._dumb_time_since_seen or 0
                npc._dumb_last_seen_update     = npc._dumb_last_seen_update or tg
                npc._dumb_seen_update          = npc._dumb_seen_update or tg
        local m = mem
        if m ~= npc._dumb_last_seen_update then
                npc._dumb_last_seen_update = m
                npc._dumb_seen_update      = m
        end
        local delta_last_seen = tg - npc._dumb_last_seen_update
        local delta_seen      = tg - npc._dumb_seen_update
                npc._dumb_time_since_last_seen = delta_last_seen
                npc._dumb_time_since_seen      = delta_seen
        local time_since_last_seen = npc._dumb_time_since_last_seen
        local time_since_seen      = npc._dumb_time_since_seen

        local weapon = npc:active_item()
        if not weapon then
                local bw_id = npc:best_weapon()
                weapon = bw_id and level.object_by_id(bw_id)
        end

        local actor_weapon = actor and actor:active_item()
        local is_actor_sniper = get_sniper_weapon(actor_weapon)

        local npc_see_actor = false
        local actor_see_npc = false

        if actor and actor:alive() then
                npc_see_actor = npc:see(actor)
                actor_see_npc = actor:see(npc)
        end

        local npc_see_enemy = false
        local enemy_see_npc = false

        if enemy and enemy:alive() then
                npc_see_enemy = npc:see(enemy)
                enemy_see_npc = enemy:see(npc)
        end

        local npc_health   = npc.health
        local enemy_health = enemy.health

        local pos1 = npc:position()
        local pos2 = enemy:position()
        local dist = pos1:distance_to_sqr(pos2)

        if get_enemy_distance(npc, enemy) then return false end
        if time_since_seen == nil or dist == nil then return false end

        if IsStalker(npc) then
                if npc._cover_pos == nil then npc._cover_pos = true end
                if weapon ~= nil then
                        if get_weapon_type(weapon) == false then
                                swicth_table4[npc_id]["priority"].value = 1.0 + 1.5
                        else
                                swicth_table4[npc_id]["priority"].value = 0.5 + 0.5
                        end
                end

                if npc_see_enemy then
                	if enemy_obj_id then
                		swicth_table4[npc_id][enemy_id].value = 5.0
                	end
                	
                	if not table_npc[npc_id] then
                		table_npc[npc_id] = true
                	end

                elseif table_npc[npc_id] then
                	set_table_memory(npc, enemy, table_npc, "coward")
                end

                if (not npc_see_actor and actor_see_npc) or (not npc_see_enemy and enemy_see_npc) then return false end

                if sniper_combat_enabled and is_actor_sniper then
                        if dist >= 500 and t4 ~= nil then
                	        if swicth_table4[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                		        return false
                	        end
                                return true
                        end
                end

                if npc_health <= 0.5 and t4 ~= nil then
                	if dist >= 100 and dist < 1000 and t4 < rnd then
                		if swicth_table4[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                			return false
                		end
                		return true
                	end
                else
                	if enemy_health <= 0.25 and t4 ~= nil then
                		if dist <= 1000 and t4 < rnd then
                			if swicth_table4[npc_id]["priority"].value >= 0.05 and npc_health < 0.8 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.5 and t4 ~= nil then
                		if dist <= 750 and t4 < rnd then
                			if swicth_table4[npc_id]["priority"].value >= 0.05 and npc_health < 0.5 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.75 and t4 ~= nil then
                		if dist <= 500 and t4 < rnd then
                			if swicth_table4[npc_id]["priority"].value >= 0.05 and npc_health < 0.3 then
                				return true
                			end
                			return false
                		end
                	end
                end

                if last_hit_time[npc_id] and tg - last_hit_time[npc_id] < 15000 then
                        --printf("[DEBUG] DUMB CAMPER HIT FALSE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table4[npc_id]["priority"].value = 1.0 + 5
                end

                dumb_npc(npc_id)

                if is_dumb(npc_id, dist, time_since_last_seen) and swicth_table4[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] IS DUMB ATTACKER CAMPER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table4[npc_id]["priority"].value = 1.0 + 3
                end

                if table_npc[npc_id] and time_since_last_seen >= 100 and swicth_table4[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] DUMB TABLE_CAMPER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table4[npc_id]["priority"].value = 1.0 + 3
                end

                if verification_npc4[npc_id] == nil then verification_npc4[npc_id] = 0 end
                if verification_npc3[npc_id] == 15 and (dist > 100 and dist < 1000) then
                        if verification_npc4[npc_id] < 20 then
                                verification_npc4[npc_id] = verification_npc4[npc_id] + 1
                        else
                                verification_npc3[npc_id] = 0
                                verification_npc4[npc_id] = 0
                                return false
                        end
                        return true
                end
                if verification_npc4[npc_id] > 0 then verification_npc4[npc_id] = math.max(0, verification_npc4[npc_id] - 0.5) end
                if verification_npc4[npc_id] <= 0 then verification_npc4[npc_id] = 0 end

                if (time_since_seen >= math_random(dumb_min, dumb_max) and dist >= 100) or (time_since_last_seen >= math_random(dumb_min, dumb_max) and dist >= 100) then
                        if cover_mode and npc._cover_pos ~= true then set_cover_distance(npc)
                                --printf("[DEBUG] DUMB MOVE FALSE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                                return false
                        end
                        --printf("[DEBUG] DUMB MOVE TRUE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        return true
                end
        end
        --printf("[DEBUG] SCHEME DUMB CAMPER ended for NPC: %d\n", npc_id)
        return false
end

-----------------------------------------------------------------------------
-- STUPID SCHEMES
-----------------------------------------------------------------------------
function scheme_stupid(enemy, npc, actor)
        --printf("[DEBUG] SCHEME STUPID started for NPC: %d\n", npc:id())
	if not npc or not npc:alive() then return false end
        if not enemy or not enemy:alive() then return false end

        local IsEnemy = redone_ai_combat.get_combat_enemy(npc)
        if not IsEnemy or not IsEnemy:alive() then return false end
        if (IsMonster(enemy) or character_community(enemy) == "zombied") then return false end
        if IsWounded(npc) then return false end

        local actor = db.actor
        local npc_id = npc:id()
        local enemy_id = db.storage[npc_id] and db.storage[npc_id].enemy_id
        local enemy_obj_id = enemy_id and level.object_by_id(enemy_id)
        local squad = get_object_squad(npc)
        local squad_id
        if type(squad) == "table" and squad.id then
                squad_id = squad:id()
        elseif type(squad) == "number" then
                squad_id = squad
        else
                squad_id = npc_id
        end

        if cinema_mode then
                -- Cinema Mode Activated
        elseif vanilla_mode then
                local is_companion = (alife():has_info(enemy_id, "npcx_is_companion")) or (npc:has_info("npcx_is_companion"))
                if enemy_id ~= db.actor:id() and not is_companion then return false end
        end

        --[[if swicth_table5[npc_id]["priority"].value == nil then swicth_table5[npc_id]["priority"].value = 0.05 end
        swicth_table [npc_id]["priority"].value = 0
        swicth_table2[npc_id]["priority"].value = 0
        swicth_table3[npc_id]["priority"].value = 0
        swicth_table4[npc_id]["priority"].value = 0]]--

        local t5 = time_table5[npc_id]
        local tg = time_global()
        local mem = npc:memory_time(enemy)

        if time_table5[npc_id] == nil then time_table5[npc_id] = tg - mem end

        npc._stupid = mem
        if npc._stupid == 0 then npc._stupid = tg end

        time_table5[npc_id] = tg - npc._stupid
                npc._stupid_time_since_last_seen = npc._stupid_time_since_last_seen or 0
                npc._stupid_time_since_seen      = npc._stupid_time_since_seen or 0
                npc._stupid_last_seen_update     = npc._stupid_last_seen_update or tg
                npc._stupid_seen_update          = npc._stupid_seen_update or tg
        local m = mem
        if m ~= npc._stupid_last_seen_update then
                npc._stupid_last_seen_update = m
                npc._stupid_seen_update      = m
        end
        local delta_last_seen = tg - npc._stupid_last_seen_update
        local delta_seen      = tg - npc._stupid_seen_update
                npc._stupid_time_since_last_seen = delta_last_seen
                npc._stupid_time_since_seen      = delta_seen
        local time_since_last_seen = npc._stupid_time_since_last_seen
        local time_since_seen      = npc._stupid_time_since_seen

        local weapon = npc:active_item()
        if not weapon then
                local bw_id = npc:best_weapon()
                weapon = bw_id and level.object_by_id(bw_id)
        end

        local actor_weapon = actor and actor:active_item()
        local is_actor_sniper = get_sniper_weapon(actor_weapon)

        local npc_see_actor = false
        local actor_see_npc = false

        if actor and actor:alive() then
                npc_see_actor = npc:see(actor)
                actor_see_npc = actor:see(npc)
        end

        local npc_see_enemy = false
        local enemy_see_npc = false

        if enemy and enemy:alive() then
                npc_see_enemy = npc:see(enemy)
                enemy_see_npc = enemy:see(npc)
        end

        local npc_health   = npc.health
        local enemy_health = enemy.health

        local pos1 = npc:position()
        local pos2 = enemy:position()
        local dist = pos1:distance_to_sqr(pos2)

        if get_enemy_distance(npc, enemy) then return false end
        if dist < 100 or dist >= 5000 then return false end

        if IsStalker(npc) then
                if npc._cover_pos == true then npc._cover_pos = false end
                if weapon ~= nil then
                        if get_weapon_type(weapon) == true then
                                swicth_table5[npc_id]["priority"].value = 1.0 + 1.5
                        else
                                swicth_table5[npc_id]["priority"].value = 0.5 + 0.5
                        end
                end

                if npc_see_enemy then
                	if enemy_obj_id then
                		swicth_table5[npc_id][enemy_id].value = 5.0
                	end
                	
                	--[[if not table_npc[npc_id] then
                		table_npc[npc_id] = true
                	end]]--

                elseif table_npc[npc_id] then
                	set_table_memory(npc, enemy, table_npc, "coward")
                end

                if (not npc_see_actor and actor_see_npc) or (not npc_see_enemy and enemy_see_npc) then return false end

                if sniper_combat_enabled and is_actor_sniper then
                        if dist >= 500 and t5 ~= nil then
                	        if swicth_table5[npc_id]["priority"].value >= 0.05 and enemy_health < 0.5 then
                		        return true
                	        end
                                return false
                        end
                end

                if npc_health <= 0.5 and t5 ~= nil then
                	if dist >= 100 and dist < 1000 and t5 < rnd then
                		if swicth_table5[npc_id]["priority"].value >= 0.05 and enemy_health < 0.3 then
                			return true
                		end
                		return false
                	end
                else
                	if enemy_health <= 0.25 and t5 ~= nil then
                		if dist <= 5000 and t5 < rnd2 then
                			if swicth_table5[npc_id]["priority"].value >= 0.05 and npc_health < 0.8 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.5 and t5 ~= nil then
                		if dist <= 2500 and t5 < rnd then
                			if swicth_table5[npc_id]["priority"].value >= 0.05 and npc_health < 0.5 then
                				return true
                			end
                			return false
                		end
                	elseif enemy_health <= 0.75 and t5 ~= nil then
                		if dist <= 1500 and t5 < rnd then
                			if swicth_table5[npc_id]["priority"].value >= 0.05 and npc_health < 0.3 then
                				return true
                			end
                			return false
                		end
                	end
                end
         
                if last_hit_time[npc_id] and tg - last_hit_time[npc_id] < 1000 then
                        --printf("[DEBUG] STUPID HIT TRUE for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table5[npc_id]["priority"].value = 1.0 + 5
                end

                stupid_npc(npc_id)

                if is_stupid(npc_id, dist, time_since_last_seen) and swicth_table5[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] IS STUPID ATTACKER for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table5[npc_id]["priority"].value = 1.0 + 3
                end

                if table_npc[npc_id] == true and time_since_last_seen >= 100 and swicth_table5[npc_id]["priority"].value >= 0.05 then
                        --printf("[DEBUG] STUPID TABLE_NPC for NPC: %d, squad_id: %s\n", npc_id, tostring(squad_id))
                        swicth_table5[npc_id]["priority"].value = 1.0 + 3
                end

                if verification_npc5[npc_id] == nil then verification_npc5[npc_id] = 0 end
                if stupid_table[npc_id] ~= nil then
                        if (dist > 100 and dist < 5000) and t5 < rnd2 then
                                if swicth_table5[npc_id]["priority"].value >= 0.05 and verification_npc5[npc_id] == 25 then
                                        if verification_npc5[npc_id] < 30 then verification_npc5[npc_id] = verification_npc5[npc_id] + 1 end
                                        return true
                                end
                        else
                                return false
                        end
                        return false
                end
                if verification_npc5[npc_id] > 0 then verification_npc5[npc_id] = math.max(0, verification_npc5[npc_id] - 0.5) end
                if verification_npc5[npc_id] <= 0 then verification_npc5[npc_id] = 0 end

                if combat_mode and set_npc_distance(npc, enemy) then
                        --printf("[DEBUG] SCHEME STUPID COMBAT for NPC: %d\n", npc:id())
                        return true
                end
        end
        --printf("[DEBUG] SCHEME STUPID END for NPC: %d\n", npc_id)
        return false
end