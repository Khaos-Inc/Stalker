-----------------------------------------------------------------------------
-- DEBUG
local LAST_ENEMY_LOG = {}
local function d(msg)
	if not DEBUG_ENEMY_OFF then
		utils_data.debug_write(msg)
	end
end
-----------------------------------------------------------------------------
-- COMBAT ENEMY
-----------------------------------------------------------------------------
function get_combat_enemy(npc)
	if not npc or not npc:alive() then return nil end

	local npc_id = npc:id()
	local st = db.storage[npc_id]
	if not st then
		db.storage[npc_id] = {}
		st = db.storage[npc_id]
	end

	local function has_los(e)
		if not e or not e:alive() then return false end

		local st = db.storage[npc_id]
		if not st then return false end

		st.los_cache = st.los_cache or {}
		local cache = st.los_cache
		local t = time_global()
		local eid = e:id()

		cache[eid] = cache[eid] or { last_t = 0, result = false }
		local c = cache[eid]
		if t - c.last_t < 200 then
			return c.result
		end

		local res = demonized_geometry_ray
			and demonized_geometry_ray.geo_los
			and demonized_geometry_ray.geo_los(npc, e)

		if res == nil then
			res = false
		end

		c.last_t = t
		c.result = res
		return res
	end
	-------------------------------------------------
	-- ENGINE ENEMY
	-------------------------------------------------
	local enemy = npc:best_enemy()
	if DEBUG_ENEMY_RAW then
		d("[ENEMY] ENGINE | npc=" .. npc_id ..
		" best_enemy=" .. tostring(enemy and enemy:id() or -1))
	end

	if enemy and enemy:alive() then
		st.enemy_id = enemy:id()
		st.last_seen_enemy = enemy:id()
		st.last_seen_pos = enemy:position()
		if DEBUG_ENEMY_CLEAN then
			local eid = enemy:id()
			local last = LAST_ENEMY_LOG[npc_id]

			if last ~= eid then
				d("[ENEMY] SWITCH | npc=" .. npc_id ..
				" " .. tostring(last) .. " -> " .. eid)
				LAST_ENEMY_LOG[npc_id] = eid
			end
		end

		if has_los(enemy) then
			if DEBUG_ENEMY_RAW then
				d("[ENEMY] LOS | npc=" .. npc_id ..
				" CONFIRMED enemy=" .. enemy:id())
			end
			return enemy
		else
			if DEBUG_ENEMY_RAW then
				d("[ENEMY] LOS | npc=" .. npc_id ..
				" BLOCKED enemy=" .. enemy:id())
			end
		end
	end

	-------------------------------------------------
	-- MEMORY ENEMY
	-------------------------------------------------
	local enemy_id = st.enemy_id
	if DEBUG_ENEMY_RAW then
		d("[ENEMY] MEMORY | npc=" .. npc_id ..
		" enemy_id=" .. tostring(enemy_id))
	end

	if enemy_id then
		local mem_enemy = level.object_by_id(enemy_id)
		if mem_enemy and mem_enemy:alive() then
			if DEBUG_ENEMY_CLEAN then
				local last = LAST_ENEMY_LOG[npc_id]
				if last ~= enemy_id then
					d("[ENEMY] SWITCH | npc=" .. npc_id ..
					" " .. tostring(last) .. " -> " .. enemy_id)
					LAST_ENEMY_LOG[npc_id] = enemy_id
				end
			end

			if has_los(mem_enemy) then
				if DEBUG_ENEMY_RAW then
					d("[ENEMY] MEMORY LOS | npc=" .. npc_id ..
					" ACTIVE enemy=" .. enemy_id)
				end
				return mem_enemy
			else
				if DEBUG_ENEMY_RAW then
					d("[ENEMY] MEMORY LOS | npc=" .. npc_id ..
					" BLOCKED enemy=" .. enemy_id)
				end

				if st.last_seen_pos then
					d("[ENEMY] FALLBACK | npc=" .. npc_id ..
					" using last_seen_pos")
					return mem_enemy
				end
				return mem_enemy
			end
		end
	end
	-------------------------------------------------
	-- NO VALID ENEMY
	-------------------------------------------------
	if st then st.enemy_id = nil end
	if DEBUG_ENEMY_RAW then
		d("[ENEMY] RESET | npc=" .. npc_id ..
		" no valid enemy")
	end

	if DEBUG_ENEMY_CLEAN then
		local last = LAST_ENEMY_LOG[npc_id]
		if last ~= false then
			d("[ENEMY] STATE | npc=" .. npc_id ..
			" -> NONE")
			LAST_ENEMY_LOG[npc_id] = false
		end
	end
	return nil
end

-----------------------------------------------------------------------------
-- COMBAT UTLIS
-----------------------------------------------------------------------------
local function set_weapon(npc)
        local active_weapon = npc:active_item()
        if active_weapon then return active_weapon end

        local best_weapon_id = npc:best_weapon()
        return best_weapon_id and level.object_by_id(best_weapon_id)
end

local function get_weapon_type(weapon)
        if not weapon then return "other" end
        local kind = ini_sys:r_string_ex(weapon:section(), "kind") or "unknown"
            if kind == "w_pistol"   then return "pistol"
        elseif kind == "w_smg"      then return "smg"
        elseif kind == "w_rifle"    then return "rifle"
        elseif kind == "w_shotgun"  then return "shotgun"
        elseif kind == "w_sniper"   then return "sniper"
        elseif kind == "w_launcher" then return "launcher"
        else return "other" end
end

-----------------------------------------------------------------------------
-- COMBAT DISTANCE
-----------------------------------------------------------------------------
function get_combat_distances(npc, enemy)
        local rank = ranks.get_obj_rank_name(npc)
        local faction = character_community(npc) or "stalker"
        local weapon = set_weapon(npc)

        local weapon_type = get_weapon_type(weapon)
        local base = COMBAT_DISTANCE_PROFILE[faction] and COMBAT_DISTANCE_PROFILE[faction][rank]
        local abort, release = 20, 25
        if base then
                abort, release = base.abort, base.release
        end

        local mod = WEAPON_DISTANCE_MOD[weapon_type]
        if mod then
                abort = abort + mod.abort
                release = release + mod.release
        end

        abort = math.max(abort, 5)
        release = math.max(release, abort + 5)
        return abort, release
end

-----------------------------------------------------------------------------
-- DEBUG
function movement_debug(name, fn)
        return function()
                if DEBUG_MOVEMENT then
                        printf("[COMBAT] movement: %s", tostring(name))
                end
                return fn()
        end
end
-----------------------------------------------------------------------------
-- COMBAT MOVEMENT
-----------------------------------------------------------------------------
local function select_movements(t)
        local n = #t
        for i = n, 2,-1 do
            local j = math.random(1, i)
            t[i], t[j] = t [j], t[i]
        end
        return t
end

function get_faction_rank_movements(npc, enemy_pos)
	local rank = ranks.get_obj_rank_name(npc) or "professional"
	local faction = character_community(npc)
	local weapon = set_weapon(npc)
	local weapon_type = get_weapon_type(weapon)
	local best_enemy = get_combat_enemy(npc)
	local level_vertex_id = npc:level_vertex_id()
	------------------------------------------------
	-- MOVEMENT DISTANCE PROFILE
	------------------------------------------------
	local profile =
		MOVEMENT_DISTANCE_PROFILE[faction]
		or MOVEMENT_DISTANCE_PROFILE.stalker

	local backstep_dist     = profile.backstep
	local cover_move_dist   = profile.cover_move
	local cover_search_dist = profile.cover_search
	local sneak_back_dist   = profile.sneak_back
	local strafe_dist       = profile.strafe
	local flank_dist        = profile.flank
	local peek_dist         = profile.peek
	------------------------------------------------
	-- RANK MODIFIER
	------------------------------------------------
	if rank == "novice" or rank == "trainee" then
		backstep_dist     = math.max(5, backstep_dist - 5)
		cover_move_dist   = math.max(5, cover_move_dist - 5)
		cover_search_dist = math.max(6, cover_search_dist - 6)
		sneak_back_dist   = math.max(5, sneak_back_dist - 5)
		strafe_dist       = math.max(4, strafe_dist - 2)
		flank_dist        = math.max(8, flank_dist - 5)
		peek_dist         = math.max(1, peek_dist - 1)

	elseif rank == "expert"
		or rank == "master"
		or rank == "legend"
	then
		backstep_dist     = backstep_dist + 5
		cover_move_dist   = cover_move_dist + 5
		cover_search_dist = cover_search_dist + 6
		sneak_back_dist   = sneak_back_dist + 5
		strafe_dist       = strafe_dist + 2
		flank_dist        = flank_dist + 5
		peek_dist         = peek_dist + 1
	end
	------------------------------------------------
	-- DEFAULT MOVEMENTS
	------------------------------------------------
	local default_movements = {
		movement_debug("[DEFAULT] try_go_cover", 			function() return utils_obj.try_go_cover		(npc, enemy_pos) end),
		movement_debug("[DEFAULT] try_go_cover_backward", 		function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
		movement_debug("[DEFAULT] try_go_backward", 			function() return utils_obj.try_go_backward		(npc, backstep_dist) end),
		--movement_debug("[DEFAULT] try_go_position", 			function() return utils_obj.try_go_position		(npc, enemy_pos) end),
		movement_debug("[DEFAULT] try_go_aside_object", 		function() return utils_obj.try_go_aside_object		(npc, best_enemy, enemy_pos) end),
		movement_debug("[DEFAULT] try_to_peek", 			function() return utils_obj.try_to_peek			(npc, level_vertex_id, peek_dist) end),
		movement_debug("[DEFAULT] try_to_stay", 			function() return utils_obj.try_to_stay			(npc) end),
		movement_debug("[DEFAULT] try_to_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[DEFAULT] try_to_strafe_behind_enemy", 		function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
		movement_debug("[DEFAULT] try_to_sneak", 			function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
		movement_debug("[DEFAULT] try_to_sneak_backward", 		function() return utils_obj.try_to_sneak_backward	(npc, best_enemy, sneak_back_dist, level_vertex_id) end),
		movement_debug("[DEFAULT] try_to_sneak_strafe", 		function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[DEFAULT] try_to_sneak_strafe_behind_enemy", 	function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
	}
	------------------------------------------------
	-- LOW RANK
	------------------------------------------------
	local low_rank_movements = {
		movement_debug("[<<RANK] try_go_cover", 			function() return utils_obj.try_go_cover		(npc, enemy_pos) end),
		movement_debug("[<<RANK] try_go_cover_backward", 		function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
		movement_debug("[<<RANK] try_go_backward", 			function() return utils_obj.try_go_backward		(npc, backstep_dist) end),
		--movement_debug("[<<RANK] try_go_position", 			function() return utils_obj.try_go_position		(npc, enemy_pos) end),
		movement_debug("[<<RANK] try_to_peek", 				function() return utils_obj.try_to_peek			(npc, level_vertex_id, peek_dist) end),
		movement_debug("[<<RANK] try_to_stay", 				function() return utils_obj.try_to_stay			(npc) end),
		movement_debug("[<<RANK] try_to_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[<<RANK] try_to_strafe_behind_enemy", 		function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
		movement_debug("[<<RANK] try_to_sneak", 			function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
		movement_debug("[<<RANK] try_to_sneak_backward", 		function() return utils_obj.try_to_sneak_backward	(npc, best_enemy, sneak_back_dist, level_vertex_id) end),
		movement_debug("[<<RANK] try_to_sneak_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
	}
	------------------------------------------------
	-- MID RANK
	------------------------------------------------
	local mid_rank_movements = {
		movement_debug("[<RANK>] try_go_cover", 			function() return utils_obj.try_go_cover		(npc, enemy_pos) end),
		movement_debug("[<RANK>] try_go_cover_backward", 		function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
		movement_debug("[<RANK>] try_go_backward", 			function() return utils_obj.try_go_backward		(npc, backstep_dist) end),
		--movement_debug("[<RANK>] try_go_position", 			function() return utils_obj.try_go_position		(npc, enemy_pos) end),
		movement_debug("[<RANK>] try_go_aside_object", 			function() return utils_obj.try_go_aside_object		(npc, best_enemy, enemy_pos) end),
		movement_debug("[<RANK>] try_to_peek", 				function() return utils_obj.try_to_peek			(npc, level_vertex_id, peek_dist) end),
		movement_debug("[<RANK>] try_to_stay", 				function() return utils_obj.try_to_stay			(npc) end),
		movement_debug("[<RANK>] try_to_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[<RANK>] try_to_strafe_behind_enemy", 		function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
		movement_debug("[<RANK>] try_to_sneak", 			function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
		movement_debug("[<RANK>] try_to_sneak_backward", 		function() return utils_obj.try_to_sneak_backward	(npc, best_enemy, sneak_back_dist, level_vertex_id) end),
		movement_debug("[<RANK>] try_to_sneak_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[<RANK>] try_to_sneak_strafe_behind_enemy", 	function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
	}
	------------------------------------------------
	-- HIGH RANK
	------------------------------------------------
	local high_rank_movements = {
		movement_debug("[RANK>>] try_go_cover", 			function() return utils_obj.try_go_cover		(npc, enemy_pos) end),
		movement_debug("[RANK>>] try_go_cover_backward", 		function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
		--movement_debug("[RANK>>] try_go_position", 			function() return utils_obj.try_go_position		(npc, enemy_pos) end),
		movement_debug("[RANK>>] try_go_aside_object", 			function() return utils_obj.try_go_aside_object		(npc, best_enemy, enemy_pos) end),
		movement_debug("[RANK>>] try_to_peek", 				function() return utils_obj.try_to_peek			(npc, level_vertex_id, peek_dist) end),
		movement_debug("[RANK>>] try_to_stay", 				function() return utils_obj.try_to_stay			(npc) end),
		movement_debug("[RANK>>] try_to_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[RANK>>] try_to_strafe_behind_enemy", 		function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
		movement_debug("[RANK>>] try_to_sneak", 			function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
		movement_debug("[RANK>>] try_to_sneak_strafe", 			function() return utils_obj.try_to_strafe		(npc, nil, strafe_dist) end),
		movement_debug("[RANK>>] try_to_sneak_strafe_behind_enemy", 	function() return utils_obj.try_to_strafe_behind_enemy	(npc, best_enemy, level_vertex_id, flank_dist) end),
	}
	------------------------------------------------
	-- FACTION TABLE
	------------------------------------------------
	local movement_table = {}
	movement_table[faction] = {}
	movement_table[faction].novice       = low_rank_movements
	movement_table[faction].trainee      = low_rank_movements
	movement_table[faction].experienced  = mid_rank_movements
	movement_table[faction].professional = mid_rank_movements
	movement_table[faction].veteran      = mid_rank_movements
	movement_table[faction].expert       = high_rank_movements
	movement_table[faction].master       = high_rank_movements
	movement_table[faction].legend       = high_rank_movements

	local movements = movement_table[faction][rank] or default_movements
	------------------------------------------------
	-- WEAPON OVERRIDE
	------------------------------------------------
	if weapon_type == "sniper" then
		movements = {
			movement_debug("[WEAPON_S] try_go_backward", 		function() return utils_obj.try_go_backward		(npc, backstep_dist + 5) end),
			movement_debug("[WEAPON_S] try_go_backward_far", 	function() return utils_obj.try_go_backward		(npc, backstep_dist + 15) end),
			movement_debug("[WEAPON_S] try_go_cover_backward", 	function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
			movement_debug("[WEAPON_S] try_go_cover_backward_far", 	function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist + 10, cover_search_dist + 15) end),
			movement_debug("[WEAPON_S] try_to_sneak", 		function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
			movement_debug("[WEAPON_S] try_to_sneak_backward", 	function() return utils_obj.try_to_sneak_backward	(npc, best_enemy, sneak_back_dist + 10, level_vertex_id) end),
		}

	elseif weapon_type == "launcher" then
		movements = {
			movement_debug("[WEAPON_L] try_go_backward", 		function() return utils_obj.try_go_backward		(npc, backstep_dist + 5) end),
			movement_debug("[WEAPON_L] try_go_backward_far", 	function() return utils_obj.try_go_backward		(npc, backstep_dist + 15) end),
			movement_debug("[WEAPON_L] try_go_cover_backward", 	function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist, cover_search_dist) end),
			movement_debug("[WEAPON_L] try_go_cover_backward_far", 	function() return utils_obj.try_go_cover_backward	(npc, enemy_pos, nil, cover_move_dist + 10, cover_search_dist + 15) end),
			movement_debug("[WEAPON_L] try_to_sneak", 		function() return utils_obj.try_to_sneak		(npc, enemy_pos, level_vertex_id) end),
			movement_debug("[WEAPON_L] try_to_sneak_backward", 	function() return utils_obj.try_to_sneak_backward	(npc, best_enemy, sneak_back_dist + 10, level_vertex_id) end),
		}
	end

	movements = select_movements(movements)
	return movements
end

function get_combat_movement(npc, enemy_pos)
        if not npc or not npc:alive() then return nil end

        local movements = get_faction_rank_movements(npc, enemy_pos)
        if not movements then return nil end

        for i = 1, #movements do
                local vertex = movements[i]()
                if vertex then
                        return vertex
                end
        end
        return nil
end

-----------------------------------------------------------------------------
-- ON OPTION CHANGE
-----------------------------------------------------------------------------
function on_option_change()
        enemy_debug_mode  = stealth_mcm.get_config("debug_enemy")
        DEBUG_ENEMY_OFF   = (enemy_debug_mode == 1)
        DEBUG_ENEMY_CLEAN = (enemy_debug_mode == 2)
        DEBUG_ENEMY_RAW   = (enemy_debug_mode == 3)
        DEBUG_MOVEMENT    = stealth_mcm.get_config("debug_movement")
end

-----------------------------------------------------------------------------
-- ON GAME START CALLBACKS
-----------------------------------------------------------------------------
function on_game_start()
        on_option_change()
end