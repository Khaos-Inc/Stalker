local language_list = {
    eng = true,
    rus = true,
}
local text_modifiers = {}

---comment
---@param file_name string --xml file name without extension
---@param string_id string --string id
---@param callback function --takes string from xml, returns modified string
function add_text_modifier(file_name, string_id, callback)
    local modifier = {
        file_name = file_name,
        string_id = string_id,
        callback = callback
    }
    table.insert(text_modifiers, modifier)
end

