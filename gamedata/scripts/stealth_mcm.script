local key_to_tab = {}

local function build_key_map()
	for full_path, _ in pairs(defaults) do
		local tab, key = full_path:match("(.+)%/(.+)")
		if tab and key then key_to_tab[key] = tab end
	end
end

function get_config(key)
	if not next(key_to_tab) then build_key_map() end
	local tab = key_to_tab[key]
	if not tab then return nil end
	if ui_mcm then
		local val = ui_mcm.get("stealth/" .. tab .. "/" .. key)
		if val ~= nil then return val end
	end
	return defaults[tab .. "/" .. key]
end

