local agressive_response = true

-- 8. Weather-profile system
-- Each weather profile defines desired luminance at key times of day.
local weather_profiles = {
   default = {
      [0]  = 0.1,
      [2]  = 0.1,
      [4]  = 0.1,
      [6]  = 0.6,
      [8]  = 0.7,
      [10] = 0.8,
      [12] = 0.9,
      [14] = 0.9,
      [16] = 0.8,
      [18] = 0.7,
      [20] = 0.5,
