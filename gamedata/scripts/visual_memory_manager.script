local weather_rain = 0.75
local weather_storm = 0.7
local weather_fog = 0.7
local weather_default = 0.9

-- 3. Luminance Normalization Controls
local global_luminance_multiplier = 1
local dark_area_boost_strength = 0
local bright_area_nerf_strength = 0

-- 4. Movement and Body Factors
local crouch_visibility_multiplier = 0.6
local slow_crouch_visibility_multiplier = 0.4
local sprinting_visibility_multiplier = 1.25
local surface_noise_intensity = 0.2

-- 5. Lighting and Environmental Factors
local campfire_influence_distance = 7
