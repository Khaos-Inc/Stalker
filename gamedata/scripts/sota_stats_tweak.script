		["boost_explosion_immunity"]	= { index= 17,	typ= "float",	name= "ui_inv_outfit_explosion_protection",		icon_p= "ui_am_prop_explo",					icon_n= "ui_am_prop_explo_minus",			track= false,	magnitude= (100 * adj_boost_t["explosion"]),																				unit= "st_perc",							compare= false,	sign= true,		show_always= false	},
		["boost_fire_wound_immunity"]	= { index= 18,	typ= "float",	name= "ui_inv_outfit_fire_wound_protection",	icon_p= "ui_am_propery_01",					icon_n= "ui_am_prop_fire_wound_negative",	track= false,	magnitude= (100 * adj_boost_t["fire_wound"]	/ SYS_GetParam(2,"actor_condition","max_fire_wound_protection")),				unit= "st_perc",							compare= false,	sign= true,		show_always= false	},
		
		["boost_anabiotic"]				= { index= 19,	typ= "float",	name= "",										icon_p= "ui_am_prop_Vibros",				icon_n= "ui_am_prop_anabiotic",				track= false,	magnitude= 1000,																											unit= "",									compare= false,	sign= true,		show_always= false	},
		["boost_max_weight"]			= { index= 20,	typ= "float",	name= "ui_inv_outfit_additional_weight",		icon_p= "ui_am_propery_08",					icon_n= "ui_am_prop_max_weight",			track= false,	magnitude= 1,																												unit= "st_kg",								compare= false,	sign= true,		show_always= false	},
	}
	
	if hts_inventory_bars then
--		utils_ui.stats_table["booster"]["eat_satiety"					] = { index	= 4, typ= "float", name= "ui_inv_satiety",	icon_p= "ui_am_prop_satiety_restore_speed",	icon_n= "ui_am_prop_satiety",	track= false, magnitude= 100,							unit= "st_perc", compare= false, sign= true, show_always= false	}
		utils_ui.stats_table["booster"]["eat_thirstiness"				] = { index	= 5, typ= "float", name= "ui_inv_thirst",	icon_p= "ui_am_prop_thirst_n",				icon_n= "ui_am_prop_thirst_p",	track= false, magnitude= -(100*thirst_mul/thirst_max),	unit= "st_perc", compare= false, sign= true, show_always= false }
		utils_ui.stats_table["booster"]["eat_sleepiness"				] = { index	= 6, typ= "float", name= "ui_inv_sleep",	icon_p= "ui_am_prop_sleep_n",				icon_n= "ui_am_prop_sleep_p",	track= false, magnitude= -(100*sleep_mul/sleep_max),	unit= "st_perc", compare= false, sign= true, show_always= false }
		utils_ui.stats_table["booster"]["boost_power_restore"			].index		= 7
		utils_ui.stats_table["booster"]["boost_radiation_restore"		].index		= 8
		utils_ui.stats_table["booster"]["boost_radiation_immunity"		].index		= 9
		utils_ui.stats_table["booster"]["boost_radiation_protection"	].index		= 10
		utils_ui.stats_table["booster"]["boost_chemburn_immunity"		].index		= 11
		utils_ui.stats_table["booster"]["boost_chemburn_protection"		].index		= 12
		utils_ui.stats_table["booster"]["boost_shock_immunity"			].index		= 13
		utils_ui.stats_table["booster"]["boost_burn_immunity"			].index		= 14
		utils_ui.stats_table["booster"]["boost_telepat_immunity"		].index		= 15
		utils_ui.stats_table["booster"]["boost_telepat_protection"		].index		= 16
		utils_ui.stats_table["booster"]["boost_wound_immunity"			].index		= 17
		utils_ui.stats_table["booster"]["boost_strike_immunity"			].index		= 18
