	end
end

-- custom functor to call the original function in utils_ui and scale the return value up to a percent.
function scale_100(obj, sec, base_file, base_func, param)
	local base_value = _G[base_file][base_func](obj, sec, param)
	return math.floor(base_value * 100)
end

-- custom functor to retrieve the highest pellet count from compatible ammunition and multiply with the base damage value.
-- this is to display a better damage value for shotguns that can fire buck shot.
function scale_100_for_pellets(obj, sec, base_file, base_func, param)
	local base_damage = scale_100(obj, sec, base_file, base_func, param)
	
	local max_pellet_count = 0
	
	local id = obj and obj:id()
	local ammo_list = utils_item.get_ammo(sec, id)
	
	for _, ammo_name in pairs(ammo_list) do
		if ammo_name ~= "ammo_12x70_buck_self" then
			local pellet_count = ini_sys:r_float_ex(ammo_name, "buck_shot") or 1
			if pellet_count > max_pellet_count then
				max_pellet_count = pellet_count
			end
		end
	end
	return base_damage * max_pellet_count
end

local og_inventory_init = ui_inventory.UIInventory.__init
function ui_inventory.UIInventory:__init()
	og_inventory_init(self)
	
	local ctrl_stats_lst	= ui_rework_support.ctrl_stats_lst
	
	local ctrl_stats_def	= ctrl_stats_lst[1]
	local xml_stats			= self.xml
	
	for _,ctrl_stats in ipairs(ctrl_stats_lst) do
		
		if (ctrl_stats ~= ctrl_stats_def) then
			xml_stats = CScriptXmlInit()
			xml_stats:ParseFile("actor_menu_state_info" .. ctrl_stats .. ".xml")
		end
		
		local str_stat		= "stat" .. ctrl_stats
		
		for name,_ in pairs(self.stat_list) do
			if not ( (ctrl_stats ~= "_hts_ext") and ( (name == "strike") or (name == "explosion") ) ) then
				self[str_stat][name].bar_bns = xml_stats:InitProgressBar( "equipment:actor_state_info:" .. name .. "_sensor:state_progress" , self[str_stat][name].base )
			end
		end
		
		if (not hts_inventory_bars) then break end
	end
end
--[[
function clr_to_str(clr)
	local a,r,g,b = 255
	if (not clr) then
		return strformat("%c[%s,%s,%s,%s]",a,r,g,b)
	end
	a = bit.band(bit.rshift(clr, 24), 255)
	r = bit.band(bit.rshift(clr, 16), 255)
	g = bit.band(bit.rshift(clr, 8), 255)
	b = bit.band(clr, 255)
	return strformat("%c[%s,%s,%s,%s]",a,r,g,b)
end
--]]
local og_inventory_recolor_stats = ui_inventory.UIInventory.RecolorStats
function ui_inventory.UIInventory:RecolorStats()
	og_inventory_recolor_stats(self)
	
	local clr_w				= clr_stats_t["w"]
	
	local use_faction_color	= color_settings.stat_colors
	local use_colored_stats	= color_settings.colored_stats
	
	for name,v in pairs(self.stat) do
		local color = use_faction_color and self.faction_color or stat_colors[name]
		
		local final_color = use_colored_stats and color or clr_w
		v.bar_bns:SetColor( final_color )
	end
end

local og_inventory_update_stats = ui_inventory.UIInventory.UpdateStats
function ui_inventory.UIInventory:UpdateStats()
	og_inventory_update_stats(self)
	
	self:UpdateStatsBonus()
end

function ui_inventory.UIInventory:UpdateStatsBonus()
	
	local obj = hovered_object and get_object_by_id(hovered_object)
	
-- init of bonus stats values
	local stat_outfit_bonus = {}
	local stat_helm_bonus = {}
	for name,v in pairs(self.stat) do
		v.value_bonus = v.value
		-- need to save stats of new equipment when comparing
		stat_outfit_bonus[name] = self.stat_outfit[name]
		stat_helm_bonus[name] = self.stat_helm[name]
	end
	
-- calculation of bonuses and boosters
	if obj then
		local actor = db.actor
		local sec = obj:section()
		local cond = obj:condition()
		local cond_opp = 1
		if ui_inventory.show_full_stats then
			cond_opp = 1/cond
			cond = 1
		end
		
		local helm_available = true
		local outfit = actor:item_in_slot(7)
		if outfit then
			helm_available = outfit:cast_CustomOutfit().bIsHelmetAvaliable
		end
		
		if IsOutfit(obj) then
			local in_slot_modifier = item_backpack.is_in_slot(obj) and 0 or 1
			local c_outfit = obj:cast_CustomOutfit()
			local has_helm = (not c_outfit.bIsHelmetAvaliable)
			
			for name,v in pairs(prot_stats) do
				local stat = self.stat[name]
				if (not stat) then
					goto continue
				end
				
				local val_max = self.stat_list[name].max
				local old_outfit = self.stat_outfit[name] / val_max
				if has_helm then
					old_outfit = old_outfit + self.stat_helm[name] / val_max
				end
				local new_outfit = 0
				
				if (name == "fire_wound") then
					local bone_value = c_outfit:GetBoneArmor( BoneID["bip01_spine"] ) or 0
					if has_helm then
						bone_value = bone_value + (c_outfit:GetBoneArmor( BoneID["bip01_head"] ) or 0)
					end
					new_outfit = bone_value * cond
				elseif (name == "power") then
					local outfit_power = cond * (c_outfit.m_fPowerRestoreSpeed or 0)
					
					local power_clamp = 15 -- to bring power to vanilla values
					local power = actor:cast_Actor():conditions():V_SatietyPower()
					power = power - self.stat_boost[name]
					local power_no_outfit = power / 0.5
					
					power = power + outfit_power
					local power_loss = c_outfit.m_fPowerLoss or 0
					if (power_loss ~= 0) then
						power = power / power_loss
					end
					new_outfit = (power - power_no_outfit) / power_clamp
				else
					new_outfit = cond_opp * (c_outfit:GetDefHitTypeProtection( HitTypeID[ v.prot ] ) or 0)
				end
				new_outfit = new_outfit * in_slot_modifier
				
				stat_outfit_bonus[name] = new_outfit
				
				new_outfit = new_outfit - self.stat_arty[name]
				
				stat.value_bonus = stat.value - old_outfit + new_outfit / val_max
				
				::continue::
			end
		elseif IsHeadgear(obj) and helm_available then
			local in_slot_modifier = item_backpack.is_in_slot(obj) and 0 or 1
			local c_helm = obj:cast_Helmet()
			
			for name,v in pairs(prot_stats) do
				local stat = self.stat[name]
				if (not stat) then
					goto continue
				end
				
				local val_max = self.stat_list[name].max
				local old_helm = self.stat_helm[name] / val_max
				local new_helm = 0
				
				if (name == "fire_wound") then
					local bone_value = c_helm:GetBoneArmor( BoneID["bip01_head"] ) or 0
					new_helm = bone_value * cond
				elseif (name == "power") then
					new_helm = 0
				else
					new_helm = cond_opp * (c_helm:GetDefHitTypeProtection( HitTypeID[ v.prot ] ) or 0)
				end
				new_helm = new_helm * in_slot_modifier
				
				stat_helm_bonus[name] = new_helm
				
				stat.value_bonus = stat.value - old_helm + new_helm / val_max
				
				::continue::
			end
		elseif IsArtefact(obj) then
			
			local is_on_belt = actor:is_on_belt(obj) -- selected artefact is on the belt
			local in_belt_modifier = is_on_belt and -1 or 1
			
			-- if the selected artefact is not on the belt, then we look for a free slot for it
			if (not is_on_belt) then
				
				local has_free_slot
				local cnt_arty = actor:belt_count()
				local cc = self.CC["actor_belt"]
				local cnt_cell = #cc.cell
				
				-- search for at least one free slot
				for i=1,cnt_cell do
					if (i > cnt_arty) and (not self.blocker_arty[i]:IsShown()) then
						has_free_slot = true
						break
					end
				end
				
				-- if there is no free slot, then the new artefact will not fit on the belt
				if (not has_free_slot) then return end
			end
			
			for name,v in pairs(prot_stats) do
				local stat = self.stat[name]
				if (not stat) then
					goto continue
				end
				
				local val_max = self.stat_list[name].max
				local bonus = 0
				
				if (name == "power") then
					bonus = cond * SYS_GetParam(2, sec, v.arty, 0)
				else
					local immunities_sec = SYS_GetParam(0, sec, "hit_absorbation_sect", 0)
					bonus = cond * SYS_GetParam(2, immunities_sec, v.arty, 0)
				end
				
				local adj = adj_arty_t[name]
				if adj then
					bonus = bonus * adj
				end
				bonus = bonus * in_belt_modifier
				
				stat.value_bonus = stat.value + bonus / val_max
				
				::continue::
			end
		elseif IsItem("consumable", sec) then
			for name,_ in pairs(prot_stats) do
				local stat = self.stat[name]
				if (not stat) then
					goto continue
				end
				
				local val_max = self.stat_list[name].max
				local bonus = get_booster_protection(obj, sec, name, 0)
				local booster = self.stat_boost[name]
				
				-- remove unnecessary precision of values
				bonus = round_idp( bonus, 6 )
				booster = round_idp( booster, 6 )
				
				-- boosters don't stack, only increase to a large boost
				if (booster < bonus) then
					bonus = bonus - booster
				else
					bonus = 0
				end
				
				stat.value_bonus = stat.value + bonus / val_max
				
				::continue::
			end
			
			for name,_ in pairs(simple_stats) do
				local stat = self.stat[name]
				if stat then
					stat.value_bonus = stat.value + (simple_stat_values(obj, name) or 0)
				end
			end
		end
	end
	
-- compare and recolor stats
	local use_faction_color		= color_settings.stat_colors
	local use_colored_stats		= color_settings.colored_stats
	local idp_stats_inv			= color_settings.show_num_stats_ext and 0 or color_settings.idp_stats_inv
	local xml_clr_w				= xml_clr_t["w"]
	
	for name,v in pairs(self.stat) do
		if ( not v.base:IsShown() ) then
			goto continue
		end
		
		local old = v.value
		local new = v.value_bonus
		
		-- remove unnecessary precision of values
		old = round_idp( old, 6 )
		new = round_idp( new, 6 )
		
		if simple_stats[name] then
			old = clamp( old, 0, 1 )
			new = clamp( new, 0, 1 )
		end
		
		local clr_stat = use_faction_color and self.faction_color or stat_colors[name]
		local clr_bns = clr_stats_t["w"]
		local clr_bar = use_colored_stats and clr_stat or clr_stats_t["w"]
		
		local val_bns = old
		local val_bar = old
		
		if (new ~= old) then
			if (new > old) then
				clr_bns = clr_stats_t["g"]
				val_bns = old
				val_bar = new
			else--if (new < old) then
				clr_bns = clr_stats_t["r"]
				val_bns = new
				val_bar = old
			end
			v.bar:SetColor( clr_bns )
			v.bar_bns:SetColor( clr_bar )
		end
		v.bar:SetProgressPos( val_bar )
		v.bar_bns:SetProgressPos( val_bns )
		
		if v.txt_val:IsShown() then
			v.txt_val:SetTextColor( clr_bns )
			v.txt_val:SetText( stats_round_idp( new * 100 , idp_stats_inv ) .. st_perc )
		end
		
		if v.txt_val_ext:IsShown() then
			local val_max = self.stat_list[name].max
			
			local old_outfit = stats_round_idp( self.stat_outfit[name] / val_max * 100 , idp_stats_inv )
			local new_outfit = stats_round_idp( stat_outfit_bonus[name] / val_max * 100 , idp_stats_inv )
			
			local old_helm = stats_round_idp( self.stat_helm[name] / val_max * 100 , idp_stats_inv )
			local new_helm = stats_round_idp( stat_helm_bonus[name] / val_max * 100 , idp_stats_inv )
			
			local xml_clr_bns_outfit = (new_outfit ~= old_outfit) and ( (new_outfit > old_outfit) and xml_clr_t["g"] or xml_clr_t["r"] ) or xml_clr_w
			local xml_clr_bns_helm = (new_helm ~= old_helm) and ( (new_helm > old_helm) and xml_clr_t["g"] or xml_clr_t["r"] ) or xml_clr_w
			
			local st_outfit = gts("st_stats_subtitle_outfit")
			local str_outfit = xml_clr_w .. st_outfit .. ": " .. xml_clr_bns_outfit .. new_outfit .. st_perc
			
			local st_helm = gts("st_stats_subtitle_helm")
			local str_helm = xml_clr_w .. st_helm .. ": " .. xml_clr_bns_helm .. new_helm .. st_perc
			local str_gap = (new_outfit < 10) and "	 " or (new_outfit < 100) and " " or ""
			
			v.txt_val_ext:SetText( str_outfit .. ", " .. str_gap .. str_helm )
		end
		
		::continue::
	end
end

-- ========== start of utils from Accurate Stats Extended - G_FLAT x momopate (small edit by Sota) ==========
function get_booster_protection(obj, sec, name, def)
	def = def or 0
	
	if (not name) then
		return def
	end
	
	local param = prot_stats[name].boost
	if (not param) then
		return def
	end
	
	if (not sec) then
		if (not obj) then
			return def
		end
		sec = obj:section()
	end
	
	local prot = SYS_GetParam(2, sec, param, 0)
	
	local adj = adj_boost_t[name]
	if adj then
		prot = prot * adj
	end
	
	return prot
end

function simple_stat_values(obj, name)
	if obj then
		local sec = obj:section()
		if (name == "health") then
			local hp_num = 0
			local thp_num = 0
			local boost_time = ini_sys:r_float_ex(sec, "boost_time")
			
			local eat_health = ini_sys:r_float_ex(sec, "eat_health")
			if eat_health then
				hp_num = eat_health
			end
			
			if boost_time and (boost_time ~= 0) then
				local boost_health_restore = ini_sys:r_float_ex(sec, "boost_health_restore")
				if boost_health_restore then
					thp_num = boost_health_restore * 6 * boost_time
				end
			end
			
			return hp_num + thp_num
		elseif (name == "hunger") then
			local eat_sat = ini_sys:r_float_ex(sec, "eat_satiety")
			if eat_sat then
				return eat_sat
			end		
		elseif (name == "thirst") then
			local eat_thirstiness = ini_sys:r_float_ex(sec, "eat_thirstiness")
			if eat_thirstiness then
				return -(eat_thirstiness * thirst_mul / thirst_max)
			end		
		elseif (name == "sleep") then
			local eat_sleepiness = ini_sys:r_float_ex(sec, "eat_sleepiness")
			if eat_sleepiness then
				return -(eat_sleepiness * sleep_mul / sleep_max)
			end		
		end
	else
		if (name == "health") then
			return db.actor.health
		elseif (name == "hunger") then
			return hts_inventory_bars.get_satiety_val()
		elseif (name == "thirst") then
			return hts_inventory_bars.get_thirst_val()
		elseif (name == "sleep") then
			return hts_inventory_bars.get_sleep_val()
		end
	end
end

hovered_object = nil
local function update_with_focus(obj)
	-- if db.actor:is_on_belt(obj) then return end
	hovered_object = obj:id()
	local gui = ui_inventory.GUI
	if gui then
		gui:UpdateStats()
	end
end

local function update_no_focus()
	hovered_object = nil
	local gui = ui_inventory.GUI
	if gui then
		gui:UpdateStats()
	end
end
-- ========== end of utils from Accurate Stats Extended - G_FLAT x momopate (small edit by Sota) ==========

-- update only tooltip and stats, also control blocking if full stats key is pressed (taken (with edits by Sota) from momopate_accurate_stats.script)
local function update_gui(gui)
	if gui and gui.item_info then
		gui:UpdateStats()
		gui.item_info:Update()
		local is_kcrouch = ui_inventory.color_settings.full_stats_key == bind_to_dik(key_bindings.kCROUCH)
		gui:AllowMovement( not (ui_inventory.show_full_stats and is_kcrouch) and (gui.mode == "inventory") )
	end
end

-- function to return tooltip delay back (taken unchanged from momopate_accurate_stats.script)
local nextTick = _G.nextTick or function(f, n)
	n = math.floor(math.max(n or 1, 1))
	AddUniqueCall(function()
		if n == 1 then
			return f()
		else
			n = n - 1
			return false
		end
	end)
end

-- show full stats of item (taken (with edits by Sota) from momopate_accurate_stats.script)
local function on_key_press(key)
	local gui = ui_inventory.GUI
	if gui and hovered_object then -- Edited by Sota - no need show full stats if no object is hovered
		if (key == ui_inventory.color_settings.full_stats_key) and (actor_menu.get_last_mode() > 0) then -- edited by G_FLAT, no stutter when inventory is closed
			--printf("full stats key pressed")
			ui_inventory.show_full_stats = true
			--gui.item_info.delay = 0
			update_gui(gui)
			--nextTick(function()
					--gui.item_info.delay = instant_tooltip and instant_tooltip.delay or 350
					--end, 5)
		end
	end
end

-- hide full stats of item (taken (with edits by Sota) from momopate_accurate_stats.script)
local function on_key_release(key)
	local gui = ui_inventory.GUI
	if gui then
		if (key == ui_inventory.color_settings.full_stats_key) and (actor_menu.get_last_mode() > 0) then -- edited by G_FLAT, no stutter when inventory is closed
			--printf("full stats key released")
			ui_inventory.show_full_stats = false
			--gui.item_info.delay = 0
			update_gui(gui)
			--nextTick(function()
					--gui.item_info.delay = instant_tooltip and instant_tooltip.delay or 350
					--end, 5)
		end
	end
end

function on_game_start()
	-- callbacks for comparison hovered items (from Accurate Stats Extended - G_FLAT x momopate)
	RegisterScriptCallback("ActorMenu_on_item_focus_receive", update_with_focus)
	RegisterScriptCallback("ActorMenu_on_item_focus_lost", update_no_focus)
	RegisterScriptCallback("actor_item_to_belt", update_no_focus)
	RegisterScriptCallback("actor_item_to_slot", update_no_focus)
	RegisterScriptCallback("actor_item_to_ruck", update_no_focus)
	RegisterScriptCallback("actor_on_item_drop", update_no_focus)
	RegisterScriptCallback("actor_on_item_use", update_no_focus)
	RegisterScriptCallback("GUI_on_hide", update_no_focus)
	-- callbacks for show full stats
	RegisterScriptCallback("on_key_press", on_key_press)
	RegisterScriptCallback("on_key_release", on_key_release)
end
