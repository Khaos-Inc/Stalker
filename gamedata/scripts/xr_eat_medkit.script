local db = db
local level = level
local time_global = time_global
local math_random = math.random
local string_find = string.find
-------------------------------
local function ai_medkit_enabled() 
	return stealth_mcm.get_config("enable_ai_medkit") 
end

local function debug_medkit_enabled()
	return stealth_mcm.get_config("debug_medkit")
end

local _eating = {}
local _enabled
local _max_strings
-------------------------------------------------------------------------------------
-- PRIVATE
-------------------------------------------------------------------------------------
local LOUD_DEBUG = false

function pr(...)
	if not debug_medkit_enabled() then
		return true
	end

	local txt = strformat(...)

	if LOUD_DEBUG then 
		tasks_chimera_scan.message_by_id(0, txt)
	end

	printf("xr_eat_medkit: %s", txt)

	return true
end

function get_max_strings()
	local i = 0
	while not (game.translate_string("st_eat_medkit_cry_"..(i+1)) == "st_eat_medkit_cry_"..(i+1)) do
		i = i + 1
	end
	return i
end

function on_register(se, kind)
	if not (kind == "se_stalker") then return end
	if math.random() > 0.5 then
		pr('on_register(%s): healing charge ok',se:name())
		se_save_var( se.id, se:name(), "healing_charge", true)
	end
end

