-- ADD YOUR FUNCTORS FOR RELOAD SPEED INCREASE USING THIS

local reload_speed_increase = {}

function add_reload_speed_increase(functor, priority)
	table.insert(reload_speed_increase, {functor = functor, priority = priority})
	
	table.sort(reload_speed_increase, function(a,b) return a.priority < b.priority end)
end

function change_reload_animation_speed(anim_table, obj)
	local anm_name = anim_table.anm_name
	printdbg("anm_name is %s!", anm_name)
	if not anm_name:startswith("anm_reload") and not anm_name:startswith("anm_add_cartridge") and not anm_name:startswith("anm_open") and not anm_name:startswith("anm_close") or anm_name:find("misfire") then 
		printdbg("not the right anim!")
		return 
	end
	if obj:parent() and obj:parent():id() ~= AC_ID then return end
	
	printdbg("change_reload_animation_speed called!")
	local speed, cam_anim_bool
	
	--print_r(reload_speed_increase)
	for i, func_table in ipairs(reload_speed_increase) do
		speed, cam_anim_bool = func_table.functor(anim_table, obj)
		if speed then break end
	end
	
	if mcm_cam_anim then
		cam_anim_bool = false
	end
	
	if not speed then 
		printdbg("uh oh, speed is nil!")
		return 
	end
	
	printdbg("speed is %s, cam_anim_bool is %s!", speed, cam_anim_bool)
	
	local wpn_sec = obj:section()
	local hud_sec = ini_sys:r_string_ex(wpn_sec,"hud")
	local ltx_params = ini_sys:r_string_ex(hud_sec, anm_name)
	if not ltx_params then return end
	local ltx_anim_speed = tonumber((str_explode(ltx_params, ","))[3]) or 1
	
	anim_table.anm_speed = ltx_anim_speed * speed
	
	-- VERDATIM:
	local anm_name = anim_table.anm_name	
	local wpn_sec = obj:section()
	local hud_sec = ini_sys:r_string_ex(wpn_sec,"hud")
	-- Some ways to get around weird camera anims during reloads. Either 1. Disable them entirely. 2. Disable them only after the animation is complete. or 3. decrease its power proportionately to speed
	-- Only remove after anim is finished below:
	--[[
	local stop_cam_anim_length = game.get_motion_length(hud_sec, anm_name, anim_table.anm_speed)/1000
	printdbg("stop_cam_anim_length is %s", stop_cam_anim_length)
	CreateTimeEvent("ver_fast_reload_fix", "stop_cam_anim", tonumber(stop_cam_anim_length), function()
		for i = 5000,10000 do
			level.remove_cam_effector(i)
			printdbg("ver: tried to remove cam anim %s!", i)
		end
		printdbg("ver: tried to remove cam anim!")
		return true
	end)
	]]
	-- Remove entirely if any speed bonus available
	if not cam_anim_bool then
		-- not ENTIRELY sure how optimised this is but its necessary, just dont reload too often yeah?

		nextTick(function()
			for i = 5000,10000 do
				level.remove_cam_effector(i)
				--printdbg("ver: tried to remove cam anim %s!", i)
			end
			return true
		end)
	end
	
	-- Scale down the power if any speed bonus available, MOST COMPLEX AND CAUSES CRASHES FOR SOME REASON 
	--[=[
	if (1 + (reload_bonuses[x_cxv_perks_data.perks["perk_rapid_reload"]] * 0.01) + zone_slayer_bonus + wick_mode_bonus) > 1 then
		nextTick(function()
			for i = 5000,10000 do
				level.remove_cam_effector(i)
				--printdbg("ver: tried to remove cam anim %s!", i)
			end
			local motion_params = ini_sys:r_string_ex(hud_sec, anm_name)
			if not motion_params then return true end
			local motion_params = str_explode(motion_params, ",")
			local hand_animation = motion_params[1]
			local camera_animation = "camera_effects\\weapon\\" .. tostring(hand_animation) .. ".anm"
			printdbg("hand animation is %s", tostring(hand_animation)..".anm")
			
			printdbg(hand_animation..".anm")
			printdbg("whatever the hell this is %s", getFS():exist("$game_anims$", "camera_effects\\weapon\\"..hand_animation..".anm"))
			if not camera_animation or not getFS():exist("$game_anims$", "camera_effects\\weapon\\" ..hand_animation..".anm") then return true end
			
			local cam_power = (1 / ((1 + (reload_bonuses[x_cxv_perks_data.perks["perk_rapid_reload"]] * 0.01) + zone_slayer_bonus + wick_mode_bonus)^2)) or 0
			level.add_cam_effector(camera_animation, 12394, false, " ", 0, false, cam_power)
			local stop_cam_anim_length = game.get_motion_length(hud_sec, anm_name, anim_table.anm_speed)/1000
			printdbg("stop_cam_anim_length is %s", stop_cam_anim_length)
			CreateTimeEvent("ver_fast_reload_fix", "stop_cam_anim", tonumber(stop_cam_anim_length), function()
				level.remove_cam_effector(12394)
				return true
			end)
			return true
		end)
	end]=]
	
	-- TEST FUNCTION TO ADD CUSTOM RELOAD TIMINGS (thanks a bunch to the team behind arisaka for the inventory iterator and ammo code!)
	local anim_length = game.get_motion_length(hud_sec, anm_name, anim_table.anm_speed)/1000
	local motion_params = ini_sys:r_string_ex(hud_sec, anm_name)
	local motion_params = str_explode(motion_params, ",")
	local hand_animation = motion_params[1]
	local motion_mark
	local reload_time
	if hand_animation then
		motion_mark = ini_marks:r_float_ex("motion_marks", hand_animation)
		--printdbg('ini_marks:r_float_ex("motion_marks", hand_animation) is %s', ini_marks:r_float_ex("motion_marks", hand_animation))
		if not motion_mark then
			motion_mark = mcm_motion_mark_def
			printdbg("no motion mark found in custom_reload_speed_motion_marks.ltx! Default is %s, hand_animation is %s", mcm_motion_mark_def, hand_animation)
		else
			printdbg("motion mark found! multiplier is %s", motion_mark)
		end
	else
		motion_mark = mcm_motion_mark_def
		printdbg("no hand animation????? settings default motion mark to... default??")
	end
	reload_time = anim_length * motion_mark
	local og_anim_length = game.get_motion_length(hud_sec, anm_name, animation_speed)/1000
	
	wpn_id = obj:id()
	
	local tri_state_reload = ini_sys:r_string_ex(wpn_sec, "tri_state_reload")
	printdbg("tri state reload is %s", tri_state_reload)
	if tri_state_reload ~= "on" then
		if reload_time and speed > 1 then 
			printdbg("attempt early reload!")
			temp_num = nil
			
			-- okay why are there so many bugs
			CreateTimeEvent("i hate my life ver", "cool_down_start", 0.02, function()
				--RegisterScriptCallback("actor_on_item_take", prevent_ammo_pickup) -- lmao turns out i had infinite ammo on during testing which broke the script. this "fix" isnt needed.
				return true
			end)
			
			-- Cool down timer to prevent ammo duplication
			CreateTimeEvent("i hate my life ver", "cool_down_timer", anim_length, function()
				printdbg("removing time events and unregistering callback!")
				RemoveTimeEvent("ver_reload_sound", "set_ammo_elapsed")
				RemoveTimeEvent("ver_reload_sound", "set_ammo_elapsed2")
				--UnregisterScriptCallback("actor_on_item_take", prevent_ammo_pickup)
				return true
			end)
			
			-- first reload
			CreateTimeEvent("ver_reload_sound", "set_ammo_elapsed", reload_time, function(wpn_id)
				local wpn = get_object_by_id(wpn_id)
				if not wpn and not wpn:is_weapon() then return true end
				local current_ammo = wpn:cast_Weapon():GetAmmoElapsed()
				local mag_size = wpn:cast_Weapon():GetAmmoMagSize()
				
				local ammo_list = utils_item.get_ammo(nil,wpn_id)
				local ammo_name = ammo_list[wpn:get_ammo_type() + 1]
				local ammo_have = utils_item.get_amount(db.actor,ammo_name) or 0
				local num = math.min(mag_size,ammo_have)
				if (current_ammo + ammo_have) > num then
					num = math.min(current_ammo + ammo_have, mag_size)
				end
				printdbg("ver stupid: ammo_list %s, ammo_name %s, ammo_have %s, num %s", ammo_list, ammo_name, ammo_have, num)
				wpn:cast_Weapon():SetAmmoElapsed(num)
				temp_num = num
				reduce_ammo(ammo_name,num - current_ammo)
				printdbg("tried to reload early!")
				-- second reload, necessary because engine can override our reload. ---- WHY DO I KEEP USING UNLIMITED AMMO DURING TESTING. I KEEP ADDING UNECESSARY SHIT.
				--[[
				CreateTimeEvent("ver_reload_sound", "set_ammo_elapsed2", math.abs(og_anim_length-anim_length), function(wpn_id, temp_num)
					local wpn = get_object_by_id(wpn_id)
					printdbg("reset reload again!")
					if not wpn and not wpn:is_weapon() then return true end
					wpn:cast_Weapon():SetAmmoElapsed(temp_num)
					temp_num = nil
					return true
				end, wpn_id, temp_num)]]
				return true
			end, wpn_id)
		end
	end
	
	
	-- sounds boo
	local sound_name = nil
	
	if anm_name:startswith("anm_reload") then 
		sound_name = "snd_reload"
		if string.find(anm_name, "empty") then
			sound_name = "snd_reload_empty"
		end
		if string.find(anm_name, "1") then
			sound_name = "snd_reload_1"
		end
	end
	if anm_name:startswith("anm_reload_g") then
		sound_name = "snd_reload_grenade"
	end
	if anm_name:startswith("anm_add_cartridge") then
		sound_name = "snd_add_cartridge"
	end
	
	
	local scripted_snd = string.gsub(anm_name, "anm_", "scripted_snd_")
	local scripted_sound_check = ini_sys:r_string_ex(wpn_sec, scripted_snd)
	
	if scripted_sound_check then
		scripted_sound_check_table = str_explode(scripted_sound_check, ",")
		scripted_sound_check = scripted_sound_check_table[1] or scripted_sound_check
		printdbg("scripted_snd is %s", scripted_snd)
		printdbg("scripted_sound_check is %s", scripted_sound_check)

		common.stop_all_sound_object(wpn_sec)
		local snd_obj = common.get_safe_sound_object(scripted_sound_check, wpn_sec)
		snd_obj:play(db.actor, 0, 2)
		snd_obj.frequency = snd_obj.frequency * speed
		snd_obj.volume = snd_obj.volume * speed
		printdbg("snd_obj.volume is %s", snd_obj.volume)
		return
	end
	
	printdbg("ver: anm_name is %s", anm_name)
	printdbg("ver: wpn_sec is %s, sound_name is %s", wpn_sec, sound_name)
	if not sound_name or not wpn_sec then return end
	local sound_path = ini_sys:r_string_ex(wpn_sec, sound_name) or " "
	local sound_path_table = str_explode(sound_path, ",")
	local sound_path = sound_path_table[1] or sound_path
	sound_name = nil
	if not sound_path then return end
	
	snd_obj = common.get_safe_sound_object(sound_path, wpn_sec)
	if not snd_obj then return end
	--[[
	CreateTimeEvent("ver_fast_reload_sound", "speed_up_sound", 0.1, function(snd_obj, ver_reload_bonus, zone_slayer_bonus, wick_mode_bonus)
		printdbg("sound_object playing is %s", snd_obj:playing())
		if snd_obj:playing() then
			snd_obj.frequency = snd_obj.frequency * (1 + ver_reload_bonus + zone_slayer_bonus + wick_mode_bonus)
			printdbg("ver: sound frequency changed to %s!", snd_obj)
		else
			printdbg("ver: sound not playing!")
		end
		return true
	end, snd_obj, ver_reload_bonus, zone_slayer_bonus, wick_mode_bonus)]]
	
	--[[
	printdbg("sound_object playing is %s", snd_obj:playing())
		if snd_obj:playing() then
			snd_obj.frequency = snd_obj.frequency * (1 + ver_reload_bonus + zone_slayer_bonus + wick_mode_bonus)
			printdbg("ver: sound frequency changed to %s!", snd_obj)
		else
			printdbg("ver: sound not playing!")
		end]]
	
	snd_obj:play(db.actor, 0, 2)
	snd_obj.frequency = snd_obj.frequency * speed
	snd_obj.volume = snd_obj.volume * speed
	printdbg("snd_obj.volume is %s, frequency is %s", snd_obj.volume, snd_obj.frequency)
	
end

function on_game_start()
	
	-- Verdatim
	RegisterScriptCallback("actor_on_hud_animation_play", change_reload_animation_speed)
	RegisterScriptCallback("on_before_play_hud_sound", remove_sound)
	
	-- TEST CALLBACK FOR EARLY FAST RELOADS
	--RegisterScriptCallback("actor_on_hud_animation_mark", ver_reload_now)
	--RegisterScriptCallback("actor_on_hud_animation_end", zero_ammo_check)
	
	-- INI callbacks
	RegisterScriptCallback("on_game_load", initialize)
    RegisterScriptCallback("on_option_change", initialize)
	
	-- Stop any pending processes if hide anim is initiated
	RegisterScriptCallback("actor_on_hud_animation_play", stop_all_processes)
	
	-- MCM stuff
	RegisterScriptCallback("on_option_change", get_mcm_values)
	RegisterScriptCallback("actor_on_first_update", get_mcm_values)
end

function initialize()
    ini_marks = ini_file("plugins\\custom_reload_speed_motion_marks.ltx")
end

function stop_all_processes(anim_table, obj)
	if not anim_table or not obj then return end
	anm_name = anim_table.anm_name
	if not anm_name:startswith("anm_hide") then return end
	printdbg("stopping all processes")
	RemoveTimeEvent("ver_reload_sound", "set_ammo_elapsed")
    RemoveTimeEvent("ver_reload_sound", "set_ammo_elapsed2")
	RemoveTimeEvent("i hate my life ver", "cool_down_timer")
	level.remove_cam_effector(12394)
	local sec = obj:section()
	common.stop_all_sound_object(sec)
end
	
