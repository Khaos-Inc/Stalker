function ver_reload_now(wpn_state, mark_name)
	printdbg("wpn_state is %s", wpn_state)
	if wpn_state ~= 7 then return end
	local wpn1 = db.actor:active_item()
	local wpn_id1 = wpn1:id()
	printdbg("wpn_id1 is %s", wpn_id1)
	if not wpn1 then return end
	if not wpn1:is_weapon() then return end
	if temp_num then
		CreateTimeEvent("ver_reload_now", "reset_ammo_now", 0, (function(temp_num, wpn_id1)
			printdbg("wpn_id1 is %s", wpn_id1)
			printdbg("temp_num is %s", temp_num)
			wpn1 = get_object_by_id(wpn_id1)
			if not wpn1 then return true end
			printdbg("ver_reload_now: tried to reset ammo to %s!", temp_num)
			wpn1:cast_Weapon():SetAmmoElapsed(temp_num)
			return true
		end), temp_num, wpn_id1)
	end
end
		

-- ADD YOUR FUNCTORS FOR SOUND DISABLING USING THIS

local sound_disabler_functors = {}

function add_sound_disabler_functor(functor, priority)
	table.insert(sound_disabler_functors, {functor = functor, priority = priority})
	
	table.sort(sound_disabler_functors, function(a,b) return a.priority < b.priority end)
end

function remove_sound(alias, parent, result)
	printdbg("alias is %s, parent is %s, result is %s", alias, parent, result)
	local stop = false
	
	for i, func_table in ipairs(sound_disabler_functors) do
		stop = func_table.functor()
		if stop then break end
	end
	printdbg("stop is %s", stop)
	if not stop then return end
	
	wpn = db.actor:active_item()
	if not wpn then return end
	printdbg("sound alias is %s", alias)
	if not (alias:startswith("sndReload")) and not (alias == "sndAddCartridge") then 
		printdbg("alias does not coincide with recognised sounds")
		return 
	end
	if (string.find(alias, "Misfire")) then
		return
	end

	printdbg("alias coincides with recognised sounds")
	if wpn:is_weapon() and wpn:cast_Weapon():IsZoomed() then return end

	result.volume_mult = 0
	printdbg("result.volume_multiplier is %s", result.volume_mult)
	
	local wpn_sec = wpn:section()
	if not wpn_sec then 
		return result
	end
	common.stop_all_sound_object(wpn_sec)
	return result
end

function reduce_ammo(section,num)
	local function f(_,itm)
		if (itm and (itm:section() == section)) then
			if (num <= 0) then
				return
			end
			if (itm:ammo_get_count() > num) then
				itm:ammo_set_count(itm:ammo_get_count() - num)
				num = 0
				return
			end
			num = num - itm:ammo_get_count()
			alife_release(itm)
		end
	end
	db.actor:iterate_inventory(f)
end

-- base stupid speed increase
add_reload_speed_increase((function(anim_table, obj)
	if not obj then return false end
	local cam_anim_bool_
	if mcm_base_speed == 1 then return false end
	if mcm_base_speed > 1.1 or mcm_base_speed < 0.9 then
		cam_anim_bool_ = false
	else
		cam_anim_bool_ = true
	end
	return mcm_base_speed, cam_anim_bool_
	

end), 20)


-- base stupid reload sound disabler
add_sound_disabler_functor((function()
	if mcm_base_speed > 1 or mcm_base_speed < 1 then
		return true
	else
		return false
	end
end), 20)


