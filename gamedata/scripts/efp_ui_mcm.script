-- Edited by Sota - get defaults from ui_inventory.script
local player_faction_color_defs			= color_to_table( ui_inventory.player_faction_color )
local player_faction_text_color_defs	= color_to_table( ui_inventory.player_faction_text_color )

function get_faction_color_template(faction)
	local template = {
		id= faction, sh= true, gr= {
			{ id= "title"					, type= "slide", link= "ui_options_slider_warfare", text= "ui_mcm_menu_" .. mcm_id .. "_title", size= {512,50}, spacing= 20 },
			{ id= "desc_faction_color"		, type= "desc", text= "ui_mcm_desc_faction_banner_color"},
			{ id= "color_red"				, hint= mcm_id .. "_red"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_color_defs[faction].r },
			{ id= "color_green"				, hint= mcm_id .. "_green"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_color_defs[faction].g },
			{ id= "color_blue"				, hint= mcm_id .. "_blue"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_color_defs[faction].b },
			{ id= "color_alpha"				, hint= mcm_id .. "_alpha"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_color_defs[faction].a },
			{ id= "divider"					, type= "line" },
			{ id= "desc_faction_text_color"	, type= "desc", text= "ui_mcm_desc_faction_text_color" },
			{ id= "color_red_text"			, hint= mcm_id .. "_red"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_text_color_defs[faction].r },
			{ id= "color_green_text"		, hint= mcm_id .. "_green"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_text_color_defs[faction].g },
			{ id= "color_blue_text"			, hint= mcm_id .. "_blue"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_text_color_defs[faction].b },
			{ id= "color_alpha_text"		, hint= mcm_id .. "_alpha"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= faction_text_color_defs[faction].a },
		}
	}
	return template
end

function get_stats_color_template(stat)
	local template = {
		{ id= "desc" .. stat, type= "desc", text= "ui_mcm_desc_stat_" .. stat },
		{ id= "color_red"	.. stat, hint= mcm_id .. "_red"		, type= "track", val= 2, min= 0, max= 255, step= 1, def= stat_color_defs[stat].r },
		{ id= "color_green"	.. stat, hint= mcm_id .. "_green"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= stat_color_defs[stat].g },
		{ id= "color_blue"	.. stat, hint= mcm_id .. "_blue"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= stat_color_defs[stat].b },
		{ id= "color_alpha"	.. stat, hint= mcm_id .. "_alpha"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= stat_color_defs[stat].a },
		{ id= "divider", type= "line" },
	}
	return template
end

module_settings = {}

function add_module_settings(t)
	module_settings[#module_settings + 1] = t
end

function get_module_settings(path)
	return ui_mcm.get( mcm_id .. "/modules_settings/" .. path )
end

function get_slot_cell_template(slot)
	local template = {
		{ id= "desc" .. slot_color_defs[slot].st, type= "desc", text= "ui_mcm_desc_cell_" .. slot_color_defs[slot].st },
		{ id= "color_red"	.. slot, hint= mcm_id .. "_red"		, type= "track", val= 2, min= 0, max= 255, step= 1, def= slot_color_defs[slot].r },
		{ id= "color_green"	.. slot, hint= mcm_id .. "_green"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= slot_color_defs[slot].g },
		{ id= "color_blue"	.. slot, hint= mcm_id .. "_blue"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= slot_color_defs[slot].b },
		{ id= "color_alpha"	.. slot, hint= mcm_id .. "_alpha"	, type= "track", val= 2, min= 0, max= 255, step= 1, def= slot_color_defs[slot].a },
		{ id= "divider", type= "line" },
	}
	return template
end

-- Edited by Sota - add new MCM features for UI Rework
function on_mcm_load()
	local op = { id= mcm_id, gr= {{ id= "faction_settings", gr= {} }} }
	
	op.gr[1] = { id= "main_settings", sh= true, gr= {} }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "title", type= "slide", link= "ui_options_slider_warfare", text= "ui_mcm_menu_" .. mcm_id.. "_title", size= {512,50}, spacing= 20 }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_ranks"			, hint= mcm_id .. "_use_alt_ranks"			, type= "list"		, val= 2, content= { { 1, "ranks" }		, { 2, "ranks_mui" }	, { 3, "ranks_svui" }	, { 4, "ranks_svui_alt" } }	, def= color_setting_defs["use_alt_ranks"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_factions"		, hint= mcm_id .. "_use_alt_factions"		, type= "list"		, val= 2, content= { { 1, "factions" }	, { 2, "factions_alt" }	, { 3, "factions_alt2" } }							, def= color_setting_defs["use_alt_factions"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_inv"			, hint= mcm_id .. "_use_alt_inv"			, type= "list"		, val= 2, content= { { 1, "inv" }		, { 2, "inv_alt" }		, { 3, "inv_alt_bg" } }								, def= color_setting_defs["use_alt_inv"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_grid"			, hint= mcm_id .. "_use_alt_grid"			, type= "list"		, val= 2, content= { { 1, "no_grid" }	, { 2, "grid" }			, { 3, "grid_alt" } }								, def= color_setting_defs["use_alt_grid"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_blockers"		, hint= mcm_id .. "_use_alt_blockers"		, type= "list"		, val= 2, content= { { 1, "blck_lock" }	, { 2, "blck_cross" }	, { 3, "blck_dash" } }								, def= color_setting_defs["use_alt_blockers"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_upgr"			, hint= mcm_id .. "_use_alt_upgr"			, type= "list"		, val= 2, content= { { 1, "upgr" }		, { 2, "upgr_gear" }	, { 3, "upgr_arrow" }	, { 4, "upgr_wrench" } }	, def= color_setting_defs["use_alt_upgr"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_equ_bars"		, hint= mcm_id .. "_use_alt_equ_bars"		, type= "list"		, val= 2, content= { { 1, "bars" }		, { 2, "bars_flat" }	, { 3, "bars_fade" } }								, def= color_setting_defs["use_alt_equ_bars"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_alt_inv_bars"		, hint= mcm_id .. "_use_alt_inv_bars"		, type= "list"		, val= 2, content= { { 1, "bars" }		, { 2, "bars_flat" }	, { 3, "bars_fade" } }								, def= color_setting_defs["use_alt_inv_bars"] }
	
	if (not is_gamma) then
		op.gr[1].gr[#op.gr[1].gr + 1]	= { id= "use_alt_stats_bars"	, hint= mcm_id .. "_use_alt_stats_bars"		, type= "list"		, val= 2, content= { { 1, "bars" }		, { 2, "bars_flat" }	, { 3, "bars_fade" } }								, def= color_setting_defs["use_alt_stats_bars"] }
	end
	
--	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "divider", type= "line" }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_inv_labels"		, hint= mcm_id .. "_use_inv_labels"			, type= "check"		, val= 1																											, def= color_setting_defs["use_inv_labels"] }
	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "use_small_icons"		, hint= mcm_id .. "_use_small_icons"		, type= "check"		, val= 1																											, def= color_setting_defs["use_small_icons"] }
