	["thirst"]			= { i= 3	},
	["sleep"]			= { i= 4	},
	["radia"]			= { i= 5	},
	["acid"]			= { i= 6	},
	["shock"]			= { i= 7	},
	["fire"]			= { i= 8	},
	["psi"]				= { i= 9	},
	["wound"]			= { i= 10	},
	["strike"]			= { i= 11	},
	["explosion"]		= { i= 12	},
	["head_fire_wound"]	= { i= 13	},
	["head_br_class"]	= { i= 14	},
	["fire_wound"]		= { i= 15	},
	["br_class"]		= { i= 16	},
}
for name,clr in pairs(stat_colors) do
	local t_clr = color_to_table(clr)
	stat_color_defs[name] = {
		a = t_clr.a,
		r = t_clr.r,
		g = t_clr.g,
