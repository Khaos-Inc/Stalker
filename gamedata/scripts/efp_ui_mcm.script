-- Added by Sota
-- check if it's gamma
local is_gamma = ui_inventory.is_gamma
-- links to tabels
local color_settings		= ui_inventory.color_settings
local faction_colors		= ui_inventory.faction_colors
local faction_text_colors	= ui_inventory.faction_text_colors
local stat_colors			= ui_inventory.stat_colors
local slot_colors			= ui_inventory.slot_colors

mcm_id = "efp_ui"

-- Added by Sota - convert color from GetARGB() to table {a= _, r= _, g= _, b= _}
local function color_to_table(clr)
	if (not clr) then
		return {a= 255, r= 255, g= 255, b= 255}
	end
	return {
		a = bit.band(bit.rshift(clr, 24), 255),
		r = bit.band(bit.rshift(clr, 16), 255),
		g = bit.band(bit.rshift(clr, 8), 255),
		b = bit.band(clr, 255)
	} 
end

-- Added by Sota - get defaults from ui_inventory.script
local color_setting_defs = {}
for name,val in pairs(color_settings) do
	color_setting_defs[name] = val
end

-- Edited by Sota - get defaults from ui_inventory.script and fix for incorrect order of adding to settings
local faction_color_defs = {
	["stalker"]			= { i= 1	},
	["bandit"]			= { i= 2	},
	["csky"]			= { i= 3	},
	["dolg"]			= { i= 4	},
	["freedom"]			= { i= 5	},
	["killer"]			= { i= 6	},
	["army"]			= { i= 7	},
	["ecolog"]			= { i= 8	},
	["monolith"]		= { i= 9	},
	["renegade"]		= { i= 10	},
	["greh"]			= { i= 11	},
	["isg"]				= { i= 12	},
}
for name,clr in pairs(faction_colors) do
	local t_clr = color_to_table(clr)
	faction_color_defs[name] = {
		a = t_clr.a,
		r = t_clr.r,
		g = t_clr.g,
		b = t_clr.b,
		i = faction_color_defs[name].i
	}
end

-- Edited by Sota - get defaults from ui_inventory.script
local faction_text_color_defs = {}
for name,clr in pairs(faction_text_colors) do
	faction_text_color_defs[name] = color_to_table(clr)
end

-- Edited by Sota - get defaults from ui_inventory.script and fix for incorrect order of adding to settings
