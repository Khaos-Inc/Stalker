	op.gr[1].gr[#op.gr[1].gr + 1]		= { id= "swap_wpn_slots"		, hint= mcm_id .. "_swap_wpn_slots"			, type= "check"		, val= 1																											, def= color_setting_defs["swap_wpn_slots"] }
