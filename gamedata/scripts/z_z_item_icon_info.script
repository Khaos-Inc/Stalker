local old_z_item_icon_info_parts_sort = z_item_icon_info.parts_sort
function z_item_icon_info.parts_sort(t, a, b)
	-- Edited by Sota - add check for existence of this script with this function
--	return zzzz_arti_jamming_repairs.sort_parts(t, a, b)
	if zzzz_arti_jamming_repairs and zzzz_arti_jamming_repairs.sort_parts then
		return zzzz_arti_jamming_repairs.sort_parts(t, a, b)
	else
		return old_z_item_icon_info_parts_sort(t, a, b)
	end
end
