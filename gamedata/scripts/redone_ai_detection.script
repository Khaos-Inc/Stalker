end]]--

----------------------------------------------------------------------------
-- NPC ON UPDATE
----------------------------------------------------------------------------
local UPDATE_INTERVAL = 500
local npc_next_update = {}
local npc_next_detection_time = {}

local function npc_on_update(npc)
        if not redone_ai_detection then return end
        if not is_valid_detection_npc(npc) then return end
        if not db.actor then return end

        local id = npc:id()
        local current_time = time_global()

        if not npc_next_update[id] then
                npc_next_update[id] = current_time
                npc_next_detection_time[id] = 0
        end

        if current_time < npc_next_update[id] then return end
        npc_next_update[id] = current_time + UPDATE_INTERVAL

        local actor_pos = db.actor:position()
        local npc_pos = npc:position()
        local dist = npc_pos:distance_to(actor_pos)

        if dist > 50 then return end

        local hrs = level.get_time_hours() + level.get_time_minutes() / 60
        local is_night = (hrs >= 21 or hrs < 5)
        local time_factor = is_night and 0.8 or 1.0

        local actor_has_torch = actor_has_light_source()

        local speed = get_actor_speed()
        local weight_ratio = get_actor_weight_ratio()
        local weight_mult = 1.0 + weight_ratio * 0.4

        --DEBUG: actor weight
        --[[if weight_ratio > 0.8 then
                utils_data.debug_write("[DETECTION] Actor is heavily loaded: " .. tostring(weight_ratio))
        else
                utils_data.debug_write("[DETECTION] Actor is light: " .. tostring(weight_ratio))
        end]]--

        local rank_mult, base_dist_vals = get_npc_detection_values(npc)
        local weather_strength, is_foggy, is_raining, is_storm = get_weather_mult("detection_weather_enabled", "detection_weather_mult")

        local dist_sneak  = base_dist_vals.sneak  * rank_mult * time_factor * weather_strength * weight_mult
        local dist_walk   = base_dist_vals.walk   * rank_mult * time_factor * weather_strength * weight_mult
        local dist_run    = base_dist_vals.run    * rank_mult * time_factor * weather_strength * weight_mult
        local dist_sprint = base_dist_vals.sprint * rank_mult * time_factor * weather_strength * weight_mult

        local dist_torch_day   = base_dist_vals.torch_day * rank_mult
        local dist_torch_night = base_dist_vals.torch_night * rank_mult
        local dist_weather     = base_dist_vals.run * rank_mult * time_factor * weather_strength

        -- Detection Checks
        local tg = current_time
        if tg < (npc_next_detection_time[id] or 0) then return end
        local cooldown = 1200
        if speed > 0.24 then
                cooldown = 800
        elseif speed > 0.36 then
                cooldown = 1000
        else
                cooldown = 1500
        end

        npc_next_detection_time[id] = tg + cooldown

        -- SNEAK
        if speed > 0.0 and speed <= 0.29 and dist < dist_sneak then
                --npc:make_object_visible_somewhen(db.actor)
                if DEBUG_DETECTION_ON then utils_data.debug_write(string.format("[DETECTION] ACTOR SNEAKING (%.2f m/s)", speed)) end
        -- SNEAK\WALK
        elseif speed > 0.30 and speed <= 0.34 and dist < dist_walk then
                --npc:make_object_visible_somewhen(db.actor)
                if DEBUG_DETECTION_ON then utils_data.debug_write(string.format("[DETECTION] ACTOR SNEAK_WALKING (%.2f m/s)", speed)) end
        -- RUN
        elseif speed > 0.34 and speed <= 0.74 and dist < dist_run then
                npc:make_object_visible_somewhen(db.actor)
                if DEBUG_DETECTION_ON then utils_data.debug_write(string.format("[DETECTION] ACTOR RUNNING (%.2f m/s)", speed)) end
        -- SPRINT
        elseif speed > 0.74 and dist < dist_sprint then
                npc:make_object_visible_somewhen(db.actor)
                if DEBUG_DETECTION_ON then utils_data.debug_write(string.format("[DETECTION] ACTOR SPRINT (%.2f m/s)", speed)) end
        end

        -- WEATHER
        if is_storm and dist < dist_weather and speed > 0.74 then
		if DEBUG_DETECTION_ON then utils_data.debug_write(string.format(
			"[DETECTION][WEATHER] STORM detected dist=%.2f speed=%.2f",dist, speed))
		end
                npc:make_object_visible_somewhen(db.actor)
        elseif (is_foggy or is_raining) and dist < dist_weather and speed > 0.34 then
                npc:make_object_visible_somewhen(db.actor)
		if DEBUG_DETECTION_ON then utils_data.debug_write(string.format(
			"[DETECTION][WEATHER] RAIN/FOG detected dist=%.2f speed=%.2f",dist, speed))
		end
        end

        -- DEVICE
        if actor_has_torch and not is_night and dist < dist_torch_day then
                npc:make_object_visible_somewhen(db.actor)
		if DEBUG_DETECTION_ON then utils_data.debug_write(string.format(
			"[DETECTION][DEVICE] TORCH DAY detected dist=%.2f",dist))
		end

        elseif actor_has_torch and is_night and dist < dist_torch_night then
                npc:make_object_visible_somewhen(db.actor)
		if DEBUG_DETECTION_ON then utils_data.debug_write(string.format(
			"[DETECTION][DEVICE] TORCH NIGHT detected dist=%.2f",dist))
		end
        end

        -- COMBAT (disabled) TODO: Get it work x)
        --[[if speed > 0.5 then
                local enemy = db.actor or npc:best_enemy()
                if enemy and enemy:alive() then
                        local dist = npc:position():distance_to(enemy:position())

                            utils_data.debug_write(string.format("[DETECTION] COMBAT detection (%.2f m/s)", speed))
                        end
                end
        end]]--
end

-----------------------------------------------------------------------------
-- ON OPTION CHANGE
-----------------------------------------------------------------------------
function on_option_change()
        DEBUG_DETECTION_ON        = stealth_mcm.get_config("debug_detection")
        redone_ai_detection       = stealth_mcm.get_config("redone_ai_detection")
        detection_rank_enabled    = stealth_mcm.get_config("detection_rank_enabled")
        detection_rank_mult       = stealth_mcm.get_config("detection_rank_mult")
        detection_weather_enabled = stealth_mcm.get_config("detection_weather_enabled")
        detection_weather_mult    = stealth_mcm.get_config("detection_weather_mult")
        redone_ai_sound           = stealth_mcm.get_config("redone_ai_sound")
        sound_WPN_mult            = stealth_mcm.get_config("sound_WPN_mult")
        sound_MST_mult            = stealth_mcm.get_config("sound_MST_mult")
        sound_ITM_mult            = stealth_mcm.get_config("sound_ITM_mult")
        sound_DNG_mult            = stealth_mcm.get_config("sound_DNG_mult")
        sound_limit               = stealth_mcm.get_config("sound_limit")
        sound_rank_enabled        = stealth_mcm.get_config("sound_rank_enabled")
        sound_rank_mult           = stealth_mcm.get_config("sound_rank_mult")
        sound_weather_enabled     = stealth_mcm.get_config("sound_weather_enabled")
        sound_weather_mult        = stealth_mcm.get_config("sound_weather_mult")
end

-----------------------------------------------------------------------------
-- ON GAME START
-----------------------------------------------------------------------------
function on_game_start()
        on_option_change()

        RegisterScriptCallback("npc_on_update", npc_on_update)
        RegisterScriptCallback("on_option_change", on_option_change)
end
