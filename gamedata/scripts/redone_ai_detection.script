local sound_MST_mult = stealth_mcm.get_config("sound_MST_mult")
local sound_ITM_mult = stealth_mcm.get_config("sound_ITM_mult")
local sound_DNG_mult = stealth_mcm.get_config("sound_DNG_mult")
--------------------------------------
local function in_combat_sound_enabled() return stealth_mcm.get_config("sound_combat_enabled") == 1 end
--------------------------------------
local sound_limit           = stealth_mcm.get_config("sound_limit")
local sound_rank_enabled    = stealth_mcm.get_config("sound_rank_enabled")
local sound_rank_mult       = stealth_mcm.get_config("sound_rank_mult")
local sound_weather_enabled = stealth_mcm.get_config("sound_weather_enabled")
local sound_weather_mult    = stealth_mcm.get_config("sound_weather_mult")

DEBUG = false
