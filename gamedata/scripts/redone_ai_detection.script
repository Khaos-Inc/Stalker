        ["novice"]       = {sneak = 8,  walk = 10, run = 12, sprint = 18, torch_day = 24, torch_night = 42},
        ["trainee"]      = {sneak = 8,  walk = 10, run = 12, sprint = 18, torch_day = 24, torch_night = 42},
        ["experienced"]  = {sneak = 10, walk = 12, run = 14, sprint = 20, torch_day = 26, torch_night = 44},
        ["professional"] = {sneak = 10, walk = 12, run = 14, sprint = 20, torch_day = 26, torch_night = 44},
        ["expert"]       = {sneak = 12, walk = 14, run = 16, sprint = 22, torch_day = 28, torch_night = 46},
        ["veteran"]      = {sneak = 12, walk = 14, run = 16, sprint = 22, torch_day = 28, torch_night = 46},
        ["master"]       = {sneak = 14, walk = 16, run = 18, sprint = 24, torch_day = 30, torch_night = 48},
