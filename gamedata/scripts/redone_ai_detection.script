local detection_rank_enabled     = stealth_mcm.get_config("detection_rank_enabled")
local detection_rank_mult        = stealth_mcm.get_config("detection_rank_mult")
local detection_weather_enabled  = stealth_mcm.get_config("detection_weather_enabled")
local detection_weather_mult     = stealth_mcm.get_config("detection_weather_mult")
--------------------------------------
local redone_ai_sound = stealth_mcm.get_config("redone_ai_sound")
