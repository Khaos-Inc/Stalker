        ["novice"]  = 0.70, ["trainee"] = 0.80, ["experienced"] = 0.90, ["professional"] = 1.00,
        ["expert"]  = 1.10, ["veteran"] = 1.20, ["master"]      = 1.35, ["legend"]       = 1.50,
        ["special"] = 1.00
}

local npc_sound_rank = {
        ["novice"]  = 0.95, ["trainee"] = 1.05, ["experienced"] = 1.15, ["professional"] = 1.25,
        ["expert"]  = 1.35, ["veteran"] = 1.45, ["master"]      = 1.55, ["legend"]       = 1.65,
        ["special"] = 1.15
}

local sound_type_to_vkey = {
        ["WPN_shoot"]  = "wpn_shoot",  ["WPN_reload"] = "wpn_reload", ["WPN_empty"] = "wpn_empty",
        ["WPN_hit"]    = "wpn_hit",    ["WPN_show"]   = "wpn_show",   ["WPN_hide"]  = "wpn_hide",
        ["MST_attack"] = "mst_attack", ["MST_damage"] = "mst_damage", ["MST_step"]  = "mst_step",
        ["MST_talk"]   = "mst_talk",   ["MST_die"]    = "mst_die",    ["MST_eat"]   = "mst_eat",
        ["ITM_pckup"]  = "itm_pckup",  ["ITM_drop"]   = "itm_drop",   ["ITM_hide"]  = "itm_hide",
        ["ITM_take"]   = "itm_take",   ["ITM_use"]    = "itm_use"
}

local npc_sound_type = {
        ["WPN_shoot"]  = 1.8, ["WPN_reload"] = 0.6, ["WPN_empty"] = 0.6,
        ["WPN_hit"]    = 1.2, ["WPN_show"]   = 0.6, ["WPN_hide"]  = 0.6,
        ["MST_attack"] = 1.0, ["MST_damage"] = 0.9, ["MST_step"]  = 1.0,
        ["MST_talk"]   = 0.8, ["MST_die"]    = 0.8, ["MST_eat"]   = 0.5,
        ["ITM_pckup"]  = 0.5, ["ITM_drop"]   = 0.4, ["ITM_hide"]  = 0.4,
        ["ITM_take"]   = 0.5, ["ITM_use"]    = 0.5, ["Special"]   = 1.0
}

local npc_weather_factors = {
        ["clear"] = 1.0, ["rain"] = 0.8, ["storm"] = 0.6, ["foggy"] = 0.9
}

------------------------------------------------------------------------------
-- RANK UTILS
------------------------------------------------------------------------------
function get_npc_rank_key(npc)
        if not npc or not npc:alive() then return "novice" end
        if not IsStalker(npc) then return "special" end

        local comm = npc:character_community()
        if not comm then return "special" end
        if comm == "zombied" then return "special" end

        local rank_name = ranks and ranks.get_obj_rank_name and ranks.get_obj_rank_name(npc)
        if not rank_name or rank_name == "" then return "special" end

        return rank_name
end

------------------------------------------------------------------------------
-- WEATHER UTILS
------------------------------------------------------------------------------
function get_weather_factors(enabled_key)
        local enabled = false

        if enabled_key == "detection_weather_enabled" then
                enabled = detection_weather_enabled

        elseif enabled_key == "sound_weather_enabled" then
                enabled = sound_weather_enabled
        end

        if not enabled then
                return npc_weather_factors.clear, false, false, false
        end

        local weather_manager =
                level_weathers
                and level_weathers.get_weather_manager
                and level_weathers.get_weather_manager()
                or nil

        local curr_weather = weather_manager and weather_manager:get_curr_weather_preset() or ""
        local rain_factor = level.rain_factor() or 0

        local is_foggy = false
        local is_raining = false
        local is_storm = false

        local weather_factor = npc_weather_factors.clear
        local w = string.lower(tostring(curr_weather))

        if string.find(w, "foggy", 1, true) then
                is_foggy = true
                weather_factor = npc_weather_factors.foggy

        elseif string.find(w, "storm", 1, true) then
                is_storm = true
                is_raining = true
                weather_factor = npc_weather_factors.storm

        elseif string.find(w, "rain", 1, true) then
                is_raining = true
                weather_factor = npc_weather_factors.rain

        else
                if rain_factor >= 0.75 then
                        is_storm = true
                        is_raining = true
                        weather_factor = npc_weather_factors.storm
                elseif rain_factor >= 0.1 then
                        is_raining = true
                        weather_factor = npc_weather_factors.rain
                end
        end

        if DEBUG then
                utils_data.debug_write(string.format("[WTH] %.2f f:%s r:%s s:%s",
                        weather_factor,
                        tostring(is_foggy),
                        tostring(is_raining),
                        tostring(is_storm)
                ))
        end

        return weather_factor, is_foggy, is_raining, is_storm
end

function get_weather_mult(enabled_key, mcm_key)
        local weather_factor, is_foggy, is_raining, is_storm = get_weather_factors(enabled_key)

        local mcm_mult = 1.0

        if mcm_key == "detection_weather_mult" then
                mcm_mult = detection_weather_mult or 1.0

        elseif mcm_key == "sound_weather_mult" then
                mcm_mult = sound_weather_mult or 1.0
        end

        local final_mult = weather_factor * mcm_mult

        if DEBUG then utils_data.debug_write(string.format("[WTHM] %.2f", final_mult)) end
        return final_mult, is_foggy, is_raining, is_storm
end

------------------------------------------------------------------------------
-- DETECTION UTILS
------------------------------------------------------------------------------
function get_npc_detection_values(npc)
        local key = get_npc_rank_key(npc)
        local base_dist_vals = npc_base_dist[key] or npc_base_dist["special"]

        local rank_enabled = detection_rank_enabled
        local mcm_mult = detection_rank_mult

        if not rank_enabled then
                local neutral_mult = 0.55
                return neutral_mult, base_dist_vals
        end

        local rank_mult = npc_detection_rank[key] or 1.0
        local final_rank_mult = rank_mult * mcm_mult

        local scaled_base_dist_vals = {}
        for k, v in pairs(base_dist_vals) do
                scaled_base_dist_vals[k] = (type(v) == "number") and (v * mcm_mult) or v
        end

        if DEBUG then utils_data.debug_write(string.format("[DET] %.2f", final_rank_mult)) end
        return final_rank_mult, scaled_base_dist_vals
end

local function is_valid_detection_npc(npc)
        if not npc or not npc:alive() then return false end
        if not IsStalker(npc) or IsWounded(npc) then return false end
        if character_community(npc) == "zombied" then return false end

        return true
end

------------------------------------------------------------------------------
-- SOUND UTILS
------------------------------------------------------------------------------
function get_npc_sound_values(npc)
        if not npc or not npc:alive() then return 1.0 end
        if not IsStalker(npc) then return 1.0 end
        if not sound_rank_enabled then return 1.0 end

        local key = get_npc_rank_key(npc)
        local base = npc_sound_rank[key] or 1.0
        local mcm = sound_rank_mult or 1.0

        return base * mcm
end

function get_type_multiplier(s_type)
        if not redone_ai_sound then return 1.0 end
        if not s_type then return 1.0 end

        local type_mult =
                npc_sound_type[s_type]
                or (sound_type_to_vkey[s_type] and npc_sound_type[sound_type_to_vkey[s_type]])
                or npc_sound_type["Special"]
                or 1.0

        return type_mult
end

function get_noise_limit()
        if not in_combat_sound_enabled() then return 1.0 end
        return sound_limit or 1.0
end

function get_sound_noises(npc, weather_factor, s_type)
        if not in_combat_sound_enabled() then return 0 end
        if not npc or not npc:alive() then return 0 end
        if not s_type then return 0 end

        local base_noise_value = 45

        local rank_mult = get_npc_sound_values(npc) or 1.0
        local type_mult = get_type_multiplier(s_type) or 1.0
        local weather_mult = get_weather_mult("sound_weather_enabled", "sound_weather_mult") or 1.0

        local speed = get_actor_speed() or 0
        local speed_factor = 1 + speed * 0.25

        local weight_ratio = get_actor_weight_ratio() or 0
        local weight_factor = 1 + weight_ratio * 0.15

        local base_noise =
                base_noise_value
                * rank_mult
                * type_mult
                * speed_factor
                * weight_factor
                * weather_mult

        local mcm = get_noise_limit()
        local noise_radius = base_noise * mcm

        if DEBUG then utils_data.debug_write(string.format("[SND] %.1f", base_noise)) end
        return noise_radius
end

------------------------------------------------------------------------------
-- ACTOR UTILS
------------------------------------------------------------------------------
function get_actor_speed()
        if not db.actor then return 0 end

        local pos = db.actor:position()
        local time = time_global()
        if not last_actor_pos or not last_update_time then
                last_actor_pos = pos
                last_update_time = time
                return 0
        end

        local dist = pos:distance_to(last_actor_pos)
        local delta = (time - last_update_time) / 200

        last_actor_pos = pos
        last_update_time = time

        if delta <= 0 then return 0 end

        local speed = dist / delta
        if speed < 0.1 then return 0 end

        if DEBUG then utils_data.debug_write(string.format("[SPD] %.2f", speed)) end
        return speed
end

function get_actor_weight_ratio()
        if not db.actor then return 0 end

        local inv_weight = db.actor:get_total_weight()
        local max_walk_weight = db.actor:get_actor_max_walk_weight()
        local free_weight = 0.35 * max_walk_weight

        local ratio = (inv_weight > free_weight)
            and ((inv_weight - free_weight) / (max_walk_weight - free_weight)) or 0
        if inv_weight > max_walk_weight then
                ratio = 1.0 + ((inv_weight - max_walk_weight) / 5.0) * 0.1
        else
                ratio = math.min(math.max(ratio, 0), 1)
        end

        if DEBUG then utils_data.debug_write(string.format("[WEIGHT] %.2f", ratio)) end
        return ratio
end

local function actor_has_light_source()
        if not db.actor then return false end
        local torch = db.actor:item_in_slot(10)
        local flash = db.actor:item_in_slot(9)

        local actor_torch_on = torch and torch:torch_enabled()
        local actor_flash_on = flash
        and flash:section() == "device_flashlight"
        and db.actor:active_detector()

        return actor_torch_on or actor_flash_on
end

