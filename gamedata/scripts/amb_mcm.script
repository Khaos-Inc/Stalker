function get_config(key)
    if ui_mcm then return ui_mcm.get("s2_ambience/" .. key) end
    return defaults[key]
end

function is_enabled() return get_config("enabled") end
function get_master_volume() return get_config("master_volume") or 1.0 end
function get_frequency_multiplier() return get_config("frequency_multiplier") or 1.0 end
function get_rain_frequency_multiplier() return get_config("rain_frequency_multiplier") or 1.0 end
function is_dynamic_rain_frequency() return get_config("dynamic_rain_frequency") end
function get_tick_interval() return get_config("tick_interval") or 100 end
function is_debug_mode() return get_config("debug_mode") end

function is_context_enabled(context)
    local key = "enable_" .. context .. "_sounds"
    if context == "static_emitters" then key = "enable_static_emitters" end
    local result = get_config(key)
    if result == nil then return true end
    return result
end

function is_category_enabled(category)
    if not category then return true end
    local result = get_config("cat_" .. category)
    if result == nil then return true end
    return result
end

function get_category_volume(category)
    if not category then return 1.0 end
    return get_config("vol_" .. category) or 1.0
end

function get_sound_category(sound_name) return sound_categories[sound_name] end

function is_sound_enabled(sound_name)
    if not is_enabled() then return false end
    local category = get_sound_category(sound_name)
    return not category or is_category_enabled(category)
end

function get_sound_volume(sound_name, base_volume)
    return (base_volume or 1.0) * get_master_volume() * get_category_volume(get_sound_category(sound_name))
end

function get_rain_loop_volume()
    return (get_config("vol_rain_loop") or 1.0) * get_master_volume()
end

function get_rain_loop_indoor_volume()
    return (get_config("vol_rain_loop_indoor") or 1.0) * get_master_volume()
end

function get_sound_interval(base_interval)
    local f = get_frequency_multiplier()
    return base_interval / (f > 0 and f or 0.1)
end

function get_rain_sound_interval(base_interval, rain_density)
    local f = get_rain_frequency_multiplier()
    if is_dynamic_rain_frequency() and rain_density then
        -- more aggressive curve: ramps up faster at medium-high density
        local density_factor = math.max(0.3, math.min(3.5, 0.4 + rain_density * 3.0))
        f = f * density_factor
    end
    return base_interval / (f > 0 and f or 0.1)
end

