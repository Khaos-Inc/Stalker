--[[----------------------------------------------------------------------------------------------------
	Overrides
------------------------------------------------------------------------------------------------------]]
local function ai_wpn_enabled()
        return stealth_mcm.get_config("redone_ai_wpn")
end
-------------------------------
if ai_wpn_enabled() then
-------------------------------
local function get_weapon_type(weapon)
        if not weapon then return "unknown" end
        local kind = ini_sys:r_string_ex(weapon:section(), "kind") or "unknown"

        if kind == "w_pistol"   	then return "pistol"
        elseif kind == "w_smg"      then return "smg"
        elseif kind == "w_rifle"    then return "rifle"
        elseif kind == "w_shotgun"  then return "shotgun"
        elseif kind == "w_sniper"   then return "sniper"
        elseif kind == "w_launcher" then return "launcher"
        else return "generic" end
end

function _g.update_best_weapon(npc, cur_wpn)
        local st = db.storage[npc:id()]
        if not st then return cur_wpn end

        local be = redone_ai_combat.get_combat_enemy(npc)
        local is_actor_enemy = db.actor and be and be:id() == db.actor:id()
        if is_actor_enemy then
                local tg = time_global()
                local see_enemy = be and npc:see(be)
                local dist2 = be and be:position():distance_to_sqr(npc:position()) or 0

                if cur_wpn then
                        local cat = get_weapon_type(cur_wpn)
                        if cat ~= "pistol" and cat ~= "sniper" and cat ~= "launcher" then
                                local ammo = cur_wpn:get_ammo_in_magazine()
                                if ammo and ammo > 0 then
                                        return cur_wpn
                                end
                        end
                end

                st._choose_bw_timer = tg + 5000
                st._pistol_used = st._pistol_used or false

                local best_primary = {}
                local pistol_weapon = nil
                local shotgun_weapon = nil
                local has_main_gun = false

                local function itr(npc, wpn)
                if not IsWeapon(nil, wpn:clsid()) then return false end
                        local cat = get_weapon_type(wpn)
                        local cost = ini_sys:r_float_ex(wpn:section(), "cost") or 1

                        if cat == "pistol" then
                                pistol_weapon = wpn
                        elseif cat == "shotgun" then
                                shotgun_weapon = wpn
                                best_primary[wpn] = cost + 1300
                        elseif cat == "rifle" or cat == "sniper" then
                                has_main_gun = true
                                best_primary[wpn] = cost + 1200
                        elseif cat == "smg" then
                                has_main_gun = true
                                best_primary[wpn] = cost + 1100
                        elseif cat == "generic" then
                                has_main_gun = true
                                best_primary[wpn] = cost + (dist2 <= 500 and 1000 or 900)
                        else
                                best_primary[wpn] = cost + 800
                        end
                        return false
                end

                npc:iterate_inventory(itr, npc)

                local close_dist2 = 450
                local sniper_close_dist2 = 525

                if see_enemy then
                        local cur_cat = cur_wpn and get_weapon_type(cur_wpn)
                        if cur_cat == "sniper" and dist2 <= sniper_close_dist2 then
                                if shotgun_weapon then
                                        return shotgun_weapon
                                elseif pistol_weapon then
                                        return pistol_weapon
                                else
                                        for wpn,_ in spairs(best_primary,function(t,a,b) return t[a] > t[b] end) do
                                                if get_weapon_type(wpn) ~= "sniper" then
                                                        return wpn
                                                end
                                        end
                                end
                        end

                        if dist2 <= close_dist2 then
                                if shotgun_weapon then
                                        return shotgun_weapon
                                elseif not has_main_gun and pistol_weapon and not st._pistol_used then
                                        local ammo = pistol_weapon:get_ammo_in_magazine()
                                        if ammo and ammo > 0 then
                                                return pistol_weapon
                                        else
                                                st._pistol_used = true
                                        end
                                elseif dist2 <= 100 and pistol_weapon and not st._pistol_used then
                                        local ammo = pistol_weapon:get_ammo_in_magazine()
                                        if ammo and ammo > 0 then
                                                return pistol_weapon
                                        else
                                                st._pistol_used = true
                                        end
                                end
                        end
                end

                if cur_wpn and get_weapon_type(cur_wpn) == "pistol" and dist2 <= close_dist2 and not see_enemy then
                        for wpn,_ in spairs(best_primary,function(t,a,b) return t[a] > t[b] end) do
                                if get_weapon_type(wpn) ~= "sniper" and get_weapon_type(wpn) ~= "launcher" then
                                        return wpn
                                end
                        end
                end

                if dist2 > close_dist2 then
                        if not has_main_gun and pistol_weapon then
                                return pistol_weapon
                        end
                for wpn,_ in spairs(best_primary,function(t,a,b) return t[a] > t[b] end) do
                                return wpn
                        end
                end

                return cur_wpn
        else
                local be = npc:best_enemy()
                local dist2 = be and be:position():distance_to_sqr(npc:position()) or 0

                local prior = {}
                if be then
                        if IsMonster(nil, be:clsid()) then
                                if dist2 > 500 then
                                        prior = {"rifle", "generic", "shotgun", "smg", "sniper", "pistol", "launcher"}
                                else
                                        prior = {"shotgun", "rifle", "smg", "generic", "pistol", "sniper", "launcher"}
                                end
                        elseif dist2 > 1000 then
                                prior = {"sniper", "rifle", "generic", "smg", "shotgun", "pistol", "launcher"}
                        elseif dist2 > 200 then
                                prior = {"rifle", "shotgun", "generic", "smg", "pistol", "sniper", "launcher"}
                        else
                                prior = {"shotgun", "rifle", "smg", "generic", "pistol", "sniper", "launcher"}
                        end

                elseif axr_npc_vs_heli.is_under_npc_vs_heli(npc) then
                        prior = {"launcher", "sniper", "rifle", "generic", "smg", "pistol", "shotgun"}
                else
                        prior = {"rifle", "sniper", "generic", "smg", "pistol", "shotgun", "launcher"}
                end

                local found = {}
                local function itr(npc, wpn)
                if not IsWeapon(nil, wpn:clsid()) then return false end
                        local cat = get_weapon_type(wpn)
                        found[cat] = found[cat] or {}
                        table.insert(found[cat], wpn)
                        return false
                end

                npc:iterate_inventory(itr, npc)

                for _, cat in ipairs(prior) do
                        if found[cat] and found[cat][1] then
                                return found[cat][1]
                        end
                end

                local flags = {gun_id = nil}

                SendScriptCallback("npc_on_choose_weapon", npc, cur_wpn, flags)

                if flags.gun_id and tonumber(flags.gun_id) then
                        local se_gun = alife_object(tonumber(flags.gun_id))
                        if se_gun and IsWeapon(nil, se_gun:clsid()) and se_gun.parent_id == npc:id() then
                                local obj = level.object_by_id(tonumber(flags.gun_id))
                                if obj then
                                        return obj
                                end
                        end
                end

                return cur_wpn
        end
end

--ai_wpn_enabled()
-------------------------------
end
-------------------------------
