		["strike"]		= { min= 0 , max= 1																	, hint= "ui_inv_strike_protection"			, title= "ui_inv_strike_protection_title"			},
		["explosion"]	= { min= 0 , max= 1																	, hint= "ui_inv_explosion_protection"		, title= "ui_inv_explosion_protection_title"		},
		["power"]		= { min= 0 , max= (SYS_GetParam(2,"actor_condition","max_power_restore_speed"))		, hint= "ui_inv_power_restore"				, title= "ui_inv_power_restore_title"				},
	}
	
	-- Added by Sota - add HTS stats and hint variable to stats list (if HTS addon is installed)
	if hts_inventory_bars then
		self.stat_list["hunger"]	= { min= 0 , max= 1 , hint= "st_hts_title_hunger"	, title= "st_hts_title_hunger"	, value_functor= hts_inventory_bars.get_satiety_val	}
		self.stat_list["thirst"]	= { min= 0 , max= 1 , hint= "st_hts_title_thirst"	, title= "st_hts_title_thirst"	, value_functor= hts_inventory_bars.get_thirst_val	}
		self.stat_list["sleep"]		= { min= 0 , max= 1 , hint= "st_hts_title_sleep"	, title= "st_hts_title_sleep"	, value_functor= hts_inventory_bars.get_sleep_val	}
	end
	
	-- Added by Sota - GAMMA v0.9.3 compatibility, init new stats
	if is_gamma then
		self.stat_list["head_fire_wound"]	= { min= 0 , max= 1 , hint= "ui_inv_fire_wound_protection"	, title= "ui_inv_head_fire_wound_protection_title"	}
		self.stat_list["head_br_class"]		= { min= 0 , max= 1 , hint= "ui_inv_br_protection"			, title= "ui_inv_head_br_class_protection_title"	}
		self.stat_list["br_class"]			= { min= 0 , max= 1 , hint= "ui_inv_br_protection"			, title= "ui_inv_br_class_protection_title"			}
	end
	
	-- Edited by Sota - add missing entries to boosterID-to-stat names table
	self.boost_id = {
		[ BoosterID["HpRestore"] ]				= "health_restore",
		[ BoosterID["BleedingRestore"] ]		= "bleeding_restore",
		[ BoosterID["RadiationRestore"] ]		= "radia_restore",
		[ BoosterID["RadiationProtection"] ]	= "radia",
		[ BoosterID["TelepaticProtection"] ]	= "psi",
		[ BoosterID["ChemicalBurnProtection"] ]	= "acid",
		[ BoosterID["FireWoundImmunity"] ]		= "fire_wound",
		[ BoosterID["WoundImmunity"] ]			= "wound",
		[ BoosterID["StrikeImmunity"] ]			= "strike",
		[ BoosterID["ExplImmunity"] ]			= "explosion",
		[ BoosterID["PowerRestore"] ]			= "power",
	}
	self.boost_id_inv =  invert_table( dup_table(BoosterID) )
	for name,v in pairs(self.stat_list) do
		self.stat_outfit[name] = 0
		self.stat_helm[name] = 0
		self.stat_boost[name] = 0
		self.stat_arty[name] = 0
	end
	
	
	-- Item properties
	self.properties = {
		["use"]             = { index= 1 ,  name= "st_use",                    mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Use"},                                               	   action= {"Action_Use"} },
		["attach_1"]        = { index= 2 ,  name_func= {"Name_Attach",1},      mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Attach",1},                                              action= {"Action_Attach",1} },
		["attach_2"]        = { index= 3 ,  name_func= {"Name_Attach",2},      mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Attach",2},                                              action= {"Action_Attach",2} },
		["attach_3"]        = { index= 4 ,  name_func= {"Name_Attach",3},      mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Attach",3},                                              action= {"Action_Attach",3} },
		["to_slot"]         = { index= 5 ,  name_func= {"Name_Equip"},         mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Equip"},                                                 action= {"Action_Equip"} },
		["to_ruck"]         = { index= 6 ,  name_func= {"Name_UnEquip"},	   mode= {"inventory","trade"},		cont= {"actor_equ","actor_belt"}, 					                                                                   action= {"Action_UnEquip"} },
		["move"]            = { index= 7 ,  name_func= {"Name_Move"},          mode= {"loot","trade"},			cont= {"actor_equ","actor_belt","actor_bag","actor_trade_bag","actor_trade","npc_bag","npc_trade","npc_trade_bag"},   precondition1= {"Cond_Move"},                        action= {"Action_Move"} },
		["move_all"]        = { index= 8 ,  name= "st_move_all",               mode= {"loot","trade"},			cont= {"actor_equ","actor_belt","actor_bag","actor_trade_bag","actor_trade","npc_bag","npc_trade","npc_trade_bag"},   precondition1= {"Cond_Childs"}, precondition2= {"Cond_Move"},          action= {"Action_Move_All"} },
		["donate"]          = { index= 9 ,  name= "st_donate",                 mode= {"trade"},					cont= {"actor_trade_bag","actor_trade"},precondition1= {"Cond_NotQuest"},                                          	   action= {"Action_Donate"} },
		["unload"]          = { index= 10,  name= "st_unload_magazine",        mode= {"loot","inventory"},		cont= {"actor_equ","actor_bag","npc_bag"}, precondition1= {"Cond_Unload"},                                             action= {"Action_Unload"} },
		["custom_1"]        = { index= 11,  name_func= {"Name_Custom",1},      mode_func= {"Mode_Custom",1},	cont_func= {"Cont_Custom",1},   		precondition1= {"Name_Custom",1 },                                             action= {"Action_Custom",1} },
		["custom_2"]        = { index= 12,  name_func= {"Name_Custom",2},      mode_func= {"Mode_Custom",2},	cont_func= {"Cont_Custom",2},   		precondition1= {"Name_Custom",2 },                                             action= {"Action_Custom",2} },
		["custom_3"]        = { index= 13,  name_func= {"Name_Custom",3},      mode_func= {"Mode_Custom",3},	cont_func= {"Cont_Custom",3},   		precondition1= {"Name_Custom",3 },                                             action= {"Action_Custom",3} },
		["custom_4"]        = { index= 14,  name_func= {"Name_Custom",4},      mode_func= {"Mode_Custom",4},	cont_func= {"Cont_Custom",4},   		precondition1= {"Name_Custom",4 },                                             action= {"Action_Custom",4} },
		["custom_5"]        = { index= 15,  name_func= {"Name_Custom",5},      mode_func= {"Mode_Custom",5},	cont_func= {"Cont_Custom",5},   		precondition1= {"Name_Custom",5 },                                             action= {"Action_Custom",5} },
		["custom_6"]        = { index= 16,  name_func= {"Name_Custom",6},      mode_func= {"Mode_Custom",6},	cont_func= {"Cont_Custom",6},   		precondition1= {"Name_Custom",6 },                                             action= {"Action_Custom",6} },
		["custom_7"]        = { index= 17,  name_func= {"Name_Custom",7},      mode_func= {"Mode_Custom",7},	cont_func= {"Cont_Custom",7},   		precondition1= {"Name_Custom",7 },                                             action= {"Action_Custom",7} },
		["custom_8"]        = { index= 18,  name_func= {"Name_Custom",8},      mode_func= {"Mode_Custom",8},	cont_func= {"Cont_Custom",8},   		precondition1= {"Name_Custom",8 },                                             action= {"Action_Custom",8} },
		["custom_9"]        = { index= 19,  name_func= {"Name_Custom",9},      mode_func= {"Mode_Custom",9},	cont_func= {"Cont_Custom",9},   		precondition1= {"Name_Custom",9 },                                             action= {"Action_Custom",9} },
		["custom_10"]       = { index= 20,  name_func= {"Name_Custom",10},     mode_func= {"Mode_Custom",10},	cont_func= {"Cont_Custom",10},  		precondition1= {"Name_Custom",10},                                             action= {"Action_Custom",10} },
		["detach_silencer"] = { index= 21,  name= "st_detach_silencer",        mode= {"loot","inventory"},		cont= {"actor_equ","actor_bag","npc_bag"},        precondition1= {"Cond_Detach_Silencer"},                                       action= {"Action_Detach_Silencer"} },
		["detach_scope"] 	= { index= 22,  name= "st_detach_scope",           mode= {"loot","inventory"},		cont= {"actor_equ","actor_bag","npc_bag"},        precondition1= {"Cond_Detach_Scope"},                                          action= {"Action_Detach_Scope"} },
		["detach_gl"]       = { index= 23,  name= "st_detach_gl",              mode= {"loot","inventory"},		cont= {"actor_equ","actor_bag","npc_bag"},        precondition1= {"Cond_Detach_GL"},                                             action= {"Action_Detach_GL"} },
		["drop"]            = { index= 24,  name= "st_drop",                   mode= {"inventory"},				cont= {"actor_equ","actor_bag"},        precondition1= {"Cond_NotQuest"},                                              action= {"Action_Drop"} },
		["drop_all"]        = { index= 25,  name= "st_drop_all",               mode= {"inventory"},				cont= {"actor_bag"},                    precondition1= {"Cond_Childs"}, precondition2= {"Cond_NotQuest"},          	   action= {"Action_Drop_All"} },
	}
	for _,props in pairs(self.properties) do
		if props.mode then t2k_table(props.mode) end
		if props.cont then t2k_table(props.cont) end
	end
	
	-- Repair/Upgrade mode
	self.upgr = { id = false , sec = false , idx = false , bag = false}
	self.upgr_tree = {}
	self.upgr_installed = {}
	self.upgr_last_row = nil
	self.upgr_last_col = nil
	self.upgr_last_ii = nil
	
	-- Controls
	self:InitControls()
	self:InitCallbacks()
	
	-- Added by Sota - update inventory style
	self:UpdateStyles()
	
	-- Callbacks
	RegisterScriptCallback("actor_item_to_ruck",self)
	RegisterScriptCallback("actor_item_to_slot",self)
	RegisterScriptCallback("actor_item_to_belt",self)
	RegisterScriptCallback("actor_on_item_drop",self)
	RegisterScriptCallback("actor_on_item_use",self)
	RegisterScriptCallback("actor_on_item_put_in_box",self)
	RegisterScriptCallback("actor_on_item_take_from_box",self)
	RegisterScriptCallback("npc_on_item_take",self)
	RegisterScriptCallback("npc_on_item_drop",self)
	RegisterScriptCallback("npc_on_use",self)
	RegisterScriptCallback("physic_object_on_use_callback",self)
	RegisterScriptCallback("actor_on_net_destroy",self)
end

function UIInventory:__finalize()
end

-- Added by Sota - screen ratio postfix for wide/uwide screens
function get_screen_ratio_postfix()
	local ratio = utils_xml.screen_ratio()
	if (ratio > 0.9) then
		return ""
	elseif (ratio > 0.6) then
		return "_16"
	else
		return "_21"
	end
end

function UIInventory:InitControls()
	-- Added by Sota - always up to date screen ratio
	local ratio = utils_xml.screen_ratio()
	
	self:SetWndRect(Frect():set(0,0,1024,768))
	self:SetAutoDelete(true)
	
	self.xml = CScriptXmlInit()
	local xml = self.xml
	xml:ParseFile("ui_inventory.xml")
	
	-- Added by Sota - backup ui_inventory.xml
	local xml_def = self.xml
	
	-- Added by Sota - need to close texture rounding in screen corners (for def inv texture)
	self.side_plugs = {
		["l"] = xml:InitStatic( "side_plugs:left" , self ),
		["r"] = xml:InitStatic( "side_plugs:right" , self )
	}
	
	-- Right side - Player
	self.trade_bg = xml:InitStatic("trade_bg", self)
	
	-- Edited by Sota - parse info controls (actor, npc, upgrade) from a separate file
	local xml_info = CScriptXmlInit()
	xml_info:ParseFile("actor_menu_info.xml")
	
	-- Edited by Sota - refactoring of inventory init
	local view_t			= ui_rework_support.view_t
	local ctrl_faction_lst	= ui_rework_support.ctrl_faction_lst
	local ctrl_info_lst		= ui_rework_support.ctrl_info_lst
	local ctrl_size_lst		= ui_rework_support.ctrl_size_lst
	local ctrl_equ_lst		= ui_rework_support.ctrl_equ_lst
	local bag_id_lst		= ui_rework_support.bag_id_lst
	local ctrl_stats_lst	= ui_rework_support.ctrl_stats_lst
	
	for view,v_view in pairs(view_t) do
		
		-- init main view dialogs (player, npc, upgrade)
		local str_view_dialog	= view .. "_dialog"
		local view_node			= v_view.node
		self[ str_view_dialog ]	= xml:InitStatic( view_node , self )
		local ele_view_dialog	= self[ str_view_dialog ]
		
		-- init inv background textures
		self[ view .. "_background" ] = xml:InitStatic( view_node .. ":background" , ele_view_dialog )
		
		-- init grid control (order is important, grid texture should be under icons)
		if (view ~= "npc_up") then
			self[ view .. "_grid" ] = xml:InitStatic( view .. ":grid" , ele_view_dialog )
		end
		
		-- init factions overlay controls (including player/npc info)
		local ctrl_faction_def		= ctrl_faction_lst[1]
		local str_faction_dialog	= view .. "_faction_dialog"
		local str_sup_lvl			= "haruka_trader_supply_level"
		
		for _,ctrl_faction in ipairs(ctrl_faction_lst) do
			
			local str_faction_dialog_ctrl	= str_faction_dialog .. ctrl_faction
			self[ str_faction_dialog_ctrl ]	= xml:InitStatic( view_node , self )
			local ele_faction_dialog		= self[ str_faction_dialog_ctrl ]
			
			local xml_faction = (ctrl_faction == ctrl_faction_def) and xml or xml_info
			self[ view .. "_community_bg"		.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":community_bg"		, ele_faction_dialog )
			self[ view .. "_community_overlay"	.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":community_overlay"	, ele_faction_dialog )
			self[ view .. "_community_icon"		.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":community_icon"		, ele_faction_dialog )
			self[ view .. "_name"				.. ctrl_faction ] = xml_faction:InitTextWnd( view_node .. ":name"				, ele_faction_dialog )
			self[ view .. "_community"			.. ctrl_faction ] = xml_faction:InitTextWnd( view_node .. ":community"			, ele_faction_dialog )
			self[ view .. "_rank"				.. ctrl_faction ] = xml_faction:InitTextWnd( view_node .. ":rank"				, ele_faction_dialog )
			self[ view .. "_rank_icon"			.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":rank_icon"			, ele_faction_dialog )
			self[ view .. "_icon"				.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":icon"				, ele_faction_dialog )
			self[ view .. "_money"				.. ctrl_faction ] = xml_faction:InitTextWnd( view_node .. ":money"				, ele_faction_dialog )
			self[ view .. "_money_icon"			.. ctrl_faction ] = xml_faction:InitStatic ( view_node .. ":money_icon"			, ele_faction_dialog )
			
			-- Trader Level by HarukaSai (adapted by Sota for UI Rework)
			if (view == "npc") then
				self[ str_sup_lvl .. ctrl_faction ] = xml_faction:InitTextWnd( view_node .. ":trader_level" , ele_faction_dialog )
			end
		end
		
		-- link to def(real) factions overlay controls
		self[ str_faction_dialog ] = self[ str_faction_dialog .. ctrl_faction_def ]
		for _,ctrl_info in ipairs(ctrl_info_lst) do
			local str_info = view .. "_" .. ctrl_info
			self[ str_info ] = self[ str_info .. ctrl_faction_def ]
		end
		-- Trader Level by HarukaSai (adapted by Sota for UI Rework)
		if (view == "npc") then
			self[ str_sup_lvl ] = self[ str_sup_lvl .. ctrl_faction_def ]
		end
		
		if (view ~= "npc_up") then
			-- init default inventory ui controls
			self[ view .. "_weight_cap"	] = xml:InitStatic ( view .. ":weight_caption"	, ele_view_dialog )
			self[ view .. "_weight"		] = xml:InitTextWnd( view .. ":weight"			, ele_view_dialog )
			self[ view .. "_weight_max"	] = xml:InitTextWnd( view .. ":weight_max"		, ele_view_dialog )
			
			if (view == "player") then
				local str_putall	= view .. "_putall"
				self[ str_putall ]	= xml:Init3tButton( view .. ":putall_button" , ele_view_dialog )
				self:Register( self[ str_putall ] , "put_all" )
			else -- is "npc"
				local str_takeall	= view .. "_takeall"
				self[ str_takeall ]	= xml:Init3tButton( view .. ":takeall_button" , ele_view_dialog )
				self:Register( self[ str_takeall ] , "take_all" )
			end
			
			local str_trade_dialog 		= view .. "_trade"
			local trade_delim_node		= view .. ":trade_delimiter"
			self[ str_trade_dialog ]	= xml:InitStatic( trade_delim_node , ele_view_dialog )
			local ele_trade_dialog		= self[ str_trade_dialog ]
			
			self[ view .. "_trade_cap"		] = xml:InitStatic ( trade_delim_node .. ":trade_caption"		, ele_trade_dialog )
			self[ view .. "_trade_price"	] = xml:InitTextWnd( trade_delim_node .. ":trade_price"			, ele_trade_dialog )
			self[ view .. "_trade_weight"	] = xml:InitTextWnd( trade_delim_node .. ":trade_weight_max"	, ele_trade_dialog )
			
			if (view == "player") then
				local str_sell		= view .. "_trade_sell"
				self[ str_sell ]	= xml:Init3tButton( trade_delim_node .. ":trade_sell_button" , ele_trade_dialog )
				self:Register( self[ str_sell ] , "sell" )
			else -- is "npc"
				local str_buy		= view .. "_trade_buy"
				self[ str_buy ]		= xml:Init3tButton( trade_delim_node .. ":trade_buy_button"  , ele_trade_dialog )
				self:Register( self[ str_buy ] , "buy" )
			end
			
			-- init def(real) bag container controls
			for _,bag_id in ipairs(bag_id_lst) do
				local str_bag		= v_view.id .. bag_id
				self.CC[ str_bag ]	= utils_ui.UICellContainer( str_bag , self , nil , view .. ":cont" .. bag_id , ele_view_dialog )
				self.CC[ str_bag ].stack_all = enable_item_picker and true or false
			end
			
			-- init def(backup)/small grid size controls to take size from them
			local ctrl_size_def = ctrl_size_lst[1]
			-- parse small inv grid and bag container layouts from a separate file
			local xml_grid = CScriptXmlInit()
			xml_grid:ParseFile("actor_menu_grid.xml")
			
			for _,ctrl_size in ipairs(ctrl_size_lst) do
				
				-- change global xml variable for utils_ui.UICellContainer init function
				self.xml = (ctrl_size == ctrl_size_def) and xml or xml_grid
				
				-- init grid control
				local str_grid		= view .. "_grid" .. ctrl_size
				self[ str_grid ]	= self.xml:InitStatic( view .. ":grid" , ele_view_dialog )
				self[ str_grid ]:Show(false)
				
				-- init trade_delimiter control
				local str_trade		= view .. "_trade" .. ctrl_size
				self[ str_trade ]	= self.xml:InitStatic( view .. ":trade_delimiter" , ele_view_dialog )
				self[ str_trade ]:Show(false)
				
				-- init bag container controls
				for _,bag_id in ipairs(bag_id_lst) do
					local str_bag		= "cc_" .. v_view.id .. bag_id .. ctrl_size
					local str_bag_id	= v_view.id .. bag_id
					self[ str_bag ]		= utils_ui.UICellContainer( str_bag_id , self , nil , view .. ":cont" .. bag_id , ele_view_dialog )
					self[ str_bag ]:Show(false)
				end
			end
			-- recovery ui_inventory.xml from backup
			self.xml = xml_def
			
		else -- is "npc_up"
			self[ view .. "_scheme"	] = xml:InitScrollView	( view_node .. ":scheme"		, ele_view_dialog )
			self[ view .. "_item"	] = xml:InitStatic		( view_node .. ":item_static"	, ele_view_dialog )
			
			local str_repair	= view .. "_repair"
			self[ str_repair ]	= xml:Init3tButton( view_node .. ":repair_button" , ele_view_dialog )
			self:Register( self[ str_repair ], "repair" )
		end
	end	
	
	self.equ_dialog		= xml:InitStatic( "equipment"				, self				)
	self.equ_background	= xml:InitStatic( "equipment:background"	, self.equ_dialog	)
	
	-- Slots
	-- Edited by Sota - init def(horz)/vert equ cell controls and add txt label controls for equ cells
	local ctrl_equ_def = ctrl_equ_lst[1]
	-- parse vert equ cells layout from a separate file
	local xml_equ = CScriptXmlInit()
	xml_equ:ParseFile("actor_menu_equipment.xml")
	
	for _,ctrl_equ in ipairs(ctrl_equ_lst) do
		
		-- change global xml variable for utils_ui.UICellContainer init function
		self.xml = (ctrl_equ == ctrl_equ_def) and xml or xml_equ
		
		-- init inv equ layouts
		local str_equ	= "actor_equ" .. ctrl_equ
		self[ str_equ ]	= utils_ui.UICellContainer( "actor_equ" , self , "equipment:cont_equ" , "equipment:cont_equ" , self.equ_dialog , true )
		local ele_equ	= self[ str_equ ]
		ele_equ.disable_callback["On_CC_Add"]		= true
		ele_equ.disable_callback["On_CC_Remove"]	= true
		for i=1,13 do
			-- add equ cells
			ele_equ:AddItemManual(nil, nil, i)
			-- add txt label controls for equ cells
			ele_equ.cell[i].txt = self.xml:InitTextWnd( "equipment:cont_equ:cell_" .. i .. ":txt" , ele_equ.cell[i].cell )
			-- save def wpn cells pos
			if (i == 2) or (i == 3) then
				local pos = ele_equ.cell[i].cell:GetWndPos()
				ele_equ.cell[i].pos = vector2():set( pos.x , pos.y )
			end
		end
		
		-- init helm and bkpk cell blockers
		self[ "blocker_helm" .. ctrl_equ ] = self.xml:InitStatic( "equipment:cont_equ:blocker_12" , ele_equ.prof )
		self[ "blocker_bkpk" .. ctrl_equ ] = self.xml:InitStatic( "equipment:cont_equ:blocker_13" , ele_equ.prof )
	end
	-- recovery ui_inventory.xml from backup
	self.xml = xml_def
	
	-- link to def(real) equ cell controls
	self.CC["actor_equ"]	= self[ "actor_equ"		.. ctrl_equ_def ]
	self.blocker_helm		= self[ "blocker_helm"	.. ctrl_equ_def ]
	self.blocker_bkpk		= self[ "blocker_bkpk"	.. ctrl_equ_def ]
	
	-- Belt
	self.CC["actor_belt"] = utils_ui.UICellContainer( "actor_belt" , self , "equipment:cont_belt" , "equipment:cont_belt" , self.equ_dialog , true )
	self.CC["actor_belt"].disable_callback["On_CC_Add"]		= true
	self.CC["actor_belt"].disable_callback["On_CC_Remove"]	= true
	self.blocker_arty = {}
	for i=1,5 do
		self.CC["actor_belt"]:AddItemManual(nil, nil, i)
		self.blocker_arty[i] = xml:InitStatic( "equipment:cont_belt:blocker_" .. i , self.CC["actor_belt"].prof )
	end
	
	-- Quick items
	self.CC["actor_quick"] = utils_ui.UICellContainer( "actor_quick" , self , "equipment:cont_quick" , "equipment:cont_quick" , self.equ_dialog , true )
	self.CC["actor_quick"].disable_drag						= true
	self.CC["actor_quick"].disable_info						= false
	self.CC["actor_quick"].disable_callback["On_CC_Add"]	= true
	self.CC["actor_quick"].disable_callback["On_CC_Remove"]	= true
	self.CC["actor_quick"].showcase							= true
	self.quick_txt = {}
	for i=1,4 do
		--self.CC["actor_quick"]:AddItemManual(nil, "bread", i)
		self.CC["actor_quick"]:AddItemManual(nil, nil, i)
		self.quick_txt[i] = xml:InitStatic( "equipment:cont_quick:cell_" .. i .. ":txt" , self.CC["actor_quick"].cell[i].cell )
	end
	
	-- Stats
	-- Edited by Sota - init def(normal) stats icons and background for stats bars
	-- also init controls for various HTS layouts (if HTS addon is installed)
	local ctrl_stats_def	= ctrl_stats_lst[1]
	local xml_stats			= xml
	
	for _,ctrl_stats in ipairs(ctrl_stats_lst) do
		
		-- parse stats layout from a separate file
		if (ctrl_stats ~= ctrl_stats_def) then
			xml_stats = CScriptXmlInit()
			xml_stats:ParseFile("actor_menu_state_info" .. ctrl_stats .. ".xml")
		end
		
		-- init main stats dialog
		local str_stats_dialog		= "stats_dialog" .. ctrl_stats
		self[ str_stats_dialog ]	= xml_stats:InitStatic( "equipment:actor_state_info" , self.equ_dialog )
		
		-- create stats table
		local str_stat				= "stat" .. ctrl_stats
		self[ str_stat ]			= {}
		local ele_stats				= self[ str_stat ]
		
		for name,_ in pairs(self.stat_list) do
			-- skip init extended stats for not extended HTS layouts
			if (ctrl_stats ~= "_hts_ext") and ( (name == "strike") or (name == "explosion") ) and (not is_gamma) then
				goto continue
			end
			
			-- init of base for stats
			ele_stats[name]						= {}
			local ele_stat						= ele_stats[name]
			ele_stat.base						= xml_stats:InitStatic( "equipment:actor_state_info:" .. name .. "_sensor" , self[ str_stats_dialog ] )
			local ele_stat_base					= ele_stat.base
			
			-- GAMMA v0.9.3 compatibility, init text controls instead of bars
			if is_gamma then
				ele_stat.text					= xml_stats:InitTextWnd( "equipment:actor_state_info:txt"		, ele_stat_base )
				ele_stat.text_bonus				= xml_stats:InitTextWnd( "equipment:actor_state_info:txt_bonus"	, ele_stat_base )
			else
				-- init bar and bar background
				ele_stat.bar_bg					= xml_stats:InitStatic		( "equipment:actor_state_info:" .. name .. "_sensor:state_progress" , ele_stat_base )
				local ele_bar_bg				= ele_stat.bar_bg
				ele_stat.bar					= xml_stats:InitProgressBar	( "equipment:actor_state_info:" .. name .. "_sensor:state_progress" , ele_stat_base )
				
				local bar_pos 					= vector2():set( ele_bar_bg:GetWndPos().x	, ele_bar_bg:GetWndPos().y	)
				local bar_size					= vector2():set( ele_bar_bg:GetWidth()		, ele_bar_bg:GetHeight()	)
				
				-- init and setup text control of stats names
				ele_stat.txt 					= xml:InitTextWnd( "equipment:actor_state_info:stats_txt" , ele_stat_base )
				local ele_stat_txt				= ele_stat.txt
				ele_stat_txt:SetText			( gts( self.stat_list[name].title ) )
				ele_stat_txt:SetWndPos			( bar_pos )
				ele_stat_txt:SetWndSize			( bar_size )
				ele_stat_txt:SetTextAlignment	( align_t["l"] )
				ele_stat_txt:SetVTextAlignment	( align_t["t"] )
				ele_stat_txt:SetFont			( font_t["small"] )
				ele_stat_txt:SetTextComplexMode(false)
				
				-- init and setup text control of stats values
				ele_stat.txt_val 				= xml:InitTextWnd( "equipment:actor_state_info:stats_txt" , ele_stat_base )
				local ele_stat_val				= ele_stat.txt_val
				ele_stat_val:SetWndPos			( bar_pos )
				ele_stat_val:SetWndSize			( bar_size )
				ele_stat_val:SetTextAlignment	( align_t["r"] )
				ele_stat_val:SetVTextAlignment	( align_t["t"] )
				ele_stat_val:SetFont			( font_t["small"] )
				ele_stat_val:SetTextComplexMode(true)
				
				-- init and setup text control of stats extended values
				ele_stat.txt_val_ext			= xml:InitTextWnd( "equipment:actor_state_info:stats_txt" , ele_stat_base )
				local ele_stat_ext				= ele_stat.txt_val_ext
				ele_stat_ext:SetWndPos			( bar_pos )
				ele_stat_ext:SetWndSize			( bar_size )
				ele_stat_ext:SetTextAlignment	( align_t["l"] )
				ele_stat_ext:SetVTextAlignment	( align_t["t"] )
				ele_stat_ext:SetFont			( font_t["small"] )
				ele_stat_ext:SetTextComplexMode(true)
				
				-- backup of text control position values
				ele_stat_txt.pos				= bar_pos
				ele_stat_val.pos				= bar_pos
				ele_stat_ext.pos				= bar_pos
			end
			
			-- init of base for stats icons
			ele_stat.ico_base					= xml_stats:InitStatic( "equipment:actor_state_info:icon" , ele_stat_base )
			local ele_ico_base					= ele_stat.ico_base
			
			-- init shadow for stats icons
			ele_stat.ico_shdw					= xml_stats:InitStatic( "equipment:actor_state_info:icon:normal" , ele_ico_base )
			local ele_ico_shdw					= ele_stat.ico_shdw
			ele_ico_shdw:InitTexture			( "ui_inGame2_inv_state_" .. name )
			local shdw_pos						= ele_ico_shdw:GetWndPos()
			shdw_pos.x							= shdw_pos.x + 1 * ratio
			shdw_pos.y							= shdw_pos.y + 1
			ele_ico_shdw:SetWndPos				( shdw_pos )
			ele_ico_shdw:SetTextureColor		( GetARGB(255, 0, 0, 0) )
			
			-- init def(normal) stats icons
			ele_stat.ico_def					= xml_stats:InitStatic( "equipment:actor_state_info:icon:normal" , ele_ico_base )
			ele_stat.ico_def:InitTexture		( "ui_inGame2_inv_state_" .. name )
			ele_stat.ico_def:Show(true)
			
			-- init positive stats icons
			ele_stat.ico_p						= xml_stats:InitStatic( "equipment:actor_state_info:icon:active" , ele_ico_base )
			ele_stat.ico_p:InitTexture			( "ui_inGame2_inv_state_P_" .. name )
			ele_stat.ico_p:Show(false)
			
			-- init negative stats icons
			ele_stat.ico_n						= xml_stats:InitStatic( "equipment:actor_state_info:icon:active" , ele_ico_base )
			ele_stat.ico_n:InitTexture			( "ui_inGame2_inv_state_N_" .. name )
			ele_stat.ico_n:Show(false)
			
			::continue::
		end
		
		-- break after first iteration (if HTS addon is not installed)
		-- and GAMMA v0.9.3 compatibility, no need to init other stats layouts
		if is_gamma or (not hts_inventory_bars) then break end
	end
	
	-- link to def(real) stats controls
	self.stats_dialog	= self[ "stats_dialog"	.. ctrl_stats_def ]
	self.stat			= self[ "stat"			.. ctrl_stats_def ]
	
	-- Sorter
	self.sort_dialog = xml:InitStatic( "equipment:sorter" , self.equ_dialog )
	self.sort_btn = {}
--	self.sort_num = {}
	
	for i=1,8 do
		self.sort_btn[i] = xml:InitCheck( "equipment:sorter:btn_" .. i , self.sort_dialog )
		self.sort_btn[i]:SetCheck(false)
		local _wrapper = function(handler) -- we need wrapper in order to pass ctrl to method
			self:On_Sort(i)
		end
		self:Register(self.sort_btn[i], "sort_" .. i)
		self:AddCallback("sort_" .. i, ui_events.BUTTON_CLICKED, _wrapper, self)
		
		-- Edited by Sota - simplify init of tab text controls
--		self.sort_num[i] = xml:InitTextWnd( "equipment:sorter:txt_" .. i , self.sort_dialog )
--		self.sort_num[i]:SetFont(GetFontSmall())
--		self.sort_num[i]:SetText(i)
		self.sort_btn[i].num = xml:InitTextWnd( "equipment:sorter:num" , self.sort_btn[i] )
		self.sort_btn[i].num:SetText(i)
	end
	
	-- Trash can
	self.trash = xml:InitStatic( "npc:trash" , self )
	
	-- Item picker
	self.CC["picker"] = utils_ui.UICellContainer( "picker" , self , nil , "equipment:cont_picker" , self.equ_dialog , nil )
	self.CC["picker"].sort_method						= "props"
	self.CC["picker"].disable_stack						= true
	self.CC["picker"].disable_scroll_dragdrop			= true
	self.CC["picker"].parent							= { bag= false , idx= false }
	self.CC["picker"].disable_callback["On_CC_Add"]		= true -- needed to prevent update loop
	self.CC["picker"].disable_callback["On_CC_Remove"]	= true
	-- Edited by Sota - picker resize now in UpdateStyles()
--	self.CC["picker"].scroll:SetWndPos(vector2():set( 10 , 0 ))
	-- Added by Sota - backup picker size
	self.CC["picker"].size = {
		w = self.CC["picker"].scroll:GetWidth(),
		h = self.CC["picker"].scroll:GetHeight()
	}
--	self.CC["picker"]:SetGridSpecs()
	self.CC["picker"]:Show(false)
	
	-- Message box
	self.message_box    = CUIMessageBoxEx()
	self:Register(self.message_box, "mbr")
	self.message_box_up = CUIMessageBoxEx()
	self:Register(self.message_box_up, "mbu")
	
	-- Info box
	self.item_info				= utils_ui.UIInfoItem(self)
	self.item_info.can_compare	= true
	
	-- Upgrade box
	self.upgr_info				= utils_ui.UIInfoUpgr(self)
	
	-- Item Properties box
	self.item_props				= utils_ui.UICellProperties(self)
	
	-- Hint Window
	self.hint_wnd				= xml:InitFrame( "hint_wnd:background" , self )
	self.hint_wnd:SetAutoDelete(false)
	self.hint_wnd_text			= xml:InitTextWnd( "hint_wnd:text" , self.hint_wnd )
	self.hint_wnd:Show(false)
	
	-- Added by Sota - backup stats hint size
	self.hint_wnd.size			= {
		w = self.hint_wnd:GetWidth(),
		h = self.hint_wnd:GetHeight(),
	}
	self.hint_wnd_text.size		= {
		w = self.hint_wnd_text:GetWidth(),
		h = self.hint_wnd_text:GetHeight(),
	}
end

function UIInventory:InitCallbacks()
	self:AddCallback("sell"		, ui_events.BUTTON_CLICKED			, self.TMode_Sell		, self)
	self:AddCallback("buy"		, ui_events.BUTTON_CLICKED			, self.TMode_Buy		, self)
	self:AddCallback("put_all"	, ui_events.BUTTON_CLICKED			, self.LMode_PutAll		, self)
	self:AddCallback("take_all"	, ui_events.BUTTON_CLICKED			, self.LMode_TakeAll	, self)
	self:AddCallback("repair"	, ui_events.BUTTON_CLICKED			, self.RMode_OnRepair	, self)
	self:AddCallback("mbr"		, ui_events.MESSAGE_BOX_YES_CLICKED	, self.RMode_RepairYes	, self)
	self:AddCallback("mbr"		, ui_events.MESSAGE_BOX_NO_CLICKED	, self.Discard			, self)
	self:AddCallback("mbr"		, ui_events.MESSAGE_BOX_OK_CLICKED	, self.Discard			, self)
	self:AddCallback("mbu"		, ui_events.MESSAGE_BOX_YES_CLICKED	, self.RMode_UpgradeYes	, self)
	self:AddCallback("mbu"		, ui_events.MESSAGE_BOX_NO_CLICKED	, self.Discard			, self)
end

-- Added by Sota - inventory stats layout update function
function UIInventory:UpdateStatsLayout()
	
	local use_alt_hts			= color_settings.use_alt_hts
	local use_alt_stats_bars	= color_settings.use_alt_stats_bars
	local show_stat_names		= color_settings.show_stat_names
	local show_num_stats		= color_settings.show_num_stats
	local show_num_stats_ext	= color_settings.show_num_stats_ext
	
-- change stats layout (if HTS addon is installed)
	if hts_inventory_bars then
		
		local ctrl_stats_lst	= ui_rework_support.ctrl_stats_lst
		local ctrl_stats_crnt	= ctrl_stats_lst[ use_alt_hts ]
		
		local str_stats_dialog	= "stats_dialog"
		local str_stat			= "stat"
		
		for _,ctrl_stats in ipairs(ctrl_stats_lst) do
			
			local ele_stats_dialog	= self[ str_stats_dialog .. ctrl_stats ]
			local ele_stat			= self[ str_stat .. ctrl_stats ]
			
			if (ctrl_stats == ctrl_stats_crnt) then
				ele_stats_dialog:Show(true)
				self[ str_stats_dialog ]	= ele_stats_dialog
				self[ str_stat ]			= ele_stat
			else
				ele_stats_dialog:Show(false)
			end
		end
	end
	
-- change display text labels of stats
	local is_htsp		= (use_alt_hts == 2)
	local is_hts_alt	= (use_alt_hts == 3)
	local is_hts_ext	= (use_alt_hts == 4)
	local is_def_bars	= (use_alt_stats_bars == 1)
	
	-- for def bars style (like columns), stats name and value labels above bar controls
	local stat_bar_h	= self.stat["health"].bar:GetHeight()--18
	local y_offset		= -(stat_bar_h * 1/3)
	local y_offset_txt	= is_def_bars and y_offset or 0
	local y_offset_ext	= is_def_bars and y_offset or (stat_bar_h * 2/3)
	
	-- show/hide power stat depending on HTS layout setting
	local stat			= self.stat
	local show_power	= (not hts_inventory_bars) or is_htsp or is_hts_ext
	stat["power"].base:Show( show_power )
	
	for name,v in pairs(stat) do
		
		-- links to tables
		local ele_txt	= v.txt
		local ele_val	= v.txt_val
		local ele_ext	= v.txt_val_ext
		
		-- set position values
		local pos_txt	= vector2():set( ele_txt.pos.x , ele_txt.pos.y + y_offset_txt )
		local pos_val	= vector2():set( ele_val.pos.x , ele_val.pos.y )
		local pos_ext	= vector2():set( ele_ext.pos.x , ele_ext.pos.y + y_offset_ext )
		
		-- offset position and set alignment of stats text labels
		local is_hts_stat		= (name == "hunger") or (name == "thirst") or (name == "sleep")
		local is_simple_stat	= (name == "health") or is_hts_stat
		
		-- special logic displaying text labels for HTS stats
		if is_hts_stat then
			
			local align_txt, align_val
			
			if is_hts_alt then
				-- for alt HTS layout, HTS stats value labels on the right and on the same line with the name
				align_txt = align_t["l"]
				align_val = align_t["r"]
				pos_val = pos_txt
			else
				-- for all other HTS layouts, center alignment for HTS stats value labels
				align_txt = align_t["c"]
				align_val = align_t["c"]
				if is_def_bars then
				-- if HTS bars like columns
					-- for extended HTS layout, HTS stats value labels centered instead of names
					-- for the rest, under bar in center
					pos_val = is_hts_ext and pos_txt or vector2():set( pos_val.x , pos_val.y + stat_bar_h )
				elseif show_stat_names then
				-- if solid HTS bars
					-- HTS stats value labels centered under bar if stats names is shown
					pos_val = pos_ext
				end
			end
			ele_txt:SetTextAlignment( align_txt )
			ele_val:SetTextAlignment( align_val )
		
		-- for all other stats, value labels on the right and on the same line with the name
		else
			pos_val = pos_txt
		end
		
		-- offset text labels
		ele_txt:SetWndPos( pos_txt )
		ele_val:SetWndPos( pos_val )
		ele_ext:SetWndPos( pos_ext )
		
		-- show/hide text labels
		local txt_to_hide	= is_def_bars and ( (show_num_stats_ext and (not is_simple_stat)) or (is_hts_ext and is_hts_stat) )
		local show_txt		= show_stat_names and (not txt_to_hide)
		local show_ext		= show_num_stats_ext and (not is_simple_stat)
		
		ele_txt:Show( show_txt )
		ele_val:Show( show_num_stats )
		ele_ext:Show( show_ext )
	end
end

-- Added by Sota - inventory style update function
function UIInventory:UpdateStyles()
	
	if (not need_update) then
		return
	end
	need_update = false
	
	self:UpdateStatsLayout()
	
	local view_t				= ui_rework_support.view_t
	local ctrl_faction_lst		= ui_rework_support.ctrl_faction_lst
	local ctrl_info_lst			= ui_rework_support.ctrl_info_lst
	local ctrl_size_lst			= ui_rework_support.ctrl_size_lst
	local ctrl_equ_lst			= ui_rework_support.ctrl_equ_lst
	local bag_id_lst			= ui_rework_support.bag_id_lst
	local str_inv_lst			= ui_rework_support.str_inv_lst
	local str_grid_lst			= ui_rework_support.str_grid_lst
	local str_blocker_lst		= ui_rework_support.str_blocker_lst
	
	local use_alt_factions		= color_settings.use_alt_factions
	local use_alt_inv			= color_settings.use_alt_inv
	local use_alt_grid			= color_settings.use_alt_grid
	local use_alt_blockers		= color_settings.use_alt_blockers
	local use_inv_labels		= color_settings.use_inv_labels
	local use_small_icons		= color_settings.use_small_icons
	local use_inv_vert			= color_settings.use_inv_vert
	local swap_wpn_slots		= color_settings.swap_wpn_slots
	local use_inv_weights		= color_settings.use_inv_weights
	
-- set transparency for tooltip (self.hint_wnd)
	-- local clr_a = color_settings.inv_hint_alpha
	-- self.hint_wnd:SetColor( GetARGB(clr_a, 255, 255, 255) )
	
-- change equ layout (horz/vert)
	local ctrl_equ_crnt = ctrl_equ_lst[ use_inv_vert and 2 or 1 ]
	local str_equ = "actor_equ"
	
	for _,ctrl_equ in ipairs(ctrl_equ_lst) do
		
		local ele_equ = self[ str_equ .. ctrl_equ ]
		
		if (ctrl_equ == ctrl_equ_crnt) then
			ele_equ:Show(true)
			self.CC[ str_equ ] = ele_equ
		else
			ele_equ:Show(false)
		end
	end
	local cc_equ = self.CC[ str_equ ]
	
-- change equ cell blockers layout
	local str_blocker_helm = "blocker_helm"
	local str_blocker_bkpk = "blocker_bkpk"
	self[ str_blocker_helm ] = self[ str_blocker_helm .. ctrl_equ_crnt ]
	self[ str_blocker_bkpk ] = self[ str_blocker_bkpk .. ctrl_equ_crnt ]
	
-- swap wpn slots
	local scndary = cc_equ.cell[2]
	local primary = cc_equ.cell[3]
	
	if swap_wpn_slots then
		scndary.cell:SetWndPos( primary.pos )
		scndary.hl:SetWndPos( primary.pos )
		
		primary.cell:SetWndPos( scndary.pos )
		primary.hl:SetWndPos( scndary.pos )
	else
		scndary.cell:SetWndPos( scndary.pos )
		scndary.hl:SetWndPos( scndary.pos )
		
		primary.cell:SetWndPos( primary.pos )
		primary.hl:SetWndPos( primary.pos )
	end
	
-- resize inv mid side cells
	local grid_size = use_small_icons and 35 or 41
	local grid_line = 2
	
	cc_equ:SetGridSpecs( grid_size , grid_line )
	self.CC["actor_belt"]:SetGridSpecs( grid_size , grid_line )
	self.CC["actor_quick"]:SetGridSpecs( grid_size , grid_line )
	 
-- change picker layout
	local ratio = utils_xml.screen_ratio()
	local picker_x_offset = use_small_icons and 2.75 or 0
	local picker_h_offset = use_small_icons and 0 or 19
	
	local cc_picker = self.CC["picker"]
	cc_picker.scroll:SetWndPos( vector2():set( ( 7.25 + picker_x_offset ) * ratio , 0 ) )
	cc_picker.scroll:SetWndSize( vector2():set( cc_picker.size.w , cc_picker.size.h - picker_h_offset ) )
	cc_picker:SetGridSpecs( grid_size , grid_line )
	
-- show/hide equ cell labels and set alignment depending on addon Inventory Weights Revised by demonized
	local align = use_inv_weights and align_t["r"] or align_t["l"]
	local equ_cells = cc_equ.cell
	for i=1,13 do
		equ_cells[i].txt:SetTextAlignment( align )
		equ_cells[i].txt:Show( use_inv_labels )
	end
	
-- set equ background texture
	-- postfix for equ orientation (horz/vert)
	local equ_postfix = use_inv_vert and ctrl_equ_lst[2] or ""
	-- postfix for inv style
	local inv_postfix = str_inv_lst[ use_alt_inv ]
	-- set equ background texture
	local tex_equ = "ui_inGame2_inventory_back" .. equ_postfix .. inv_postfix
	self.equ_background:InitTexture( tex_equ )
	
-- change equ cell blockers texture
	local blk_postfix = str_blocker_lst[ use_alt_blockers ]
	self.blocker_helm:InitTexture( "ui_inGame2_helmet_blocker" .. blk_postfix )
	self.blocker_bkpk:InitTexture( "ui_inGame2_backpack_blocker" .. blk_postfix )
	
	local tex_blk_arty = "ui_inGame2_artefact_blocker" .. blk_postfix
	for i=1,5 do
		self.blocker_arty[i]:InitTexture( tex_blk_arty )
	end
	
-- change layouts and textures for sides of inv
	-- postfix for sizing of controls
	local ctrl_size = ctrl_size_lst[ use_small_icons and 2 or 1 ]
	-- inv background texture name
	local tex_inv = ""
	-- screen ratio postfix
	local ratio_postfix = get_screen_ratio_postfix()
	-- grid size and style postfixes
	local size_postfix = use_small_icons and ctrl_size_lst[2] or ""
	local style_postfix = str_grid_lst[ (use_alt_grid == 2) and 1 or 2 ]
	
	-- lazy fix for 16:10 ratio
	local is_1610 = (ratio > 0.8) and (ratio < 1)
	-- specifically for 1600x1024 otherwise could be use "ratio"
	local ratio_1610 = (4/3) / (16/10)
	-- width multiplier for 1600x1024
	local w_mul_1610 = ratio / ratio_1610
	-- scroll pad width
	local w_pad = use_small_icons and 5 or -1
	
	-- grid and picker textures
	local tex_grid = "ui_inGame2_actor_menu_grid" .. size_postfix .. style_postfix .. ( is_1610 and "_1610" or ratio_postfix )
	local tex_picker = "ui_item_picker_background_grid" .. size_postfix .. style_postfix
	
	-- current faction selection to hide opposite control
	local ctrl_faction_crnt = ctrl_faction_lst[ (use_alt_factions == 1) and 1 or 2 ]

	for view,v_view in pairs(view_t) do
		
		-- is npc_up side
		if (view == "npc_up") then
			-- inv background texture (npc_up)
			tex_inv = "ui_inGame2_repair_panel" .. inv_postfix .. ratio_postfix
		
		-- is player or npc sides
		else
			-- inv background texture (player, npc)
			tex_inv = "ui_inGame2_left_side" .. inv_postfix .. ratio_postfix
			
			-- offset trade delimiter
			local str_trade = view .. "_trade"
			local elem_trade = self[ str_trade ]
			local base_trade = self[ str_trade .. ctrl_size ]
			utils_xml.sync_pos( base_trade , elem_trade )
			
			-- set grid and picker textures
			local str_grid = view .. "_grid"
			local elem_grid = self[ str_grid ]
			local base_grid = self[ str_grid .. ctrl_size ]
			
			-- 1 is no grid
			if (use_alt_grid == 1) then
				elem_grid:Show(false)
				-- set picker texture no grid
				cc_picker.prof:InitTexture( "ui_item_picker_background" )
			
			-- 2 and 3 is alt grid styles
			else
				-- resize grid control and set texture
				utils_xml.sync_size( base_grid , elem_grid )-- (base, element)
				elem_grid:InitTexture( tex_grid )
				
				-- lazy fix for 16:10 ratio
				if is_1610 then
					-- get grid texture width
					local w = elem_grid:GetTextureRect().x2 - elem_grid:GetTextureRect().x1
					-- because texture is x2 size of control
					w = w/2 * ratio_1610
					-- resize grid control
					elem_grid:SetWndSize( vector2():set( w , elem_grid:GetHeight() ) )
				end
				
				elem_grid:Show(true)
				-- set picker texture
				cc_picker.prof:InitTexture( tex_picker )
			end
		
			-- resize inv bag containers
			for _,bag_id in ipairs(bag_id_lst) do
				
				local str_bag = v_view.id .. bag_id
				local cc_bag = self.CC[ str_bag ]
				local base_bag = self[ "cc_" .. str_bag .. ctrl_size ]
				
				-- resize bag controls
				utils_xml.sync_element( cc_bag.prof , base_bag.prof )-- (element, base)
				utils_xml.sync_size( base_bag.prof , cc_bag.scroll )-- (base, element)
				utils_xml.sync_size( base_bag.prof , cc_bag.st )-- (base, element)
				
				-- lazy fix for 16:10 ratio
				if is_1610 then
					local w = elem_grid:GetWidth() - w_pad
					local h = cc_bag.prof:GetHeight()
					cc_bag.prof:SetWndSize( vector2():set( w , h ) )
					-- fix bag containers width for 1600x1024
					w = w * w_mul_1610
					cc_bag.scroll:SetWndSize( vector2():set( w , h ) )
					cc_bag.st:SetWndSize( vector2():set( w , h ) )
				end
				
				-- resize inv bag cells
				cc_bag:SetGridSpecs( grid_size , grid_line )
			end
		end
		
		-- set inv background textures
		self[ view .. "_background" ]:InitTexture( tex_inv )
		
		-- hide faction overlays opposite to selected faction style setting
		local str_faction = view .. "_faction_dialog"
		local str_sup_lvl = "haruka_trader_supply_level"
		
		for _,ctrl_faction in ipairs(ctrl_faction_lst) do
			
			local ele_faction = self[ str_faction .. ctrl_faction ]
			
			if (ctrl_faction == ctrl_faction_crnt) then
				
				ele_faction:Show(true)
				self[ str_faction ] = ele_faction
				
				for _,ctrl_info in ipairs(ctrl_info_lst) do
					local str_info = view .. "_" .. ctrl_info
					self[ str_info ] = self[ str_info .. ctrl_faction ]
				end
				
				-- adaptation for Trader Level by HarukaSai
				self[ str_sup_lvl ] = self[ str_sup_lvl .. ctrl_faction ]
			else
				ele_faction:Show(false)
			end
		end
	end
end

function UIInventory:Reset(obj)
	
	-- Added by Sota - update inventory style if settings change
	self:UpdateStyles()
	
	local to_show = obj and self:IsInvOwner(obj)
	local mode = self.mode
	local mI = mode == "inventory"
	local mL = mode == "loot"
	local mT = mode == "trade"
	local mR = mode == "repair"
	
	-- Trader Level by HarukaSai
	self.haruka_trader_supply_level:Show( mT and display_supply_level )
	
	-- Info
	self.npc_id           = obj and obj:id() or false
	self.npc_is_companion = obj and mL and IsStalker(obj) and obj:alive() and obj:has_info("npcx_is_companion") and true or false
	self.npc_is_box       = obj and IsInvbox(obj) or false
	self.npc_is_not_npc   = obj and ((obj:name() == "esc_m_trader") or (obj:section() == "m_lesnik"))
	self.faction_color 	  = faction_colors[db.actor:character_community():sub(7)] or faction_colors["stalker"]
	
	-- Containers
	self.CC["actor_bag"]:Show      ( mI or mL or mR )
	self.CC["actor_trade"]:Show    ( mT )
	self.CC["actor_trade_bag"]:Show( mT )
	self.CC["npc_bag"]:Show        ( mL )
	self.CC["npc_trade"]:Show      ( mT )
	self.CC["npc_trade_bag"]:Show  ( mT )
	self:Picker_Toggle()
	self.trash:Show                ( mI )
	
	self.CC["actor_bag"].can_select = mR
	self.CC["actor_equ"].can_select = mR
	self.CC["picker"].can_select 	= mR
	
	for name,cc in pairs(self.CC) do
		cc.trade_profile = nil
	end
	
	-- Elements
	-- Added by Sota - inventory side plugs
	local ratio = utils_xml.screen_ratio()
	local is_21_to_16 = (ratio < 0.75) and (get_screen_ratio_postfix() == "_16")
	local use_alt_inv = color_settings.use_alt_inv
	local need_plugs = (use_alt_inv == 1) and (not is_21_to_16) or (use_alt_inv == 3) and is_21_to_16
	self.side_plugs["l"]:Show( need_plugs and (mL or mT or mR) )
	self.side_plugs["r"]:Show( need_plugs and mode )
	
	-- Edited by Sota - trade background is now in repair mode
	self.trade_bg:Show( mT or mR )
	
	-- Right side - Player
	self.player_faction_dialog:Show( mode )
	self.player_trade:Show( mT )
	self.player_putall:Show( mL )
	
	-- Left side -- NPC
	self.npc_dialog:Show( mL or mT )
	self.npc_faction_dialog:Show( mL or mT )
	self.npc_name:Show( to_show )
	self.npc_community:Show( to_show )
	self.npc_rank_icon:Show( not self.npc_is_box )
	self.npc_icon:Show( to_show )
	self.npc_money:Show( mT )
	self.npc_money_icon:Show( mT and (not self.npc_is_box))
	
	self.npc_weight_max:Show( self.npc_is_companion and mL )
	self.npc_trade:Show( mT )
	self.npc_takeall:Show( mL )
	
	-- Upgrade/Repair
	self.npc_up_dialog:Show( mR )
	self.npc_up_faction_dialog:Show( mR )
	self.npc_up_repair:Enable(false)
	
	-- Added by HarukaSai
	self:ShowFaction( "neutral" , "npc" )
	self:RecolorStats()
	
	-- Hints
	self.item_info:Update()
	self.upgr_info:Update()
	self:SetHint(false)
	if self.item_props:IsShown() then
		self.item_props:OnHide()
	end
	
	-- Reset sorting
	self.sort_btn[1]:SetCheck(true)
	self:On_Sort(1, true)
	
	self.upgr 			 = { id = false , sec = false , idx = false , bag = false}
	self.hover           = { idx = false , bag = false, tg = 0 }
	self.slot_hl         = { idx = false , bag = false }
	self.holding_ctrl    = false
	self.holding_shift   = false
	
	-- Allow player movement for this UI
	self:AllowMovement( mI )
end


-- General
function UIInventory:ParseInventory(npc, all, id_list, ignore_kind)

	local inv = {}
	local size_c = 0
	local pkind = self.possible_kind
	local sec, kind, w, h
	local function iterate(owner,obj)
		sec = obj:section()
		kind = SYS_GetParam(0,sec,"kind") or "na"
		
		-- Parsing for kinds, according to sorter
		if ignore_kind or pkind["s_all"] or pkind[kind] then
			if id_list then
				inv[obj:id()] = obj
			else
				size_c = size_c + 1
				inv[size_c] = obj
			end
		end
	end
	if self:IsInvOwner(npc) then
		if all then
			npc:iterate_inventory(iterate,nil)
		else
			npc:iterate_ruck(iterate,nil)
		end
	elseif npc and self.npc_is_box then
		npc:iterate_inventory_box(iterate,nil)
	end
	
	return inv
end

function UIInventory:ParseInventory_Companion(npc, id_list, ignore_kind)
	-- only for alive NPCs, player shouldn't get NPC equipped items
	-- companions are a special case, player can only get their assigned items
	if npc == nil then return end
	local npc_id = npc:id() 
	local inv = {}
	local size_c = 0
	local pkind = self.possible_kind
	local id, sec, kind
	local pass = false
	local is_assigned_item = axr_companions.is_assigned_item
	npc:iterate_inventory( function(owner,obj)
		id = obj:id()
		sec = obj:section()
		kind = SYS_GetParam(0,sec,"kind") or "na"
		pass = false
		
		-- Player's assigned items
		if is_assigned_item(npc_id, id) then 
			pass = true
			
		-- Player's strapped weapons
		elseif IsWeapon(obj) and se_load_var(id, nil, "strapped_item") then 
			pass = true
		end
		
		-- Parsing for kinds, according to sorter
		if pass then
			if ignore_kind or pkind["s_all"] or pkind[kind] then
				if id_list then
					inv[obj:id()] = obj
				else
					size_c = size_c + 1
					inv[size_c] = obj
				end
			end
		end
	end)
	
	return inv
end

function UIInventory:IsMode(bag, mode, ...)
	local bags = {...}
	if (not mode) or (self.mode == mode) then
		for i=1,#bags do
			if bags[i] == bag then
				return true
			end
		end
	end
	return false
end

function UIInventory:Item_On_Mode(name, bag)
	local props = self.properties[name]
	return props.mode[self.mode] and props.cont[bag]
end

function UIInventory:CheckItem(obj, msg)
	if (type(obj) == "number") then
		obj = level.object_by_id(obj)
	end
	if (not obj) then
		callstack()
		printe("!ERROR Can't get item game object!")
	else
		self:Print(nil, msg, obj:name())
	end
	
	return obj
end

function UIInventory:GetPartner()
	if self.npc_id then
		return (db.storage[self.npc_id] and db.storage[self.npc_id].object or level.object_by_id(self.npc_id))
	end
end

function UIInventory:ValidOwner(obj, state)
	local p = obj:parent()
	if (not p) then
		return false
	end
	
	if state then
		return p:id() == AC_ID
	else
		local npc = self:GetPartner()
		return npc and p:id() == npc:id()
	end
end

function UIInventory:IsInvOwner(npc)
-- We need this cause Sid and Forester are not NPCs
	return IsStalker(npc) or self.npc_is_not_npc
end

function UIInventory:InitProperties(obj, bag)
	if not (obj and bag) then
		return
	end
	
	self:Print("InitProperties | bag: %s - obj: %s", bag, obj:name())

	local id = obj:id()
	local mode = self.mode
	local context_str = {}
	local context_action = {}
	local context_params = {}
	
	for n,props in spairs(self.properties, func_index) do
	
		-- Check if prop is aimed for active container
		local bag_allowed = true
		if props.cont then
			bag_allowed = props.cont[bag] and true or false
		end
		if props.cont_func and props.cont_func[1] and self[props.cont_func[1]] then
			bag_allowed = self[props.cont_func[1]](self, obj, bag, unpack(props.cont_func)) and true or false
		end
		
		-- Check if prop is aimed for active mode
		local mode_allowed = true
		if props.mode then
			mode_allowed = props.mode[mode] and true or false
		end
		if props.mode_func and props.mode_func[1] and self[props.mode_func[1]] then
			mode_allowed = self[props.mode_func[1]](self, obj, bag, unpack(props.mode_func)) and true or false
		end
		
		if mode_allowed and bag_allowed then
		
			-- Evaluate preconditions
			local cond = true
			local k = 1
			while cond and props["precondition" .. k] do
				local precond = props["precondition" .. k]
				if precond[1] and self[precond[1]] then
					cond = self[precond[1]](self, obj, bag, unpack(precond)) and true or false
				else
					cond = false
				end
				k = k + 1
			end
			if cond then
				
				-- Get prop name
				local name = props.name or ""
				local func_name = props.name_func
				if func_name and func_name[1] and self[func_name[1]] then
					name = self[func_name[1]](self, id, bag, unpack(func_name)) or name
				end
				table.insert(context_str, name)
				
				-- Get action
				local func_action = props.action
				if func_action and func_action[1] and self[func_action[1]] then
					table.insert(context_action, func_action[1])
					table.insert(context_params, {id, bag, unpack(func_action)})
				end
			end
			
		end
	end
	
	if is_not_empty(context_action) and is_not_empty(context_str) then
		self.item_props:Reset(GetCursorPosition(), context_action, context_str, context_params)
		self:PlaySND(snd_properties)
	end
end

-- Added by HarukaSai and edited by Sota - recolors of stats colors based on settings
function UIInventory:RecolorStats()
	
	local clr_w					= clr_stats_t.w
	
	local use_faction_color		= color_settings.stat_colors
	local use_colored_icons		= color_settings.colored_stat_icons
	local use_colored_stats		= color_settings.colored_stats
	
	for name,v in pairs(self.stat) do
		local color = use_faction_color and self.faction_color or stat_colors[name]
		
		local final_color = use_colored_icons and color or clr_w
		v.ico_def:SetTextureColor( final_color )
		
		local final_color = use_colored_stats and color or clr_w
		v.bar:SetColor( final_color )
	end
end

function UIInventory:Discard()
	self:Print(nil, "Discard")
end


-- Property naming
function UIInventory:Name_Equip(obj, bag)
	obj = self:CheckItem(obj,"Name_Equip")
	
	local clsid = obj:clsid()
	local sec = obj:section()
	if IsOutfit(nil,clsid) then
		return "st_dress_outfit"
	elseif IsHeadgear(nil,clsid) then
		return "st_dress_helmet"
	elseif IsItem("backpack",sec) then
		return "st_equip_backpack"
	elseif IsArtefact(nil,clsid) then
		return "st_move_on_belt"
	end
	return "st_move_to_slot"
end

function UIInventory:Name_UnEquip(obj, bag)
	obj = self:CheckItem(obj,"Name_UnEquip")
	
	local clsid = obj:clsid()
	local sec = obj:section()
	if IsOutfit(nil,clsid) then
		return "st_undress_outfit"
	elseif IsHeadgear(nil,clsid) then
		return "st_undress_helmet"
	elseif IsItem("backpack",sec) then
		return "st_unequip_backpack"
	end
	return "st_unequip"
end

function UIInventory:Name_Attach(obj, bag, temp, slot)
	obj = self:CheckItem(obj,"Name_Attach")
	
	local sec = obj:section()
	local wpn = slot and db.actor:item_in_slot(slot)
	local name = wpn and ui_item.get_obj_name(wpn) or ""
	
	if IsItem("sil",sec) then
		return (gts("st_attach_silencer_to_pistol") .. " (" .. name .. ")")
	elseif IsItem("scope",sec) then
		return (gts("st_attach_scope_to_pistol") .. " (" .. name .. ")")
	elseif IsItem("gl",sec) then
		return (gts("st_attach_gl_to_rifle") .. " (" .. name .. ")")
	end
end

function UIInventory:Name_Move(obj, bag)
	obj = self:CheckItem(obj,"Name_Move")

	if (self.mode == "loot") and (bag == "npc_bag") then
		return "st_move_to_bag"
	end
	return "st_move_to"
end

function UIInventory:Name_Custom(obj, bag, temp, i)
	obj = self:CheckItem(obj,"Name_Custom " .. i)
	
	local sec = obj:section()
	local str = SYS_GetParam(0,sec, "use" .. i .. "_functor")
	if str then
		str = str_explode(str,"%.") -- dot needs escape character!
		if str[1] and str[2] and _G[ str[1] ] and _G[ str[1] ][ str[2] ] then
			return _G[ str[1] ][ str[2] ](obj)
		else
			printe("!ERROR UIInventory:Name_Custom | can't find function (%s) for %s in section [%s]", str[1] .. str[2], "use" .. i .. "_functor", sec)
		end
	end
	return false
end


-- Precondition
function UIInventory:Mode_Custom(obj, bag, temp, i)
	obj = self:CheckItem(obj,"Mode_Custom " .. i)
	
	local mode = self.mode
	local sec = obj:section()
	local str = SYS_GetParam(0,sec, "use" .. i .. "_modes","")
	if str then
		str = str_explode(str,",")
		for i=1,#str do
			if (mode == str[i]) then
				return true
			end
		end
	end
	
	return (mode == "inventory") -- default
end

function UIInventory:Cont_Custom(obj, bag, temp, i)
	obj = self:CheckItem(obj,"Cont_Custom " .. i)
	
	local sec = obj:section()
	local str = SYS_GetParam(0,sec, "use" .. i .. "_containers","")
	if str then
		str = str_explode(str,",")
		for i=1,#str do
			if (bag == str[i]) then
				return true
			end
		end
	end
	
	return (bag == "actor_bag") or (bag == "actor_equ") or (bag == "actor_belt") -- default
end

function UIInventory:DB_Custom(obj, bag, temp, i)
	obj = self:CheckItem(obj,"DB_Custom " .. i)
	
	return SYS_GetParam(1,obj:section(), "use" .. i .. "_allow_db",false)
end


function UIInventory:Cond_Childs(obj, bag)
	obj = self:CheckItem(obj,"Cond_Childs")
	
	if obj and bag then -- GAMMA v0.9.5 fixes
		local ci = self.CC[bag]:GetCell_ID(obj:id())
		return ci.ID == obj:id() and ci:HasChild()
	end
end

function UIInventory:Cond_Use(obj, bag)
	obj = self:CheckItem(obj,"Cond_Use")
	
	return IsItem("consumable",obj:section()) and true or false
end

function UIInventory:Cond_Move(obj, bag, temp, bag_to)
	if (not obj) then
		return false
	end
	obj = self:CheckItem(obj,"Cond_Move")

	self.flags.ret_value = true
	SendScriptCallback("ActorMenu_on_item_before_move", self.flags, self.npc_id, obj, self.mode, self.bag_id[bag])
	if (not self.flags.ret_value) then
		return false
	end
	
	-- For custom use of this function
	if bag_to then
		if (self.mode == "loot") then
			if (bag == "actor_bag") or (bag == "actor_equ") then
				if bag_to ~= "npc_bag" then return false end
			elseif bag_to == "npc_bag" then
				if bag_to ~= "actor_bag" then return false end
			end
			
		elseif (self.mode == "trade") then
			if (bag == "actor_trade_bag") then
				if bag_to ~= "actor_trade" then return false end
			elseif (bag == "actor_trade") then
				if bag_to ~= "actor_trade_bag" then return false end
			elseif (bag == "npc_trade_bag") then
				if bag_to ~= "npc_trade" then return false end
			elseif (bag == "npc_trade") then
				if bag_to ~= "npc_trade_bag" then return false end
			end
		end
	end
	
	-- Don't move quest items
	if (bag == "actor_bag") and self:Cond_Quest(obj, bag) then
		return false
	end
	
	if (self.mode == "loot") then
		local npc = self.npc_id and get_object_by_id(self.npc_id)
		return npc and true or false
		
	elseif (self.mode == "trade") then
		if (bag == "actor_trade") or (bag == "npc_trade") then
			return true
			
		elseif (bag == "actor_trade_bag") or (bag == "npc_trade_bag") then
			return self.CC[bag]:IsTradable(obj)
		end
	end
end

function UIInventory:Cond_Quest(obj, bag)
	obj = self:CheckItem(obj,"Cond_NotQuest")
	
	return (SYS_GetParam(1,obj:section(),"quest_item") == true)
end

function UIInventory:Cond_NotQuest(obj, bag)
	obj = self:CheckItem(obj,"Cond_NotQuest")
	
	return (SYS_GetParam(1,obj:section(),"quest_item") ~= true)
end

function UIInventory:Cond_Attach(obj, bag, temp, slot, wpn)
	obj = self:CheckItem(obj,"Cond_Attach")

	local add_sec = obj:section()
	local is_sil   = IsItem("sil",add_sec)
	local is_scope = IsItem("scope",add_sec)
	local is_gl    = IsItem("gl",add_sec)
	if not (is_sil or is_scope or is_gl) then
		return false
	end
	
	local wpn = wpn or slot and db.actor:item_in_slot(slot)
	if wpn then
		if utils_item.can_attach_scope(wpn, obj) then
			return true
			
		elseif utils_item.can_attach_silencer(wpn, obj) then
			return true
			
		elseif utils_item.can_attach_gl(wpn, obj) then
			return true
		end
	end
	return false
end

function UIInventory:Cond_Equip(obj, bag)
	obj = self:CheckItem(obj,"Cond_Equip")

	-- Attention: equipping something outside of actor inventory will cause a crash!
	if (bag ~= "actor_bag") then
		return false
	end
	
	local sec = obj:section()
	local arty = IsArtefact(obj)
	local slot = (SYS_GetParam(2,sec,"slot") or -1) + 1
	if arty or (slot == 12) or (slot == 13) then
		local outfit = db.actor:item_in_slot(7)
		if outfit then
			local c_outfit = outfit:cast_CustomOutfit()
			if arty then
				local arty_rooms = c_outfit:get_artefact_count() or 0
				local arty_cnt = db.actor:belt_count()
				return (arty_rooms > 0) and (arty_rooms > arty_cnt)
			elseif (slot == 12) then
				return (c_outfit.bIsHelmetAvaliable and true or false)
			elseif (slot == 13) then
				return (c_outfit.bIsBackpackAvaliable and true or false)
			end
		end
	end
	return (not arty) and (SCANNED_SLOTS[slot] == true)
end

function UIInventory:Cond_Unload(obj, bag)
	obj = self:CheckItem(obj,"Cond_Unload")

	local sec = obj:section()
	if IsWeapon(obj) and (not IsItem("fake_ammo_wpn",sec)) then
		return obj:get_ammo_in_magazine() > 0
	end
	return false
end

function UIInventory:Cond_Detach_Silencer(obj, bag)
	obj = self:CheckItem(obj,"Cond_Detach_Silencer")

	return utils_item.has_attached_silencer(obj)
end

function UIInventory:Cond_Detach_Scope(obj, bag)
	obj = self:CheckItem(obj,"Cond_Detach_Scope")
	
	return utils_item.has_attached_scope(obj)
end

function UIInventory:Cond_Detach_GL(obj, bag)
	obj = self:CheckItem(obj,"Cond_Detach_GL")

	return utils_item.has_attached_gl(obj)
end


-- Actions
function UIInventory:Action_Use(obj, bag)
	obj = self:CheckItem(obj,"Action_Use")
	
	-- Force hiding picker on use
	self:Picker_Toggle(nil, nil, nil, true)
	
	if (CInventory__eat(obj) == false) then
		return
	end
	
	db.actor:eat(obj)
	
	-- Sound effect
	self:PlaySND(snd_item_use)
	
	self:On_Item_Update()
end

function UIInventory:Action_Donate(obj, bag)
	obj = self:CheckItem(obj,"Action_Donate")
	
	local npc = self.npc_id and get_object_by_id(self.npc_id)
	if (not npc) then
		return
	end
	
	self:On_Item_Exchange(db.actor, npc, obj)
end

function UIInventory:Action_Move(obj, bag)
	obj = self:CheckItem(obj,"Action_Move")
	
	if (self.mode == "loot") then
		local npc = self.npc_id and get_object_by_id(self.npc_id)
		if (not npc) then
			return
		end
		
		if (bag == "actor_bag") or (bag == "actor_equ") then
			self:On_Item_Exchange(db.actor, npc, obj)
		elseif (bag == "npc_bag") then
			self:On_Item_Exchange(npc, db.actor, obj)
		end

	elseif (self.mode == "trade") then
		local bag_to
		if (bag == "actor_trade")         then bag_to = "actor_trade_bag"
		elseif (bag == "actor_trade_bag") then bag_to = "actor_trade"
		elseif (bag == "npc_trade")       then bag_to = "npc_trade_bag"
		elseif (bag == "npc_trade_bag")   then bag_to = "npc_trade"
		end
		
		-- Make sure item is tradable first
		if (not self.CC[bag]:IsTradable(obj)) then
			return
		end
		
		if bag_to and self.CC[bag_to] then
			self.CC[bag]:TransferItem( self.CC[bag_to] , obj)
			-- GAMMA v0.9.5 sounds compatibility
			itms_manager.play_item_sound(obj)
		end
	end

	SendScriptCallback("ActorMenu_on_item_after_move", self.npc_id, obj, self.mode, self.bag_id[bag])
	
	self:On_Item_Update()
end

function UIInventory:Action_Move_All(obj, bag)
	obj = self:CheckItem(obj,"Action_Move_All")
	
	local ci = self.CC[bag]:GetCell_ID(obj:id())
	for id,_ in pairs(ci.childs) do
		self:Action_Move(id, bag)
	end
	self:Action_Move(obj, bag)
end

function UIInventory:Action_UnEquip(obj, bag)
	obj = self:CheckItem(obj,"Action_UnEquip")

	db.actor:move_to_ruck(obj)
	
	--self:UpdateInfo(true)
	-- GAMMA v0.9.5 sounds compatibility
	--self:PlaySND(snd_item_to_ruck)
	-- FDDAR patch
	if (IsHeadgear(obj) and ui_mcm and ui_mcm.get("fddar/headgear_anm/enable"))
	or (IsItem("backpack", nil, obj) and ui_mcm and ui_mcm.get("fddar/outfit_anm/enable_backpack_equip")) then
		--printf("UIInventory:Action_Equip sound omitted")
	else
		itms_manager.play_item_sound(obj)
	end

	self:On_Item_Update()
end

function UIInventory:Action_Equip(obj, bag)
	obj = self:CheckItem(obj,"Action_Equip")
	
	-- Belt
	if IsArtefact(obj) then
		db.actor:move_to_belt(obj)
		-- GAMMA v0.9.5 sounds compatibility
		--self:PlaySND(snd_item_to_belt)
		itms_manager.play_item_sound(obj)
		
	-- Slots
	else
		-- Gather free compatible slots
		local slot = (SYS_GetParam(2,obj:section(),"slot") or -1) + 1
		local cc = self.CC["actor_equ"]
		local free_slots = {}
		local cslots = self.slot_cell[slot] or {}
		for i=1,#cslots do
			local ci = cc.cell[cslots[i]]
			if ci and (not ci:IsShown()) then
				table.insert(free_slots, cslots[i])
			end
		end
		
		if is_empty(free_slots) then
			db.actor:make_item_active(obj)
		else
			-- Get free slot
			local slot_new = free_slots[1]
			
			-- Just to make sure
			local obj_in = cc:GetObj(slot_new)
			if obj_in then
				db.actor:move_to_ruck(obj_in)
			end
			
			-- Move to slot
			db.actor:move_to_slot(obj, slot_new)
		end
		
		-- GAMMA v0.9.5 sounds compatibility
		--self:PlaySND(snd_item_to_slot)
		-- FDDAR patch
		if (IsHeadgear(obj) and ui_mcm and ui_mcm.get("fddar/headgear_anm/enable"))
		or (IsItem("backpack", nil, obj) and ui_mcm and ui_mcm.get("fddar/outfit_anm/enable_backpack_equip")) then
			--printf("UIInventory:Action_Equip sound omitted")
		else
			itms_manager.play_item_sound(obj)
		end
	end
	
	self:On_Item_Update()
end

function UIInventory:Action_Attach(obj, bag, temp, slot, wpn)
	obj = self:CheckItem(obj,"Action_Attach")

	if (bag ~= "actor_bag") then
		return
	end
	
	local wpn = wpn or slot and db.actor:item_in_slot(slot)
	if (not wpn) then
		return
	end
	
	local add_sec = obj:section()
	local typ = (IsItem("scope",add_sec) and "scope") or (IsItem("sil",add_sec) and "sil") or (IsItem("gl",add_sec) and "gl")
	if (not typ) then
		return
	end
	
	utils_item.attach_addon(wpn, obj, typ, true)

	-- GAMMA v0.9.5 sounds compatibility
	if itms_manager.timeout_snd_on_take then itms_manager.timeout_snd_on_take(50) end
	self:PlaySND(is_gamma and snd_addon["snd_attach_" .. typ] or snd_attach_addon)
	self:On_Item_Update()
end

function UIInventory:Action_Custom(obj, bag, temp, i)
	obj = self:CheckItem(obj,"Action_Custom " .. i)
	
	local sec = obj:section()
	local str = SYS_GetParam(0,sec, "use" .. i .. "_action_functor")
	if str then
		str = str_explode(str,"%.") -- dot needs escape character!
		if str[1] and str[2] and _G[ str[1] ] and _G[ str[1] ][ str[2] ] then
			_G[ str[1] ][ str[2] ](obj) -- excute
		else
			printe("!ERROR UIInventory:Action_Custom | can't find function (%s) for %s in section [%s]", str[1] .. str[2], "use" .. i .. "_action_functor", sec)
		end
	end
	
	-- GAMMA v0.9.5 sounds compatibility
	self:PlaySND(snd_button)
	self:On_Item_Update()
end

