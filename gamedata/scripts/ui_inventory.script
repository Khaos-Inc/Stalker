-- to quickly change the function of rounding stats values
local math_abs = math.abs
local math_max = math.max
stats_round_idp = function(num, idp)
	if (num == 0) then
		return num
	end
	idp = idp or 0
	-- small values will not be rounded to 0 at 0 decimal places in mcm
	local num_abs = math_abs(num)
	if (num_abs < 0.1) then
		idp = math_max( 2 , idp )
	elseif (num_abs < 1) then
		idp = math_max( 1 , idp )
	end
	
	return round_idp(num, idp)
end
