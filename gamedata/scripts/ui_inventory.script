		[7]  = {7},          -- Outfit
		[8]  = {8},          -- PDA
		[9]  = {9},          -- Detector
		[10] = {10},         -- Torch
		[11] = {11},         -- Artefact
		[12] = {12},         -- Helmet
		[13] = {13},         -- Backpack
	}
	
	-- Player stats
	self.stat_outfit = {}
	self.stat_helm = {}
	self.stat_arty = {}
	self.stat_boost = {}
	self.stat_list = {
		["health"]		= { min= 0 , max= 1																	, hint= "st_ui_health_sensor_inv"			, title= "st_ui_health_sensor_inv_title"			},
		["radia"]		= { min= 0 , max= (SYS_GetParam(2,"actor_condition","radio_zone_max_power"))		, hint= "ui_inv_radiation_protection"		, title= "ui_inv_radiation_protection_title"		},
		["acid"]		= { min= 0 , max= (SYS_GetParam(2,"actor_condition","acid_zone_max_power"))			, hint= "ui_inv_chemical_burn_protection"	, title= "ui_inv_chemical_burn_protection_title"	},
