        anm_sprint_end_jammed       = pp2000_sprint_end, pp2000_idle_jammed, 0.9

        ;--- Паттерны спринта---

        ts_pattern_sprint_start            = .+, anm_idle_sprint, anm_sprint_start, 1
        ts_pattern_sprint_end              = anm_idle_sprint, ^anm_idle.*, anm_sprint_end
        ts_strict_sprint_end_move          = anm_sprint_start, anm_idle_moving, anm_sprint_end
		
		
