<w>
	<recipe x="346.0625" y="115" width="331.875" height="538" stretch="1">
		<!-- Each element has it's counterpart (main page and recipe page) -->
		<!-- Scrollbars define stretch factor for 2nd page x:1.267 and y:1.05 -->
		
		<!-- Background texture (old letter), parent is recipe -->
		<background_main x="34.875" y="13" width="262.125" height="512" stretch="1">
			<texture>ui_con_checker_window</texture>
		</background_main>
		<background_2 x="0" y="0" width="331.875" height="538" stretch="1">
			<texture>ui_con_checker_window</texture>
		</background_2>
		
		<!-- Frame over the note background texture, parent is recipe -->
		<mainframe x="59.625" y="33" width="225" height="460" stretch="1"/><!-- x+10 -->
		<mainframe_2 x="29.25" y="21" width="284.625" height="480" stretch="1"/><!-- x+10 -->
		
		<!-- Button -->
		<btn_back x="137.8125" y="500" width="56.25" height="20"> <!-- Parent is background_2 -->
			<text font="letterica16" align="c" vert_align="c">ui_mm_back</text>
			<texture>ui_button_ordinary</texture>
		</btn_back>
		
		
		<!-- Title (note name), parent is mainframe -->
		<cap x="0" y="0" width="225" height="50" stretch="1">
			<text complex_mode="1" align="c" vert_align="c" font="letterica18"/>
		</cap>
		<cap_2 x="0" y="0" width="270" height="50" stretch="1"> <!-- Looks better when not in center of page but in center of tool item -->
			<text complex_mode="1" align="c" vert_align="c" font="letterica18"/>
		</cap_2>
		
		<!-- scrollbar for main content, parent is mainframe -->
		<scrollbar x="0" y="50" width="225" height="400" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="10" always_show_scroll="0" stretch="1"/>
		<recipe_area x="0" y="60" width="284.625" height="420" right_ident="0" left_ident="0" top_indent="0" bottom_indent="0" vert_interval="10" always_show_scroll="0" stretch="1"/>
		
		
		
		<!-- text frame in scrollbar, parent is scrollbar -->
		<text_frame x="0" y="0" width="225" height="1" stretch="1"/>
		
		<!-- Note texts, parent is scrollbar -->
		<information width="186.75" height="1">
			<text font="letterica16" complex_mode="1" align="l" vert_align="t" x="19.125" y="0"/>
		</information>
		<information2 width="164.25" height="1">
			<text font="letterica16" complex_mode="1" align="l" vert_align="t" x="30.375" y="0"/>
		</information2>
		<recipes_title x="0" y="0" width="225" height="20">
			<text font="letterica18" complex_mode="1" align="c" vert_align="t"/>
		</recipes_title>
		
		<!-- 
		utils_ui.UICellContainer, parent is scrollbar. it's meant to be static
		element (no double scrollbar), so height is adjusted in script 
		-->
		<recipe_list x="0" y="0" width="225" height="1"/>
		
	</recipe>
</w>
