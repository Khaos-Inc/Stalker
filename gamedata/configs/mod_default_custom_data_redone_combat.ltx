![logic]
active = nil
detail_path_type = smooth
combat_ignore_cond = false
combat_ignore_keep_when_attacked = false
meet = re_meet@actor
danger = {=actor_enemy} re_danger_condition
on_combat = re_combat

![settings]
;reach_distance = 0.01
jog_dist = 7
run_dist = 15
jog_anim = assault
run_anim = rush

[re_meet@actor]
close_anim = {=actor_has_weapon =actor_enemy} threat, {=actor_is_safemode} guard, idle
close_victim = actor
close_distance = 12
far_anim = {=actor_has_weapon =actor_enemy} threat, {=actor_is_safemode} guard, idle
far_victim = actor
far_distance = 24
close_snd_distance = 6
;close_snd_hello = nil
;close_snd_bye = nil
;snd_on_use = nil
use = {=actor_enemy} false, true
;meet_on_talking = true
;allow_break = false
;trade_enable = true

[re_danger_condition] 
ignore_distance_grenade   	= 55
ignore_distance_entity_corpse 	= {=is_dark_night} 25, {=is_night} 35, {=is_heavy_rain} 45, {=is_rain} 55, 60
ignore_distance_entity_attacked = {=is_dark_night} 150, {=is_night} 175, {=is_heavy_rain} 200, {=is_rain} 225, 250
ignore_distance_attacked 	= {=is_dark_night} 340, {=is_night} 345, {=is_heavy_rain} 345, {=is_rain} 350, 350
ignore_distance_bullet_ricochet = 250
ignore_distance_enemy_sound 	= {=is_heavy_rain} 250, {=is_rain} 325, 350
ignore_distance_attack_sound 	= {=is_heavy_rain} 250, {=is_rain} 325, 350
ignore_distance_entity_death 	= {=is_dark_night} 120, {=is_night} 125, {=is_heavy_rain} 125, {=is_rain} 130, 150
ignore_distance_hit		= 350
ignore_distance_sound		= {=is_heavy_rain} 135, {=is_rain} 140, 150
ignore_distance_visual		= {=is_dark_night} 200, {=is_night} 250, {=is_heavy_rain} 250, {=is_rain} 275, 300

[re_combat]
combat_type = {=cond_scheme_cover_dumb()} cover, {=cond_scheme_camper_dumb()} camper, {=cond_scheme_cover_coward()} cover, {=cond_scheme_camper_coward()} camper, {=cond_scheme_stupid()} monolith
